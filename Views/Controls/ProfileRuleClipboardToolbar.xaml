<UserControl x:Class="Gamepad_Mapping.Views.Controls.ProfileRuleClipboardToolbar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="32"
             d:DesignWidth="200">
    <StackPanel Orientation="Horizontal">
        <Button Padding="10,4"
                Margin="0,0,8,4"
                Command="{Binding CopyRuleCommand}"
                ToolTip="{Binding Source={StaticResource Loc}, Path=[ProfileRuleClipboard_CopyTooltip]}">
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ProfileRuleClipboard_Copy]}" />
        </Button>
        <Button Padding="10,4"
                Margin="0,0,8,4"
                Command="{Binding PasteRuleCommand}"
                ToolTip="{Binding Source={StaticResource Loc}, Path=[ProfileRuleClipboard_PasteTooltip]}">
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ProfileRuleClipboard_Paste]}" />
        </Button>
        <Button Padding="10,4"
                Margin="0,0,8,4"
                Command="{Binding UndoWorkspaceEditCommand}"
                ToolTip="{Binding Source={StaticResource Loc}, Path=[ProfileRuleClipboard_UndoTooltip]}">
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ProfileRuleClipboard_Undo]}" />
        </Button>
        <Button Padding="10,4"
                Margin="0,0,0,4"
                Command="{Binding RedoWorkspaceEditCommand}"
                ToolTip="{Binding Source={StaticResource Loc}, Path=[ProfileRuleClipboard_RedoTooltip]}">
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ProfileRuleClipboard_Redo]}" />
        </Button>
    </StackPanel>
</UserControl>
