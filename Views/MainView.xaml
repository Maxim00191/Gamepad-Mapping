<UserControl x:Class="Gamepad_Mapping.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:behaviors="clr-namespace:Gamepad_Mapping.Behaviors"
             xmlns:sections="clr-namespace:Gamepad_Mapping.Views.Sections"
             mc:Ignorable="d"
             behaviors:MainViewKeyboardCaptureBehavior.EnableKeyboardCapture="True"
             Focusable="True"
             Background="{DynamicResource AppBackgroundBrush}"
             Foreground="{DynamicResource AppTextBrush}">
    <UserControl.Resources>
        <Style x:Key="ToolbarToggleButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppControlSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="4"
                                SnapsToDevicePixels="True">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppControlPressedBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AppAccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppControlPressedBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- Prominent entry point for application-wide settings (saved to local config). -->
        <Style x:Key="AppSettingsToolbarToggleStyle" TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource ToolbarToggleButtonStyle}">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="MinWidth" Value="172" />
            <Setter Property="Padding" Value="10,0,14,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        </Style>
    </UserControl.Resources>
    <Grid Margin="12"
          Background="{DynamicResource AppBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="{DynamicResource AppSurfaceBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1"
                CornerRadius="6"
                Padding="12,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Row 0: template picker (full width, scales with window) -->
                <Grid Grid.Row="0"
                      Margin="0,0,0,8"
                      VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" MinWidth="120" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Source={StaticResource Loc}, Path=[Template]}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <ComboBox Grid.Column="1"
                              Height="32"
                              VerticalContentAlignment="Center"
                              ItemsSource="{Binding ProfileTemplatePanel.AvailableTemplates}"
                              DisplayMemberPath="DisplayName"
                              SelectedItem="{Binding ProfileTemplatePanel.SelectedTemplate}" />
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                Margin="6,0,0,0">
                        <Grid>
                            <ToggleButton x:Name="NewConfigButton"
                                          Style="{StaticResource ToolbarToggleButtonStyle}"
                                          Width="32"
                                          Height="32"
                                          HorizontalAlignment="Left"
                                          ToolTip="{Binding Source={StaticResource Loc}, Path=[CreateNewProfile]}">
                                <Viewbox Width="14" Height="14">
                                    <Path Data="M 7 0 L 7 14 M 0 7 L 14 7"
                                          Stroke="{DynamicResource AppTextBrush}"
                                          StrokeThickness="1.35"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          Fill="Transparent" />
                                </Viewbox>
                            </ToggleButton>
                            <Popup Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=NewConfigButton}"
                                   StaysOpen="False"
                                   IsOpen="{Binding IsChecked, ElementName=NewConfigButton, Mode=TwoWay}">
                                <Border Background="{DynamicResource AppSurfaceBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="12"
                                        MinWidth="280">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CreateNewProfile]}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,8" />
                                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[GameKey]}" Margin="0,0,0,4" />
                                        <TextBox Text="{Binding ProfileTemplatePanel.NewProfileGameId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[DisplayName]}" Margin="0,8,0,4" />
                                        <TextBox Text="{Binding ProfileTemplatePanel.NewProfileDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <WrapPanel Margin="0,10,0,0">
                                            <Button Content="{Binding Source={StaticResource Loc}, Path=[CreateProfile]}"
                                                    Command="{Binding ProfileTemplatePanel.CreateProfileCommand}" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                        <Grid Margin="10,0,0,0">
                            <ToggleButton x:Name="AppSettingsButton"
                                          Style="{StaticResource AppSettingsToolbarToggleStyle}"
                                          HorizontalAlignment="Left"
                                          ToolTip="{Binding Source={StaticResource Loc}, Path=[AppSettingsTooltip]}">
                                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsButton]}"
                                           VerticalAlignment="Center" />
                            </ToggleButton>
                            <Popup Placement="Bottom"
                                   PlacementTarget="{Binding ElementName=AppSettingsButton}"
                                   StaysOpen="False"
                                   IsOpen="{Binding IsChecked, ElementName=AppSettingsButton, Mode=TwoWay}">
                                <Border Background="{DynamicResource AppSurfaceBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="6"
                                        Padding="12"
                                        MinWidth="340"
                                        MaxWidth="420">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsHeader]}"
                                                   FontWeight="SemiBold"
                                                   FontSize="14"
                                                   Margin="0,0,0,8" />
                                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsTimingSection]}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,6" />
                                        <UniformGrid Columns="2" Margin="0,0,0,6">
                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ModifierGraceLabel]}"
                                                       Margin="0,0,8,4"
                                                       TextWrapping="Wrap" />
                                            <TextBox Text="{Binding ModifierGraceMsSetting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="88"
                                                     HorizontalAlignment="Left"
                                                     Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[LeadSuppressLabel]}"
                                                       Margin="0,4,8,4"
                                                       TextWrapping="Wrap" />
                                            <TextBox Text="{Binding LeadKeyReleaseSuppressMsSetting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="88"
                                                     HorizontalAlignment="Left"
                                                     Margin="0,4,0,4" />
                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TapHoldLabel]}"
                                                       Margin="0,4,8,4"
                                                       TextWrapping="Wrap" />
                                            <TextBox Text="{Binding KeyboardTapHoldDurationMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="88"
                                                     HorizontalAlignment="Left"
                                                     Margin="0,4,0,4" />
                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TapInterKeyDelayLabel]}"
                                                       Margin="0,4,8,4"
                                                       TextWrapping="Wrap" />
                                            <TextBox Text="{Binding TapInterKeyDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="88"
                                                     HorizontalAlignment="Left"
                                                     Margin="0,4,0,4" />
                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TextInterCharDelayLabel]}"
                                                       Margin="0,4,8,0"
                                                       TextWrapping="Wrap" />
                                            <TextBox Text="{Binding TextInterCharDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="88"
                                                     HorizontalAlignment="Left"
                                                     Margin="0,4,0,0" />
                                        </UniformGrid>

                                        <Separator Margin="0,6,0,8" />

                                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsAnalogSection]}"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,6" />
                                        <UniformGrid Columns="2">
                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[DefaultAnalogThresholdLabel]}"
                                                       Margin="0,0,8,4"
                                                       TextWrapping="Wrap" />
                                            <TextBox Text="{Binding DefaultAnalogActivationThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.00}}"
                                                     Width="88"
                                                     HorizontalAlignment="Left"
                                                     Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[MouseLookSensitivityLabel]}"
                                                       Margin="0,4,8,4"
                                                       TextWrapping="Wrap" />
                                            <TextBox Text="{Binding MouseLookSensitivity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.0}}"
                                                     Width="88"
                                                     HorizontalAlignment="Left"
                                                     Margin="0,4,0,4" />
                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AnalogEpsilonLabel]}"
                                                       Margin="0,4,8,4"
                                                       TextWrapping="Wrap" />
                                            <TextBox Text="{Binding AnalogChangeEpsilon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.000}}"
                                                     Width="88"
                                                     HorizontalAlignment="Left"
                                                     Margin="0,4,0,4" />
                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[PollingIntervalLabel]}"
                                                       Margin="0,4,8,0"
                                                       TextWrapping="Wrap" />
                                            <TextBox Text="{Binding GamepadPollingIntervalMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Width="88"
                                                     HorizontalAlignment="Left"
                                                     Margin="0,4,0,0" />
                                        </UniformGrid>
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </Grid>
                    </StackPanel>
                </Grid>

                <!-- Row 1: display name -->
                <Grid Grid.Row="1"
                      Margin="0,0,0,8"
                      VerticalAlignment="Center">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" MinWidth="120" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Source={StaticResource Loc}, Path=[DisplayName]}"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <TextBox Grid.Column="1"
                             Height="32"
                             VerticalContentAlignment="Center"
                             Text="{Binding ProfileTemplatePanel.CurrentTemplateDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </Grid>

                <!-- Row 2: profile actions -->
                <WrapPanel Grid.Row="2"
                           Margin="0,0,0,8"
                           Orientation="Horizontal">
                    <Button Height="32"
                            MinWidth="72"
                            Padding="10,0"
                            VerticalContentAlignment="Center"
                            Margin="0,0,8,6"
                            Content="{Binding Source={StaticResource Loc}, Path=[SaveProfile]}"
                            Command="{Binding ProfileTemplatePanel.SaveProfileCommand}" />
                    <Button Height="32"
                            MinWidth="72"
                            Padding="10,0"
                            VerticalContentAlignment="Center"
                            Margin="0,0,8,6"
                            Content="{Binding Source={StaticResource Loc}, Path=[DeleteProfile]}"
                            Command="{Binding ProfileTemplatePanel.DeleteSelectedProfileCommand}" />
                    <Button Height="32"
                            MinWidth="72"
                            Padding="10,0"
                            VerticalContentAlignment="Center"
                            Margin="0,0,8,6"
                            Content="{Binding Source={StaticResource Loc}, Path=[ReloadTemplate]}"
                            Command="{Binding ProfileTemplatePanel.ReloadTemplateCommand}" />
                </WrapPanel>

                <!-- Row 3: combo HUD — core on-screen guide; always visible in toolbar -->
                <StackPanel Grid.Row="3" Margin="0,0,0,8">
                    <CheckBox Content="{Binding Source={StaticResource Loc}, Path=[ShowHud]}"
                              IsChecked="{Binding GamepadMonitorPanel.IsHudEnabled, Mode=TwoWay}"
                              VerticalAlignment="Center"
                              FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ComboHudPanelOpacityHint]}"
                               Margin="0,8,0,0"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                               TextWrapping="Wrap"
                               FontSize="11" />
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ComboHudPanelOpacityLabel]}"
                               Margin="0,4,0,2"
                               Foreground="{DynamicResource AppSecondaryTextBrush}" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Slider Width="200"
                                Minimum="24"
                                Maximum="200"
                                Value="{Binding GamepadMonitorPanel.ComboHudPanelAlpha, Mode=TwoWay}"
                                SmallChange="2"
                                LargeChange="16"
                                AutoToolTipPlacement="TopLeft" />
                        <TextBlock VerticalAlignment="Center" Margin="10,0,0,0">
                            <Run Text="{Binding GamepadMonitorPanel.ComboHudPanelAlpha, Mode=OneWay}" />
                            <Run Text="/255" />
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ComboHudShadowOpacityLabel]}"
                               Margin="0,8,0,2"
                               Foreground="{DynamicResource AppSecondaryTextBrush}" />
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Slider Width="200"
                                Minimum="0.08"
                                Maximum="0.55"
                                Value="{Binding GamepadMonitorPanel.ComboHudShadowOpacity, Mode=TwoWay}"
                                TickFrequency="0.02"
                                IsSnapToTickEnabled="True"
                                SmallChange="0.02"
                                LargeChange="0.06"
                                AutoToolTipPlacement="TopLeft" />
                        <TextBlock Text="{Binding GamepadMonitorPanel.ComboHudShadowOpacity, StringFormat={}{0:F2}}"
                                   VerticalAlignment="Center"
                                   Margin="10,0,0,0" />
                    </StackPanel>
                </StackPanel>

                <!-- Row 4: target process name (stored in profile JSON; no running-process picker) -->
                <StackPanel Grid.Row="4">
                    <Grid Margin="0,0,0,6"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" MinWidth="100" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Source={StaticResource Loc}, Path=[ProcessTarget]}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"
                                   TextWrapping="Wrap" />
                        <TextBox Grid.Column="1"
                                 Height="32"
                                 VerticalContentAlignment="Center"
                                 Text="{Binding ProcessTargetPanel.TemplateTargetProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 ToolTip="{Binding Source={StaticResource Loc}, Path=[TargetProcessNameToolTip]}" />
                    </Grid>
                    <TextBlock Text="{Binding ProcessTargetPanel.TargetStatusText}"
                               TextWrapping="Wrap"
                               Margin="0,0,0,6"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                               FontSize="11" />
                    <TextBlock FontSize="11"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                               TextWrapping="Wrap"
                               Text="{Binding Source={StaticResource Loc}, Path=[ProcessRestrictionHint]}" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*" MinWidth="340" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="3*" MinWidth="240" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[MappingListTitle]}"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               DockPanel.Dock="Left" />
                    <Button Content="{Binding Source={StaticResource Loc}, Path=[AddMappingPlus]}"
                            Command="{Binding MappingEditorPanel.AddMappingCommand}"
                            Padding="12,4"
                            HorizontalAlignment="Right"
                            DockPanel.Dock="Right" />
                </DockPanel>

                <sections:MappingEditorView Grid.Row="1"
                                            DataContext="{Binding MappingEditorPanel}" />
            </Grid>

            <GridSplitter Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True"
                          Background="{DynamicResource AppBorderBrush}" />

            <Grid x:Name="RightPanelGrid"
                  Grid.Column="2"
                  Margin="12,0,0,0">
                <!-- Row heights are updated in code-behind so collapsed expanders use Auto (no star "ghost" space). -->
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" MinHeight="0" />
                    <RowDefinition Height="0" MinHeight="0" />
                    <RowDefinition Height="Auto" MinHeight="0" />
                </Grid.RowDefinitions>

                <Expander Grid.Row="0"
                          VerticalAlignment="Stretch"
                          IsExpanded="{Binding MappingEditorPanel.IsMappingDetailsExpanderExpanded, Mode=TwoWay}"
                          Margin="0,0,0,6">
                    <Expander.Header>
                        <!-- Header is hosted inside the expander's template; it does not inherit this page's DataContext, and -->
                        <!-- toggle chrome can impose a light Foreground (invisible on light header backgrounds). -->
                        <Grid DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Expander, Mode=FindAncestor}}">
                            <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                       Text="{Binding Source={StaticResource Loc}, Path=[SelectedMappingDetails]}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MappingEditorPanel.IsCreatingNewMapping}" Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                            <TextBlock Foreground="{DynamicResource AppTextBrush}"
                                       Text="{Binding Source={StaticResource Loc}, Path=[NewMappingDetailsHeader]}"
                                       TextWrapping="Wrap"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="{x:Type TextBlock}">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding MappingEditorPanel.IsCreatingNewMapping}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                    </Expander.Header>
                    <sections:MappingDetailsPanelView DataContext="{Binding MappingEditorPanel}" />
                </Expander>

                <GridSplitter x:Name="RightPanelRowSplitter"
                              Grid.Row="1"
                              Height="6"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Stretch"
                              ResizeDirection="Rows"
                              ResizeBehavior="PreviousAndNext"
                              ShowsPreview="True"
                              Background="{DynamicResource AppBorderBrush}"
                              Visibility="Collapsed" />

                <Expander Grid.Row="2"
                          VerticalAlignment="Stretch"
                          Header="{Binding Source={StaticResource Loc}, Path=[LiveGamepadMonitor]}"
                          IsExpanded="{Binding GamepadMonitorPanel.IsMonitorExpanderExpanded, Mode=TwoWay}"
                          Margin="0,6,0,0">
                    <sections:GamepadMonitorView VerticalAlignment="Stretch"
                                                 DataContext="{Binding GamepadMonitorPanel}" />
                </Expander>
            </Grid>
        </Grid>
    </Grid>
</UserControl>

