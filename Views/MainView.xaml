<UserControl x:Class="Gamepad_Mapping.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:GamepadMapperGUI.Models"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:behaviors="clr-namespace:Gamepad_Mapping.Behaviors"
             xmlns:sections="clr-namespace:Gamepad_Mapping.Views.Sections"
             xmlns:local="clr-namespace:Gamepad_Mapping.Views"
             xmlns:utils="clr-namespace:Gamepad_Mapping.Utils"
             mc:Ignorable="d"
             behaviors:MainViewKeyboardCaptureBehavior.EnableKeyboardCapture="True"
             Focusable="True"
             Background="{DynamicResource AppBackgroundBrush}"
             Foreground="{DynamicResource AppTextBrush}">
   <Grid>
       <Grid Margin="12"
             Background="{DynamicResource AppBackgroundBrush}">
       <Grid.ColumnDefinitions>
           <ColumnDefinition Width="*" />
           <ColumnDefinition Width="Auto" />
       </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Style="{StaticResource SectionCardBorder}"
                Padding="12,10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Row 0: template picker (full width, scales with window) -->
                    <Grid Grid.Row="0"
                          Margin="0,0,0,8"
                          VerticalAlignment="Center">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" MinWidth="120" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Source={StaticResource Loc}, Path=[Template]}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0" />
                        <ComboBox Grid.Column="1"
                                  Height="32"
                                  VerticalContentAlignment="Center"
                                  ItemsSource="{Binding ProfileTemplatePanel.AvailableTemplates}"
                                  DisplayMemberPath="DisplayName"
                                  SelectedItem="{Binding ProfileTemplatePanel.SelectedTemplate}" />
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    HorizontalAlignment="Right"
                                    Margin="6,0,0,0">
                            <Button Style="{StaticResource ToolbarButtonStyle}"
                                    Width="32"
                                    Height="32"
                                    Command="{Binding ProfileTemplatePanel.RefreshTemplatesFromDiskCommand}"
                                    ToolTip="{Binding Source={StaticResource Loc}, Path=[RefreshTemplatesTooltip]}">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE72C;"
                                           FontSize="14"
                                           VerticalAlignment="Center"
                                           HorizontalAlignment="Center" />
                            </Button>
                            <Grid Margin="6,0,0,0">
                                <ToggleButton x:Name="NewConfigButton"
                                              Style="{StaticResource ToolbarToggleButtonStyle}"
                                              Width="32"
                                              Height="32"
                                              HorizontalAlignment="Left"
                                              ToolTip="{Binding Source={StaticResource Loc}, Path=[CreateNewProfile]}">
                                    <Viewbox Width="14" Height="14">
                                        <Path Data="M 7 0 L 7 14 M 0 7 L 14 7"
                                              Stroke="{DynamicResource AppTextBrush}"
                                              StrokeThickness="1.35"
                                              StrokeStartLineCap="Round"
                                              StrokeEndLineCap="Round"
                                              Fill="Transparent" />
                                    </Viewbox>
                                </ToggleButton>
                                <Popup Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=NewConfigButton}"
                                       StaysOpen="False"
                                       IsOpen="{Binding IsChecked, ElementName=NewConfigButton, Mode=TwoWay}">
                                    <Border Style="{StaticResource SectionCardBorder}"
                                            MinWidth="280">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CreateNewProfile]}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,8" />

                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[DisplayName]}"
                                                       Margin="0,0,0,4" />
                                            <TextBox Text="{Binding ProfileTemplatePanel.NewProfileDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,0,8" />

                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TemplateAuthor]}"
                                                       Margin="0,0,0,4" />
                                            <TextBox Text="{Binding ProfileTemplatePanel.NewProfileAuthor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     Margin="0,0,0,8" />

                                            <Expander IsExpanded="False"
                                                      Margin="0,0,0,4">
                                                <Expander.Header>
                                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TemplateIdentityHeader]}"
                                                               FontWeight="SemiBold" />
                                                </Expander.Header>
                                                <StackPanel Margin="0,6,0,0">
                                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ProfileId]}"
                                                               Margin="0,0,0,4" />
                                                    <TextBox Text="{Binding ProfileTemplatePanel.NewProfileId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Margin="0,0,0,8" />

                                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[GameKey]}"
                                                               Margin="0,0,0,4" />
                                                    <TextBox Text="{Binding ProfileTemplatePanel.NewProfileTemplateGroupId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Margin="0,0,0,8" />

                                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TemplateCatalogFolder]}"
                                                               Margin="0,0,0,4" />
                                                    <TextBox Text="{Binding ProfileTemplatePanel.NewProfileCatalogFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                </StackPanel>
                                            </Expander>

                                            <WrapPanel Margin="0,10,0,0">
                                                <Button Content="{Binding Source={StaticResource Loc}, Path=[CreateProfile]}"
                                                        Command="{Binding ProfileTemplatePanel.CreateProfileCommand}" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                            <Grid Margin="10,0,0,0">
                                <ToggleButton x:Name="AppSettingsButton"
                                              Style="{StaticResource AppSettingsToolbarToggleStyle}"
                                              HorizontalAlignment="Left"
                                              ToolTip="{Binding Source={StaticResource Loc}, Path=[AppSettingsTooltip]}">
                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsButton]}"
                                               VerticalAlignment="Center" />
                                </ToggleButton>
                                <Popup Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=AppSettingsButton}"
                                       StaysOpen="False"
                                       IsOpen="{Binding IsChecked, ElementName=AppSettingsButton, Mode=TwoWay}">
                                    <Border Style="{StaticResource SectionCardBorder}"
                                            MinWidth="340"
                                            MaxWidth="420">
                                        <StackPanel>
                                            <StackPanel.Resources>
                                                <Style x:Key="FlatSectionToggleStyle" TargetType="ToggleButton">
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="BorderThickness" Value="0" />
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="Margin" Value="0,0,0,4" />
                                                    <Setter Property="HorizontalContentAlignment" Value="Left" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="ToggleButton">
                                                                <Grid Background="Transparent">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="14" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Path x:Name="Arrow"
                                                                          Grid.Column="0"
                                                                          Width="7"
                                                                          Height="7"
                                                                          Margin="0,0,6,0"
                                                                          VerticalAlignment="Center"
                                                                          Fill="{DynamicResource AppSecondaryTextBrush}"
                                                                          Data="M 0 0 L 7 3.5 L 0 7 Z" />
                                                                    <ContentPresenter Grid.Column="1"
                                                                                      VerticalAlignment="Center"
                                                                                      RecognizesAccessKey="True" />
                                                                </Grid>
                                                                <ControlTemplate.Triggers>
                                                                    <Trigger Property="IsChecked" Value="True">
                                                                        <Setter TargetName="Arrow" Property="RenderTransform">
                                                                            <Setter.Value>
                                                                                <RotateTransform Angle="90" CenterX="3.5" CenterY="3.5" />
                                                                            </Setter.Value>
                                                                        </Setter>
                                                                        <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource AppTextBrush}" />
                                                                    </Trigger>
                                                                </ControlTemplate.Triggers>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                </Style>
                                            </StackPanel.Resources>
                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsHeader]}"
                                                       FontWeight="SemiBold"
                                                       FontSize="14"
                                                       Margin="0,0,0,8" />
                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsLanguageSection]}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,6" />
                                            <UniformGrid Columns="2" Margin="0,0,0,6">
                                                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppLanguageLabel]}"
                                                           Margin="0,0,8,0"
                                                           TextWrapping="Wrap" />
                                                <ComboBox Width="140"
                                                          HorizontalAlignment="Left"
                                                          ItemsSource="{Binding AvailableUiLanguages}"
                                                          SelectedItem="{Binding SelectedUiLanguage, Mode=TwoWay}"
                                                          DisplayMemberPath="DisplayName" />
                                            </UniformGrid>

                                            <Separator Margin="0,6,0,8" />

                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[UpdateCheckForUpdates], Mode=OneWay}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,6" />
                                            <Grid DataContext="{Binding UpdatePanel}">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                
                                                <StackPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                                                    <CheckBox Content="{Binding Source={StaticResource Loc}, Path=[UpdateIncludePrereleases], Mode=OneWay}"
                                                              IsChecked="{Binding IncludePrereleases, Mode=TwoWay}"
                                                              Margin="0,0,0,4"
                                                              FontSize="11" />
                                                    <TextBlock FontSize="11" Foreground="{DynamicResource AppSecondaryTextBrush}">
                                                        <Run Text="{Binding Source={StaticResource Loc}, Path=[UpdateCurrentVersion], Mode=OneWay}" />
                                                        <Run Text=": " />
                                                        <Run Text="{Binding CurrentVersion, Mode=OneWay}" />
                                                    </TextBlock>
                                                    <TextBlock FontSize="11" Foreground="{DynamicResource AppSecondaryTextBrush}">
                                                        <Run Text="{Binding Source={StaticResource Loc}, Path=[UpdateLatestVersion], Mode=OneWay}" />
                                                        <Run Text=": " />
                                                        <Run Text="{Binding LatestVersion, Mode=OneWay, TargetNullValue='Unknown'}" />
                                                    </TextBlock>
                                                    <TextBlock FontSize="11" Foreground="{DynamicResource AppSecondaryTextBrush}">
                                                        <Run Text="{Binding Source={StaticResource Loc}, Path=[UpdateInstallMode], Mode=OneWay}" />
                                                        <Run Text=": " />
                                                        <Run Text="{Binding InstallModeText, Mode=OneWay}" />
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding StatusMessage}" 
                                                               FontSize="11" 
                                                               FontWeight="SemiBold"
                                                               Margin="0,2,0,0"
                                                               TextWrapping="Wrap">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsUpdateAvailable}" Value="True">
                                                                        <Setter Property="Foreground" Value="{DynamicResource AppAccentTextBrush}" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsForbidden}" Value="True">
                                                                        <Setter Property="Foreground" Value="#EB5757" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                </StackPanel>

                                                <StackPanel Grid.Row="0"
                                                            Grid.Column="1"
                                                            VerticalAlignment="Center">
                                                    <Button Content="{Binding Source={StaticResource Loc}, Path=[UpdateCheckButton], Mode=OneWay}"
                                                            Padding="12,4"
                                                            VerticalAlignment="Center"
                                                            Command="{Binding CheckUpdateCommand}"
                                                            IsEnabled="{Binding IsChecking, Converter={StaticResource InverseBooleanConverter}}" />
                                                    <Button Content="{Binding Source={StaticResource Loc}, Path=[UpdateInstallButton], Mode=OneWay}"
                                                            Margin="0,6,0,0"
                                                            Padding="12,4"
                                                            VerticalAlignment="Center"
                                                            Command="{Binding InstallUpdateCommand}" />
                                                </StackPanel>

                                                <Grid Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0"
                                                      Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Button Grid.Column="0"
                                                            Content="{Binding DownloadPrimaryActionText}"
                                                            Padding="0,6"
                                                            Style="{StaticResource AppAccentButtonStyle}"
                                                            Command="{Binding DownloadOrStopCommand}" />
                                                    <Border Grid.Column="1" />
                                                </Grid>

                                                <Grid Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,8,0,0"
                                                      Visibility="{Binding IsUpdateAvailable, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>
                                                    <ProgressBar Grid.Row="0"
                                                                 Height="8"
                                                                 Minimum="0"
                                                                 Maximum="100"
                                                                 Value="{Binding DownloadProgressPercent}" />
                                                    <TextBlock Grid.Row="1"
                                                               Margin="0,4,0,0"
                                                               FontSize="10"
                                                               Foreground="{DynamicResource AppSecondaryTextBrush}">
                                                        <Run Text="{Binding Source={StaticResource Loc}, Path=[UpdateDownloadSpeedLabel], Mode=OneWay}" />
                                                        <Run Text=": " />
                                                        <Run Text="{Binding DownloadSpeedText}" />
                                                        <Run Text="  |  " />
                                                        <Run Text="{Binding Source={StaticResource Loc}, Path=[UpdateDownloadTimeLeftLabel], Mode=OneWay}" />
                                                        <Run Text=": " />
                                                        <Run Text="{Binding DownloadEtaText}" />
                                                    </TextBlock>
                                                </Grid>

                                                <Button Grid.Row="3" Grid.Column="0" Grid.ColumnSpan="2"
                                                        Content="{Binding Source={StaticResource Loc}, Path=[UpdateOpenGitHubReleases], Mode=OneWay}"
                                                        Margin="0,8,0,0"
                                                        Padding="0,6"
                                                        Command="{Binding OpenManualUrlCommand}"
                                                        Visibility="{Binding IsForbidden, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                            </Grid>

                                            <Separator Margin="0,6,0,8" />

                                            <ToggleButton x:Name="TimingSettingsToggle"
                                                          Style="{StaticResource FlatSectionToggleStyle}">
                                                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsTimingSection]}"
                                                           FontWeight="SemiBold"
                                                           FontSize="12" />
                                            </ToggleButton>
                                            <UniformGrid Columns="2"
                                                         Margin="0,2,0,0"
                                                         Visibility="{Binding IsChecked, ElementName=TimingSettingsToggle, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ModifierGraceLabel]}"
                                                               Margin="0,0,8,4"
                                                               TextWrapping="Wrap" />
                                                    <TextBox Text="{Binding ModifierGraceMsSetting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="88"
                                                             HorizontalAlignment="Left"
                                                             Margin="0,0,0,4" />
                                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[LeadSuppressLabel]}"
                                                               Margin="0,4,8,4"
                                                               TextWrapping="Wrap" />
                                                    <TextBox Text="{Binding LeadKeyReleaseSuppressMsSetting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="88"
                                                             HorizontalAlignment="Left"
                                                             Margin="0,4,0,4" />
                                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TapHoldLabel]}"
                                                               Margin="0,4,8,4"
                                                               TextWrapping="Wrap" />
                                                    <TextBox Text="{Binding KeyboardTapHoldDurationMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="88"
                                                             HorizontalAlignment="Left"
                                                             Margin="0,4,0,4" />
                                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TapInterKeyDelayLabel]}"
                                                               Margin="0,4,8,4"
                                                               TextWrapping="Wrap" />
                                                    <TextBox Text="{Binding TapInterKeyDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="88"
                                                             HorizontalAlignment="Left"
                                                             Margin="0,4,0,4" />
                                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TextInterCharDelayLabel]}"
                                                               Margin="0,4,8,0"
                                                               TextWrapping="Wrap" />
                                                    <TextBox Text="{Binding TextInterCharDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="88"
                                                             HorizontalAlignment="Left"
                                                             Margin="0,4,0,0" />
                                            </UniformGrid>

                                            <ToggleButton x:Name="AnalogSettingsToggle"
                                                          Style="{StaticResource FlatSectionToggleStyle}">
                                                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsAnalogSection]}"
                                                           FontWeight="SemiBold"
                                                           FontSize="12" />
                                            </ToggleButton>
                                            <UniformGrid Columns="2"
                                                         Margin="0,2,0,0"
                                                         Visibility="{Binding IsChecked, ElementName=AnalogSettingsToggle, Converter={StaticResource BooleanToVisibilityConverter}}">
                                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[DefaultAnalogThresholdLabel]}"
                                                               Margin="0,0,8,4"
                                                               TextWrapping="Wrap" />
                                                    <TextBox Text="{Binding DefaultAnalogActivationThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.00}}"
                                                             Width="88"
                                                             HorizontalAlignment="Left"
                                                             Margin="0,0,0,4" />
                                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[MouseLookSensitivityLabel]}"
                                                               Margin="0,4,8,4"
                                                               TextWrapping="Wrap" />
                                                    <TextBox Text="{Binding MouseLookSensitivity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.0}}"
                                                             Width="88"
                                                             HorizontalAlignment="Left"
                                                             Margin="0,4,0,4" />
                                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AnalogEpsilonLabel]}"
                                                               Margin="0,4,8,4"
                                                               TextWrapping="Wrap" />
                                                    <TextBox Text="{Binding AnalogChangeEpsilon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.000}}"
                                                             Width="88"
                                                             HorizontalAlignment="Left"
                                                             Margin="0,4,0,4" />
                                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[PollingIntervalLabel]}"
                                                               Margin="0,4,8,0"
                                                               TextWrapping="Wrap" />
                                                    <TextBox Text="{Binding GamepadPollingIntervalMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             Width="88"
                                                             HorizontalAlignment="Left"
                                                             Margin="0,4,0,4" />
                                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[RadialMenuConfirmModeLabel]}"
                                                               Margin="0,4,8,4"
                                                               TextWrapping="Wrap" />
                                                    <ComboBox SelectedIndex="{Binding RadialMenuConfirmModeIndex, Mode=TwoWay}"
                                                              HorizontalAlignment="Stretch"
                                                              Margin="0,4,0,0">
                                                        <ComboBoxItem Content="{Binding Source={StaticResource Loc}, Path=[RadialMenuConfirmModeReturnCenter]}" />
                                                        <ComboBoxItem Content="{Binding Source={StaticResource Loc}, Path=[RadialMenuConfirmModeReleaseGuide]}" />
                                                    </ComboBox>
                                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[RadialMenuHudLabelModeLabel]}"
                                                               Margin="0,4,8,4"
                                                               TextWrapping="Wrap" />
                                                    <ComboBox SelectedIndex="{Binding RadialMenuHudLabelModeIndex, Mode=TwoWay}"
                                                              HorizontalAlignment="Stretch"
                                                              Margin="0,4,0,0">
                                                        <ComboBoxItem Content="{Binding Source={StaticResource Loc}, Path=[RadialMenuHudLabelModeBoth]}" />
                                                        <ComboBoxItem Content="{Binding Source={StaticResource Loc}, Path=[RadialMenuHudLabelModeDescriptionOnly]}" />
                                                        <ComboBoxItem Content="{Binding Source={StaticResource Loc}, Path=[RadialMenuHudLabelModeKeyboardKeyOnly]}" />
                                                    </ComboBox>
                                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[RadialHudScaleLabel]}"
                                                               Margin="0,8,8,4"
                                                               TextWrapping="Wrap" />
                                                    <StackPanel Orientation="Horizontal"
                                                                Margin="0,8,0,0"
                                                                VerticalAlignment="Center">
                                                        <Slider Width="168"
                                                                Minimum="{x:Static utils:RadialHudLayout.MinHudScale}"
                                                                Maximum="{x:Static utils:RadialHudLayout.MaxHudScale}"
                                                                SmallChange="0.05"
                                                                LargeChange="0.25"
                                                                TickFrequency="0.25"
                                                                IsSnapToTickEnabled="False"
                                                                VerticalAlignment="Center"
                                                                Value="{Binding RadialHudScaleSetting, Mode=TwoWay}" />
                                                        <TextBlock VerticalAlignment="Center"
                                                                   Margin="10,0,0,0"
                                                                   MinWidth="40"
                                                                   Text="{Binding RadialHudScaleSetting, StringFormat={}{0:0.##}}" />
                                                    </StackPanel>
                                            </UniformGrid>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                            <ToggleButton x:Name="MonitorToggleButton"
                                          Margin="10,0,0,0"
                                          MinHeight="32"
                                          VerticalAlignment="Center"
                                          ToolTip="{Binding Source={StaticResource Loc}, Path=[LiveGamepadMonitor]}"
                                          IsChecked="{Binding GamepadMonitorPanel.IsMonitorExpanderExpanded, Mode=TwoWay}">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton"
                                           BasedOn="{StaticResource ToolbarToggleButtonStyle}">
                                        <Setter Property="Padding" Value="8,0,12,0" />
                                        <Setter Property="HorizontalContentAlignment" Value="Left" />
                                        <Setter Property="Visibility" Value="Visible" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding GamepadMonitorPanel.IsMonitorExpanderExpanded}"
                                                         Value="True">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Viewbox Width="10"
                                             Height="10"
                                             VerticalAlignment="Center"
                                             Margin="0,0,8,0">
                                        <Path Data="M2,2 L10,6 L2,10 Z"
                                              Fill="{DynamicResource AppTextBrush}" />
                                    </Viewbox>
                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[LiveGamepadMonitor]}"
                                               VerticalAlignment="Center"
                                               FontWeight="SemiBold" />
                                </StackPanel>
                            </ToggleButton>
                        </StackPanel>
                    </Grid>

                    <sections:TemplateIdentityFormView Grid.Row="1"
                                                       Margin="0,0,0,8"
                                                       DataContext="{Binding ProfileTemplatePanel}" />

                    <!-- Row 2: profile actions -->
                    <WrapPanel Grid.Row="2"
                               Margin="0,0,0,8"
                               Orientation="Horizontal">
                        <Button Height="32"
                                MinWidth="72"
                                Padding="10,0"
                                VerticalContentAlignment="Center"
                                Margin="0,0,8,6"
                                Content="{Binding Source={StaticResource Loc}, Path=[SaveProfile]}"
                                Command="{Binding ProfileTemplatePanel.SaveProfileCommand}" />
                        <Button Height="32"
                                MinWidth="72"
                                Padding="10,0"
                                VerticalContentAlignment="Center"
                                Margin="0,0,8,6"
                                Content="{Binding Source={StaticResource Loc}, Path=[DeleteProfile]}"
                                Command="{Binding ProfileTemplatePanel.DeleteSelectedProfileCommand}" />
                        <Button Height="32"
                                MinWidth="72"
                                Padding="10,0"
                                VerticalContentAlignment="Center"
                                Margin="0,0,8,6"
                                Content="{Binding Source={StaticResource Loc}, Path=[ReloadTemplate]}"
                                Command="{Binding ProfileTemplatePanel.ReloadTemplateCommand}" />
                    </WrapPanel>

                    <!-- Row 3: combo HUD — core on-screen guide; always visible in toolbar -->
                    <StackPanel Grid.Row="3" Margin="0,0,0,8">
                        <Grid VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <CheckBox Grid.Column="0"
                                      Content="{Binding Source={StaticResource Loc}, Path=[ShowHud]}"
                                      IsChecked="{Binding GamepadMonitorPanel.IsHudEnabled, Mode=TwoWay}"
                                      VerticalAlignment="Center"
                                      FontWeight="SemiBold" />
                            <Grid Grid.Column="1">
                                <ToggleButton x:Name="HudAppearanceButton"
                                              Style="{StaticResource ToolbarToggleButtonStyle}"
                                              MinHeight="28"
                                              Padding="10,2"
                                              HorizontalAlignment="Right">
                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ComboHudAppearanceButton]}" />
                                </ToggleButton>
                                <Popup Placement="Bottom"
                                       PlacementTarget="{Binding ElementName=HudAppearanceButton}"
                                       StaysOpen="False"
                                       IsOpen="{Binding IsChecked, ElementName=HudAppearanceButton, Mode=TwoWay}">
                                    <Border Style="{StaticResource SectionCardBorder}"
                                            MinWidth="320"
                                            MaxWidth="360">
                                        <StackPanel>
                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ComboHudAppearanceHeader]}"
                                                       FontWeight="SemiBold"
                                                       Margin="0,0,0,8" />
                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ComboHudPanelOpacityHint]}"
                                                       Margin="0,0,0,6"
                                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                       TextWrapping="Wrap"
                                                       FontSize="11" />
                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ComboHudPanelOpacityLabel]}"
                                                       Margin="0,2,0,2"
                                                       Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Slider Width="200"
                                                        Minimum="24"
                                                        Maximum="200"
                                                        Value="{Binding GamepadMonitorPanel.ComboHudPanelAlpha, Mode=TwoWay}"
                                                        SmallChange="2"
                                                        LargeChange="16"
                                                        AutoToolTipPlacement="TopLeft" />
                                                <TextBlock VerticalAlignment="Center"
                                                           Margin="10,0,0,0">
                                                    <Run Text="{Binding GamepadMonitorPanel.ComboHudPanelAlpha, Mode=OneWay}" />
                                                    <Run Text="/255" />
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ComboHudShadowOpacityLabel]}"
                                                       Margin="0,8,0,2"
                                                       Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Slider Width="200"
                                                        Minimum="0.08"
                                                        Maximum="0.55"
                                                        Value="{Binding GamepadMonitorPanel.ComboHudShadowOpacity, Mode=TwoWay}"
                                                        TickFrequency="0.02"
                                                        IsSnapToTickEnabled="True"
                                                        SmallChange="0.02"
                                                        LargeChange="0.06"
                                                        AutoToolTipPlacement="TopLeft" />
                                                <TextBlock Text="{Binding GamepadMonitorPanel.ComboHudShadowOpacity, StringFormat={}{0:F2}}"
                                                           VerticalAlignment="Center"
                                                           Margin="10,0,0,0" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ComboHudPlacementLabel]}"
                                                       Margin="0,8,0,2"
                                                       Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                            <ComboBox Width="210"
                                                      HorizontalAlignment="Left"
                                                      SelectedValuePath="Tag"
                                                      SelectedValue="{Binding ComboHudPlacementSetting, Mode=TwoWay}">
                                                <ComboBoxItem Tag="{x:Static models:ComboHudPlacement.TopLeft}"
                                                              Content="{Binding Source={StaticResource Loc}, Path=[ComboHudPlacementTopLeft]}" />
                                                <ComboBoxItem Tag="{x:Static models:ComboHudPlacement.TopRight}"
                                                              Content="{Binding Source={StaticResource Loc}, Path=[ComboHudPlacementTopRight]}" />
                                                <ComboBoxItem Tag="{x:Static models:ComboHudPlacement.BottomLeft}"
                                                              Content="{Binding Source={StaticResource Loc}, Path=[ComboHudPlacementBottomLeft]}" />
                                                <ComboBoxItem Tag="{x:Static models:ComboHudPlacement.BottomRight}"
                                                              Content="{Binding Source={StaticResource Loc}, Path=[ComboHudPlacementBottomRight]}" />
                                                <ComboBoxItem Tag="{x:Static models:ComboHudPlacement.Center}"
                                                              Content="{Binding Source={StaticResource Loc}, Path=[ComboHudPlacementCenter]}" />
                                            </ComboBox>
                                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TemplateSwitchHudDurationHeader]}"
                                                       Margin="0,8,0,2"
                                                       Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                            <StackPanel Orientation="Horizontal"
                                                        VerticalAlignment="Center">
                                                <Slider Width="200"
                                                        Minimum="0.5"
                                                        Maximum="5"
                                                        Value="{Binding GamepadMonitorPanel.TemplateSwitchHudSeconds, Mode=TwoWay}"
                                                        TickFrequency="0.1"
                                                        IsSnapToTickEnabled="True"
                                                        AutoToolTipPlacement="TopLeft" />
                                                <TextBlock Text="{Binding GamepadMonitorPanel.TemplateSwitchHudSeconds, StringFormat={}{0:0.0}s}"
                                                           VerticalAlignment="Center"
                                                           Margin="10,0,0,0" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Grid>
                    </StackPanel>

                    <!-- Row 4: target process name (stored in profile JSON; no running-process picker) -->
                    <StackPanel Grid.Row="4">
                        <Grid Margin="0,0,0,6"
                              VerticalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" MinWidth="100" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding Source={StaticResource Loc}, Path=[ProcessTarget]}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       TextWrapping="Wrap" />
                            <TextBox Grid.Column="1"
                                     Height="32"
                                     VerticalContentAlignment="Center"
                                     Text="{Binding ProcessTargetPanel.TemplateTargetProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="{Binding Source={StaticResource Loc}, Path=[TargetProcessNameToolTip]}" />
                        </Grid>
                        <TextBlock Text="{Binding ProcessTargetPanel.TargetStatusText}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,6"
                                   Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   FontSize="11" />
                        <TextBlock FontSize="11"
                                   Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding Source={StaticResource Loc}, Path=[ProcessRestrictionHint]}" />
                    </StackPanel>
                </Grid>
        </Border>

        <!-- Monitor panel occupies a dedicated column when expanded. -->
        <Border Grid.Row="0"
                Grid.Column="1"
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Margin="12,0,0,0"
                Width="320"
                Panel.ZIndex="1">
            <Border.Style>
                <Style TargetType="Border"
                       BasedOn="{StaticResource SectionCardBorder}">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding GamepadMonitorPanel.IsMonitorExpanderExpanded}"
                                     Value="True">
                            <Setter Property="Visibility" Value="Visible" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </Border.Style>
            <Grid>
                <DockPanel LastChildFill="True">
                    <Grid DockPanel.Dock="Top"
                          Margin="8,6,8,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0"
                                   Text="{Binding Source={StaticResource Loc}, Path=[LiveGamepadMonitor]}"
                                   FontWeight="SemiBold"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Width="28"
                                Height="28"
                                Padding="0"
                                VerticalAlignment="Center"
                                Command="{Binding GamepadMonitorPanel.CollapseMonitorCommand}">
                            <Viewbox Width="10" Height="10">
                                <Path Data="M2,2 L10,10 M10,2 L2,10"
                                      Stroke="{DynamicResource AppTextBrush}"
                                      StrokeThickness="1.6"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round" />
                            </Viewbox>
                        </Button>
                    </Grid>
                    <sections:GamepadMonitorView DataContext="{Binding GamepadMonitorPanel}"
                                                 Margin="8,0,8,8" />
                </DockPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2"
              Grid.ColumnSpan="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*" MinWidth="340" />
                <ColumnDefinition Width="6" />
                <ColumnDefinition Width="3*" MinWidth="280" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Row="0"
                        Grid.ColumnSpan="3"
                        Margin="0,0,0,8">
                <Border Visibility="{Binding CatalogPanel.HasErrors, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Background="#1AEB5757"
                        BorderBrush="#EB5757"
                        BorderThickness="1,0,0,0"
                        Padding="12,8">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10,10-4.48,10-10S17.52,2,12,2Zm1,15h-2v-2h2v2Zm0-4h-2V7h2v6Z"
                                  Fill="#EB5757" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="Validation Errors" Foreground="#EB5757" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding CatalogPanel.ValidationErrors}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,2,0,0">
                                        <Ellipse Width="5"
                                                 Height="5"
                                                 Fill="{DynamicResource AppSecondaryTextBrush}"
                                                 VerticalAlignment="Top"
                                                 Margin="0,5,8,0" />
                                        <TextBlock Text="{Binding}"
                                                   Foreground="{DynamicResource AppTextBrush}"
                                                   TextWrapping="Wrap"
                                                   FontSize="12"
                                                   Opacity="0.9" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
                <Border Visibility="{Binding CatalogPanel.HasWarnings, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Background="#1AF2994A"
                        BorderBrush="#F2994A"
                        BorderThickness="1,0,0,0"
                        Padding="12,8"
                        Margin="0,12,0,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Path Data="M1,21H23L12,2L1,21ZM13,18H11V16H13V18ZM13,14H11V10H13V14Z"
                                  Fill="#F2994A" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="Validation Warnings" Foreground="#F2994A" FontWeight="SemiBold" VerticalAlignment="Center" />
                        </StackPanel>
                        <ItemsControl ItemsSource="{Binding CatalogPanel.ValidationWarnings}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,2,0,0">
                                        <Ellipse Width="5"
                                                 Height="5"
                                                 Fill="{DynamicResource AppSecondaryTextBrush}"
                                                 VerticalAlignment="Top"
                                                 Margin="0,5,8,0" />
                                        <TextBlock Text="{Binding}"
                                                   Foreground="{DynamicResource AppTextBrush}"
                                                   TextWrapping="Wrap"
                                                   FontSize="12"
                                                   Opacity="0.9" />
                                    </StackPanel>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </Border>
            </StackPanel>

            <Border Grid.Row="1"
                    Grid.Column="0"
                    Style="{StaticResource SectionCardBorder}"
                    Padding="0">
                <TabControl Style="{StaticResource MainWorkspaceTabControl}"
                            ItemContainerStyle="{StaticResource MainWorkspaceTabItem}"
                            SelectedIndex="{Binding ProfileListTabIndex, Mode=TwoWay}">
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ProfileTabMappings]}" />
                        </TabItem.Header>
                        <Grid Margin="12"
                              VerticalAlignment="Stretch">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" MinHeight="0" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       Style="{StaticResource WorkspaceSectionTitleStyle}"
                                       Text="{Binding Source={StaticResource Loc}, Path=[MappingListTitle]}" />
                            <WrapPanel Grid.Row="1"
                                       Orientation="Horizontal"
                                       Margin="0,0,0,8">
                                <Button Content="{Binding Source={StaticResource Loc}, Path=[AddMappingPlus]}"
                                        Command="{Binding MappingEditorPanel.AddMappingCommand}"
                                        Padding="10,4"
                                        Margin="0,0,0,4" />
                            </WrapPanel>
                            <sections:MappingEditorView Grid.Row="2"
                                                        DataContext="{Binding MappingEditorPanel}" />
                        </Grid>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ProfileTabKeyboardActions]}" />
                        </TabItem.Header>
                        <Grid Margin="12"
                              VerticalAlignment="Stretch">
                            <sections:ProfileKeyboardActionsListView DataContext="{Binding CatalogPanel}" />
                        </Grid>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ProfileTabRadialMenus]}" />
                        </TabItem.Header>
                        <Grid Margin="12"
                              VerticalAlignment="Stretch">
                            <sections:ProfileRadialMenusListView DataContext="{Binding CatalogPanel}" />
                        </Grid>
                    </TabItem>
                    <TabItem>
                        <TabItem.Header>
                            <TextBlock Text="Community" />
                        </TabItem.Header>
                        <Grid Margin="12"
                              VerticalAlignment="Stretch">
                            <sections:CommunityCatalogView DataContext="{Binding CommunityCatalogPanel}" />
                        </Grid>
                    </TabItem>
                </TabControl>
            </Border>

            <GridSplitter Grid.Row="1"
                          Grid.Column="1"
                          Width="6"
                          HorizontalAlignment="Stretch"
                          VerticalAlignment="Stretch"
                          ResizeDirection="Columns"
                          ResizeBehavior="PreviousAndNext"
                          ShowsPreview="True" />

            <Border Grid.Row="1"
                    Grid.Column="2"
                    Margin="12,0,0,0"
                    ClipToBounds="True"
                    Style="{StaticResource SectionCardBorder}">
                <Border.Resources>
                    <DataTemplate x:Key="RightPanelMappingTemplate">
                        <!-- Content is ProfileRightPanelSurface enum; template root DataContext would be that enum unless we bind from the host ContentControl (MainViewModel). -->
                        <sections:MappingDetailsPanelView MinHeight="0"
                                                          VerticalAlignment="Stretch"
                                                          DataContext="{Binding DataContext.MappingEditorPanel, RelativeSource={RelativeSource AncestorType=ContentControl, Mode=FindAncestor, AncestorLevel=1}}" />
                    </DataTemplate>
                    <DataTemplate x:Key="RightPanelKeyboardTemplate">
                        <sections:KeyboardActionEditorPanelView MinHeight="0"
                                                                 VerticalAlignment="Stretch"
                                                                 DataContext="{Binding DataContext.CatalogPanel, RelativeSource={RelativeSource AncestorType=ContentControl, Mode=FindAncestor, AncestorLevel=1}}" />
                    </DataTemplate>
                    <DataTemplate x:Key="RightPanelRadialTemplate">
                        <sections:RadialMenuEditorPanelView MinHeight="0"
                                                             VerticalAlignment="Stretch"
                                                             DataContext="{Binding DataContext.CatalogPanel, RelativeSource={RelativeSource AncestorType=ContentControl, Mode=FindAncestor, AncestorLevel=1}}" />
                    </DataTemplate>
                    <DataTemplate x:Key="RightPanelPlaceholderTemplate">
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ProfileEditorPlaceholder]}"
                                   TextWrapping="Wrap"
                                   TextAlignment="Center"
                                   VerticalAlignment="Center"
                                   HorizontalAlignment="Center"
                                   Margin="20"
                                   Foreground="{DynamicResource AppSecondaryTextBrush}" />
                    </DataTemplate>
                    <local:RightPanelTemplateSelector x:Key="RightPanelTemplateSelector"
                                                        MappingTemplate="{StaticResource RightPanelMappingTemplate}"
                                                        KeyboardActionTemplate="{StaticResource RightPanelKeyboardTemplate}"
                                                        RadialMenuTemplate="{StaticResource RightPanelRadialTemplate}"
                                                        PlaceholderTemplate="{StaticResource RightPanelPlaceholderTemplate}" />
                </Border.Resources>
                <ContentControl Content="{Binding RightPanelSurface}"
                                ContentTemplateSelector="{StaticResource RightPanelTemplateSelector}"
                                VerticalAlignment="Stretch"
                                HorizontalAlignment="Stretch"
                                VerticalContentAlignment="Stretch"
                                HorizontalContentAlignment="Stretch"
                                Focusable="False" />
            </Border>
        </Grid>
       </Grid>
       <local:CornerToastOverlay DataContext="{Binding ToastHost}"
                                 VerticalAlignment="Bottom"
                                 HorizontalAlignment="Right"
                                 Margin="0,0,8,8"
                                 Panel.ZIndex="50" />
   </Grid>
</UserControl>

