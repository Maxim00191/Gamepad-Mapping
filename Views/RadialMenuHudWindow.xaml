<Window x:Class="Gamepad_Mapping.Views.RadialMenuHudWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Gamepad_Mapping.ViewModels"
        xmlns:utils="clr-namespace:Gamepad_Mapping.Utils"
        mc:Ignorable="d"
        Title="Radial Menu"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowInTaskbar="False"
        Topmost="True"
        Focusable="False"
        ShowActivated="False"
        d:DataContext="{d:DesignInstance vm:RadialMenuHudViewModel}">
    <Window.Resources>
        <utils:RadialItemPositionConverter x:Key="PosConverter" />
        
        <Storyboard x:Key="FadeInStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootGrid"
                             Storyboard.TargetProperty="Opacity"
                             From="0" To="1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                             Storyboard.TargetProperty="ScaleX"
                             From="0.8" To="1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="0.3" EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
            <DoubleAnimation Storyboard.TargetName="ScaleTransform"
                             Storyboard.TargetProperty="ScaleY"
                             From="0.8" To="1" Duration="0:0:0.2">
                <DoubleAnimation.EasingFunction>
                    <BackEase Amplitude="0.3" EasingMode="EaseOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <Storyboard x:Key="FadeOutStoryboard">
            <DoubleAnimation Storyboard.TargetName="RootGrid"
                             Storyboard.TargetProperty="Opacity"
                             To="0" Duration="0:0:0.15">
                <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseIn" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
    </Window.Resources>

    <Grid x:Name="RootGrid" Margin="60" Opacity="0" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <ScaleTransform x:Name="ScaleTransform" ScaleX="0.8" ScaleY="0.8" />
        </Grid.RenderTransform>

        <!-- Outer circle: diameter = RadialHudLayout.DiscDiameter (keep in sync with layout math). -->
        <Ellipse Width="{x:Static utils:RadialHudLayout.DiscDiameter}"
                 Height="{x:Static utils:RadialHudLayout.DiscDiameter}"
                 StrokeThickness="1"
                 Stroke="#40FFFFFF">
            <Ellipse.Fill>
                <SolidColorBrush Color="#CC1C1C1E" />
            </Ellipse.Fill>
            <Ellipse.Effect>
                <DropShadowEffect BlurRadius="25" ShadowDepth="0" Opacity="0.6" Color="Black" />
            </Ellipse.Effect>
        </Ellipse>

        <!-- Items on Canvas: slot top-left from RadialHudLayout (centers on inner ring, outer edge flush with disc). -->
        <ItemsControl x:Name="ItemsHost"
                      Width="{x:Static utils:RadialHudLayout.DiscDiameter}"
                      Height="{x:Static utils:RadialHudLayout.DiscDiameter}"
                      ItemsSource="{Binding Items}">
            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas Width="{x:Static utils:RadialHudLayout.DiscDiameter}"
                            Height="{x:Static utils:RadialHudLayout.DiscDiameter}" />
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Width" Value="{x:Static utils:RadialHudLayout.ItemSize}" />
                    <Setter Property="Height" Value="{x:Static utils:RadialHudLayout.ItemSize}" />
                    <Setter Property="Canvas.Left">
                        <Setter.Value>
                            <MultiBinding Converter="{StaticResource PosConverter}" ConverterParameter="X">
                                <Binding Path="SegmentIndex" />
                                <Binding Path="SegmentCount" />
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Canvas.Top">
                        <Setter.Value>
                            <MultiBinding Converter="{StaticResource PosConverter}" ConverterParameter="Y">
                                <Binding Path="SegmentIndex" />
                                <Binding Path="SegmentCount" />
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>
                </Style>
            </ItemsControl.ItemContainerStyle>
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Grid Width="{x:Static utils:RadialHudLayout.ItemSize}"
                          Height="{x:Static utils:RadialHudLayout.ItemSize}">
                        <Border x:Name="ItemBorder"
                                CornerRadius="40"
                                Background="Transparent"
                                BorderThickness="2"
                                BorderBrush="Transparent">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <TextBlock Text="{Binding PrimaryCaption}"
                                           Foreground="White"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap" />
                                <TextBlock Foreground="#D0FFFFFF"
                                           FontSize="11"
                                           FontWeight="Normal"
                                           TextAlignment="Center"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0"
                                           Text="{Binding SecondaryCaption}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasSecondaryCaption}" Value="True">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Grid>
                    <DataTemplate.Triggers>
                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                            <Setter TargetName="ItemBorder" Property="Background" Value="#40FFFFFF" />
                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                            <Setter TargetName="ItemBorder" Property="Effect">
                                <Setter.Value>
                                    <DropShadowEffect BlurRadius="10" ShadowDepth="0" Color="White" Opacity="0.5" />
                                </Setter.Value>
                            </Setter>
                        </DataTrigger>
                    </DataTemplate.Triggers>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>

        <!-- Center Selection Indicator / Title -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
            <TextBlock Text="{Binding Title}" 
                       Foreground="White" 
                       FontSize="20" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</Window>
