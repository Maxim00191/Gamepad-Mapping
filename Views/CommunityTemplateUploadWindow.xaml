<Window x:Class="Gamepad_Mapping.Views.CommunityTemplateUploadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:Gamepad_Mapping.Utils.Converters"
        Title="{Binding Source={StaticResource Loc}, Path=[CommunityUpload_WindowTitle]}"
        Width="620"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">
    <Window.Resources>
        <conv:CommunityTemplateComplianceSeverityToBrushConverter x:Key="ComplianceSevBrush"/>
    </Window.Resources>
    <Border Padding="16" Background="{DynamicResource AppSurfaceBrush}">
        <StackPanel>
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CommunityUpload_Intro]}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                       FontSize="12"/>

            <Grid Margin="0,0,0,6">
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CommunityUpload_TemplatesToInclude]}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="{Binding Source={StaticResource Loc}, Path=[CommunityUpload_SelectAll]}"
                            Command="{Binding SelectAllTemplatesCommand}"
                            Padding="10,4"
                            Margin="0,0,6,0"
                            Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                    <Button Content="{Binding Source={StaticResource Loc}, Path=[CommunityUpload_ClearSelection]}"
                            Command="{Binding ClearTemplateSelectionCommand}"
                            Padding="10,4"
                            Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                </StackPanel>
            </Grid>

            <Border BorderBrush="{DynamicResource AppSeparatorBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Margin="0,0,0,8">
                <ListBox ItemsSource="{Binding BundleItems}"
                         BorderThickness="0"
                         Background="Transparent"
                         MaxHeight="220"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsIncluded, Mode=TwoWay}"
                                          VerticalAlignment="Top"
                                          Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding TitleLine}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding SubtitleLine}"
                                               FontSize="11"
                                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <TextBlock Text="{Binding SelectionSummary}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                       FontSize="12"/>

            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CommunityUpload_GameFolderLabel]}" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding GameFolderName, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4"
                     Margin="0,0,0,10"/>

            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CommunityUpload_AuthorFolderLabel]}" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding AuthorName, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4"
                     Margin="0,0,0,10"/>

            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CommunityUpload_ListingDescriptionLabel]}" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding ListingDescription, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     MinHeight="72"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,10"/>

            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CommunityUpload_ChecksHeader]}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,4"/>
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CommunityUpload_ChecksIntro]}"
                       TextWrapping="Wrap"
                       FontSize="11"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                       Margin="0,0,0,8"/>

            <Border BorderBrush="{DynamicResource AppSeparatorBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="10,8"
                    Margin="0,0,0,12"
                    Background="{DynamicResource AppControlSurfaceAltBrush}">
                <ItemsControl ItemsSource="{Binding ComplianceSteps}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Margin="0,0,0,10">
                                <TextBlock Text="{Binding Title}"
                                           FontWeight="SemiBold"
                                           TextWrapping="Wrap"/>
                                <TextBlock Text="{Binding Prompt}"
                                           FontSize="11"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,4"/>
                                <TextBlock Text="{Binding StatusSummary}"
                                           FontSize="12"
                                           FontWeight="SemiBold"
                                           Foreground="{Binding Severity, Converter={StaticResource ComplianceSevBrush}}"
                                           TextWrapping="Wrap"/>
                                <ItemsControl ItemsSource="{Binding Items}" Margin="8,6,0,0">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,0,0,6">
                                                <TextBlock Text="{Binding Line}"
                                                           FontSize="11"
                                                           TextWrapping="Wrap"/>
                                                <TextBlock FontSize="11"
                                                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,2,0,0">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Suggestion}" Value="{x:Null}">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Suggestion}" Value="">
                                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                    <Run Text="{Binding Source={StaticResource Loc}, Path=[CommunityUpload_SuggestionLabel], Mode=OneWay}"/>
                                                    <Run Text=": "/>
                                                    <Run Text="{Binding Suggestion, Mode=OneWay}"/>
                                                </TextBlock>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Border>

            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CommunityUpload_TokenFootnote]}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                       FontSize="11"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="{Binding Source={StaticResource Loc}, Path=[Cancel]}" IsCancel="True" Padding="16,6" Margin="0,0,8,0" MinWidth="90"/>
                <Button Content="{Binding Source={StaticResource Loc}, Path=[CommunityUpload_ButtonUpload]}" IsDefault="True" Padding="16,6" MinWidth="90"
                        IsEnabled="{Binding ComplianceReady}"
                        Click="Upload_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
