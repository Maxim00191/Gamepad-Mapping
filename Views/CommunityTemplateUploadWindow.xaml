<Window x:Class="Gamepad_Mapping.Views.CommunityTemplateUploadWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Upload templates to community"
        Width="560"
        SizeToContent="Height"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{DynamicResource AppBackgroundBrush}"
        Foreground="{DynamicResource AppTextBrush}">
    <Border Padding="16" Background="{DynamicResource AppSurfaceBrush}">
        <StackPanel>
            <TextBlock Text="Submit the current template and any profiles linked by template switches for review via a GitHub pull request. Uncheck templates you do not want in this submission."
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                       FontSize="12"/>

            <Grid Margin="0,0,0,6">
                <TextBlock Text="Templates to include"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="Select all"
                            Command="{Binding SelectAllTemplatesCommand}"
                            Padding="10,4"
                            Margin="0,0,6,0"
                            Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                    <Button Content="Clear"
                            Command="{Binding ClearTemplateSelectionCommand}"
                            Padding="10,4"
                            Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                </StackPanel>
            </Grid>

            <Border BorderBrush="{DynamicResource AppSeparatorBrush}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Margin="0,0,0,8">
                <ListBox ItemsSource="{Binding BundleItems}"
                         BorderThickness="0"
                         Background="Transparent"
                         MaxHeight="260"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Auto">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem">
                            <Setter Property="Padding" Value="10,6"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        </Style>
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <CheckBox Grid.Column="0"
                                          IsChecked="{Binding IsIncluded, Mode=TwoWay}"
                                          VerticalAlignment="Top"
                                          Margin="0,0,10,0"/>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding TitleLine}"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"/>
                                    <TextBlock Text="{Binding SubtitleLine}"
                                               FontSize="11"
                                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Margin="0,2,0,0"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>

            <TextBlock Text="{Binding SelectionSummary}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                       FontSize="12"/>

            <TextBlock Text="Game folder (repository group)" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding GameFolderName, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4"
                     Margin="0,0,0,10"/>

            <TextBlock Text="Author folder" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding AuthorName, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4"
                     Margin="0,0,0,10"/>

            <TextBlock Text="Listing description" FontWeight="SemiBold" Margin="0,0,0,4"/>
            <TextBox Text="{Binding ListingDescription, UpdateSourceTrigger=PropertyChanged}"
                     Padding="6,4"
                     TextWrapping="Wrap"
                     AcceptsReturn="True"
                     MinHeight="80"
                     VerticalScrollBarVisibility="Auto"
                     Margin="0,0,0,10"/>

            <TextBlock TextWrapping="Wrap"
                       Margin="0,0,0,12"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                       FontSize="11">
                Requires <Run FontWeight="SemiBold">communityProfilesUploadToken</Run> in local_settings.json (GitHub PAT with repo scope). The repository automation opens a PR; merging runs the index update workflow.
            </TextBlock>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="Cancel" IsCancel="True" Padding="16,6" Margin="0,0,8,0" MinWidth="90"/>
                <Button Content="Upload" IsDefault="True" Padding="16,6" MinWidth="90" Click="Upload_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
