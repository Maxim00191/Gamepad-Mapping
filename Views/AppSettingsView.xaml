<UserControl x:Class="Gamepad_Mapping.Views.AppSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utils="clr-namespace:Gamepad_Mapping.Utils"
             xmlns:sections="clr-namespace:Gamepad_Mapping.Views.Sections"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="520"
             d:DesignWidth="440">
    <StackPanel>
        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsHeader]}"
                   FontWeight="SemiBold"
                   FontSize="14"
                   Margin="0,0,0,8" />
        <TabControl Style="{StaticResource MainWorkspaceTabControl}"
                    ItemContainerStyle="{StaticResource MainWorkspaceTabItem}">
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsTabGeneral]}" />
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="440">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsLanguageSection]}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <UniformGrid Columns="2" Margin="0,0,0,8">
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppLanguageLabel]}"
                                       Margin="0,0,8,0"
                                       TextWrapping="Wrap" />
                            <ComboBox Width="140"
                                      HorizontalAlignment="Left"
                                      ItemsSource="{Binding AvailableUiLanguages}"
                                      SelectedItem="{Binding SelectedUiLanguage, Mode=TwoWay}"
                                      DisplayMemberPath="DisplayName" />
                        </UniformGrid>
                        <Separator Margin="0,4,0,8" />
                        <sections:UpdatesPanelView DataContext="{Binding UpdatePanel}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsTabInputOutput]}" />
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="440">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsInputEmulationSection]}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <ComboBox Margin="0,0,0,4"
                                  ItemsSource="{Binding AvailableInputApis}"
                                  SelectedItem="{Binding SelectedInputApi, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName"
                                  ToolTip="{Binding Source={StaticResource Loc}, Path=[InputApiWin32Hint]}" />
                        <CheckBox Content="{Binding Source={StaticResource Loc}, Path=[HumanNoiseEnableLabel]}"
                                  IsChecked="{Binding HumanNoiseEnabled, Mode=TwoWay}"
                                  Margin="0,4,0,6" />
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[HumanNoiseAmplitudeLabel]}"
                                   Margin="0,0,0,2" />
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,0,4">
                            <Slider Width="168"
                                    Minimum="0"
                                    Maximum="1"
                                    SmallChange="0.02"
                                    LargeChange="0.1"
                                    TickFrequency="0.05"
                                    IsSnapToTickEnabled="False"
                                    VerticalAlignment="Center"
                                    IsEnabled="{Binding HumanNoiseEnabled}"
                                    Value="{Binding HumanNoiseAmplitude, Mode=TwoWay}" />
                            <TextBlock VerticalAlignment="Center"
                                       Margin="10,0,0,0"
                                       MinWidth="40"
                                       IsEnabled="{Binding HumanNoiseEnabled}"
                                       Text="{Binding HumanNoiseAmplitude, StringFormat={}{0:0.##}}" />
                        </StackPanel>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[HumanNoiseFrequencyLabel]}"
                                   Margin="0,4,0,2" />
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,0,4">
                            <Slider Width="168"
                                    Minimum="0"
                                    Maximum="1"
                                    SmallChange="0.02"
                                    LargeChange="0.1"
                                    TickFrequency="0.05"
                                    IsSnapToTickEnabled="False"
                                    VerticalAlignment="Center"
                                    IsEnabled="{Binding HumanNoiseEnabled}"
                                    Value="{Binding HumanNoiseFrequency, Mode=TwoWay}" />
                            <TextBlock VerticalAlignment="Center"
                                       Margin="10,0,0,0"
                                       MinWidth="40"
                                       IsEnabled="{Binding HumanNoiseEnabled}"
                                       Text="{Binding HumanNoiseFrequency, StringFormat={}{0:0.##}}" />
                        </StackPanel>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[HumanNoiseSmoothnessLabel]}"
                                   Margin="0,4,0,2" />
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,0,4">
                            <Slider Width="168"
                                    Minimum="0"
                                    Maximum="1"
                                    SmallChange="0.02"
                                    LargeChange="0.1"
                                    TickFrequency="0.05"
                                    IsSnapToTickEnabled="False"
                                    VerticalAlignment="Center"
                                    IsEnabled="{Binding HumanNoiseEnabled}"
                                    Value="{Binding HumanNoiseSmoothness, Mode=TwoWay}" />
                            <TextBlock VerticalAlignment="Center"
                                       Margin="10,0,0,0"
                                       MinWidth="40"
                                       IsEnabled="{Binding HumanNoiseEnabled}"
                                       Text="{Binding HumanNoiseSmoothness, StringFormat={}{0:0.##}}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsTabGamepad]}" />
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="440">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsGamepadSourceSection]}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,8" />
                        <ComboBox Margin="0,0,0,12"
                                  ItemsSource="{Binding AvailableGamepadApis}"
                                  SelectedItem="{Binding SelectedGamepadApi, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName" />
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[PollingIntervalLabel]}"
                                   Margin="0,0,0,4" />
                        <TextBox Text="{Binding GamepadPollingIntervalMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="88"
                                 HorizontalAlignment="Left" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsTabMapping]}" />
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="440">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsTimingSection]}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <UniformGrid Columns="2" Margin="0,0,0,12">
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ModifierGraceLabel]}"
                                       Margin="0,0,8,4"
                                       TextWrapping="Wrap" />
                            <TextBox Text="{Binding ModifierGraceMsSetting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="88"
                                     HorizontalAlignment="Left"
                                     Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[LeadSuppressLabel]}"
                                       Margin="0,4,8,4"
                                       TextWrapping="Wrap" />
                            <TextBox Text="{Binding LeadKeyReleaseSuppressMsSetting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="88"
                                     HorizontalAlignment="Left"
                                     Margin="0,4,0,4" />
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TapHoldLabel]}"
                                       Margin="0,4,8,4"
                                       TextWrapping="Wrap" />
                            <TextBox Text="{Binding KeyboardTapHoldDurationMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="88"
                                     HorizontalAlignment="Left"
                                     Margin="0,4,0,4" />
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TapInterKeyDelayLabel]}"
                                       Margin="0,4,8,4"
                                       TextWrapping="Wrap" />
                            <TextBox Text="{Binding TapInterKeyDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="88"
                                     HorizontalAlignment="Left"
                                     Margin="0,4,0,4" />
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TextInterCharDelayLabel]}"
                                       Margin="0,4,8,0"
                                       TextWrapping="Wrap" />
                            <TextBox Text="{Binding TextInterCharDelayMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="88"
                                     HorizontalAlignment="Left"
                                     Margin="0,4,0,0" />
                        </UniformGrid>
                        <Separator Margin="0,0,0,8" />
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsAnalogSection]}"
                                   FontWeight="SemiBold"
                                   Margin="0,0,0,6" />
                        <UniformGrid Columns="2">
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[DefaultAnalogThresholdLabel]}"
                                       Margin="0,0,8,4"
                                       TextWrapping="Wrap" />
                            <TextBox Text="{Binding DefaultAnalogActivationThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.00}}"
                                     Width="88"
                                     HorizontalAlignment="Left"
                                     Margin="0,0,0,4" />
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ThumbstickDeadzoneShapeLabel]}"
                                       Margin="0,4,8,4"
                                       TextWrapping="Wrap" />
                            <ComboBox SelectedIndex="{Binding ThumbstickDeadzoneShapeIndex, Mode=TwoWay}"
                                      HorizontalAlignment="Stretch"
                                      Margin="0,4,0,4">
                                <ComboBoxItem Content="{Binding Source={StaticResource Loc}, Path=[ThumbstickDeadzoneShapeAxial]}" />
                                <ComboBoxItem Content="{Binding Source={StaticResource Loc}, Path=[ThumbstickDeadzoneShapeRadial]}" />
                            </ComboBox>
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AnalogHysteresisPressExtraLabel]}"
                                       Margin="0,4,8,4"
                                       TextWrapping="Wrap" />
                            <TextBox Text="{Binding DefaultAnalogHysteresisPressExtra, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.000}}"
                                     Width="88"
                                     HorizontalAlignment="Left"
                                     Margin="0,4,0,4" />
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AnalogHysteresisReleaseExtraLabel]}"
                                       Margin="0,4,8,4"
                                       TextWrapping="Wrap" />
                            <TextBox Text="{Binding DefaultAnalogHysteresisReleaseExtra, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.000}}"
                                     Width="88"
                                     HorizontalAlignment="Left"
                                     Margin="0,4,0,4" />
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[MouseLookSensitivityLabel]}"
                                       Margin="0,4,8,4"
                                       TextWrapping="Wrap" />
                            <TextBox Text="{Binding MouseLookSensitivity, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.0}}"
                                     Width="88"
                                     HorizontalAlignment="Left"
                                     Margin="0,4,0,4" />
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[MouseLookSmoothingLabel]}"
                                       Margin="0,4,8,4"
                                       TextWrapping="Wrap" />
                            <TextBox Text="{Binding MouseLookSmoothing, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.00}}"
                                     Width="88"
                                     HorizontalAlignment="Left"
                                     Margin="0,4,0,4" />
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[MouseLookSettleMagnitudeLabel]}"
                                       Margin="0,4,8,4"
                                       TextWrapping="Wrap" />
                            <TextBox Text="{Binding MouseLookSettleMagnitude, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.000}}"
                                     Width="88"
                                     HorizontalAlignment="Left"
                                     Margin="0,4,0,4" />
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[MouseLookReboundSuppressionLabel]}"
                                       Margin="0,4,8,4"
                                       TextWrapping="Wrap" />
                            <TextBox Text="{Binding MouseLookReboundSuppression, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.00}}"
                                     Width="88"
                                     HorizontalAlignment="Left"
                                     Margin="0,4,0,4" />
                            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AnalogEpsilonLabel]}"
                                       Margin="0,4,8,4"
                                       TextWrapping="Wrap" />
                            <TextBox Text="{Binding AnalogChangeEpsilon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, StringFormat={}{0:0.000}}"
                                     Width="88"
                                     HorizontalAlignment="Left"
                                     Margin="0,4,0,4" />
                        </UniformGrid>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[MouseLookStickLayoutHint]}"
                                   Margin="0,8,0,0"
                                   TextWrapping="Wrap"
                                   FontSize="11"
                                   Foreground="{DynamicResource AppSecondaryTextBrush}" />
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem>
                <TabItem.Header>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AppSettingsTabRadialHud]}" />
                </TabItem.Header>
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              MaxHeight="440">
                    <StackPanel>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[RadialMenuConfirmModeLabel]}"
                                   Margin="0,0,8,4"
                                   TextWrapping="Wrap" />
                        <ComboBox SelectedIndex="{Binding RadialMenuConfirmModeIndex, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  Margin="0,0,0,12">
                            <ComboBoxItem Content="{Binding Source={StaticResource Loc}, Path=[RadialMenuConfirmModeReturnCenter]}" />
                            <ComboBoxItem Content="{Binding Source={StaticResource Loc}, Path=[RadialMenuConfirmModeReleaseGuide]}" />
                        </ComboBox>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[RadialMenuHudLabelModeLabel]}"
                                   Margin="0,0,8,4"
                                   TextWrapping="Wrap" />
                        <ComboBox SelectedIndex="{Binding RadialMenuHudLabelModeIndex, Mode=TwoWay}"
                                  HorizontalAlignment="Stretch"
                                  Margin="0,0,0,12">
                            <ComboBoxItem Content="{Binding Source={StaticResource Loc}, Path=[RadialMenuHudLabelModeBoth]}" />
                            <ComboBoxItem Content="{Binding Source={StaticResource Loc}, Path=[RadialMenuHudLabelModeDescriptionOnly]}" />
                            <ComboBoxItem Content="{Binding Source={StaticResource Loc}, Path=[RadialMenuHudLabelModeKeyboardKeyOnly]}" />
                        </ComboBox>
                        <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[RadialHudScaleLabel]}"
                                   Margin="0,0,8,4"
                                   TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <Slider Width="168"
                                    Minimum="{x:Static utils:RadialHudLayout.MinHudScale}"
                                    Maximum="{x:Static utils:RadialHudLayout.MaxHudScale}"
                                    SmallChange="0.05"
                                    LargeChange="0.25"
                                    TickFrequency="0.25"
                                    IsSnapToTickEnabled="False"
                                    VerticalAlignment="Center"
                                    Value="{Binding RadialHudScaleSetting, Mode=TwoWay}" />
                            <TextBlock VerticalAlignment="Center"
                                       Margin="10,0,0,0"
                                       MinWidth="40"
                                       Text="{Binding RadialHudScaleSetting, StringFormat={}{0:0.##}}" />
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
        </TabControl>
    </StackPanel>
</UserControl>
