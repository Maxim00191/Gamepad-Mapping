             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Gamepad_Mapping.Views.Sections"
             xmlns:viewmodels="clr-namespace:Gamepad_Mapping.ViewModels"
             xmlns:utils="clr-namespace:Gamepad_Mapping.Utils"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400"
             d:DataContext="{d:DesignInstance Type=viewmodels:ControllerVisualViewModel}">
    <UserControl.Resources>
        <utils:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <Style x:Key="ControllerPathStyle" TargetType="Path">
            <Setter Property="Fill" Value="#2C3E50"/>
            <Setter Property="Stroke" Value="#34495E"/>
            <Setter Property="StrokeThickness" Value="1"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Fill" Value="#34495E"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InteractivePathStyle" TargetType="Path">
            <Setter Property="Fill" Value="#95A5A6"/>
            <Setter Property="Stroke" Value="Transparent"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Fill" Value="#BDC3C7"/>
                    <Setter Property="Stroke" Value="#3498DB"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ButtonPathStyle" TargetType="Path" BasedOn="{StaticResource InteractivePathStyle}">
            <!-- Specific colors for ABXY -->
        </Style>
    </UserControl.Resources>

