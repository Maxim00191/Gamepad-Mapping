<UserControl x:Class="Gamepad_Mapping.Views.Sections.ControllerVisualView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Gamepad_Mapping.Views.Sections"
             xmlns:viewmodels="clr-namespace:Gamepad_Mapping.ViewModels"
             xmlns:utils="clr-namespace:Gamepad_Mapping.Utils"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400"
             d:DataContext="{d:DesignInstance Type=viewmodels:ControllerVisualViewModel}">
    <UserControl.Resources>
        <utils:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        
        <Style x:Key="InteractivePathStyle" TargetType="Path">
            <Setter Property="Fill" Value="Transparent"/>
            <Setter Property="Stroke" Value="Transparent"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Fill" Value="#20FFFFFF"/>
                    <Setter Property="Stroke" Value="#007ACC"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SelectedPathStyle" TargetType="Path" BasedOn="{StaticResource InteractivePathStyle}">
            <Setter Property="Stroke" Value="#007ACC"/>
            <Setter Property="StrokeThickness" Value="3"/>
            <Setter Property="Fill" Value="#30FFFFFF"/>
        </Style>

        <Style x:Key="MappedPathStyle" TargetType="Path" BasedOn="{StaticResource InteractivePathStyle}">
            <Setter Property="Fill" Value="#2000FF00"/>
            <Setter Property="Stroke" Value="#4EC9B0"/>
            <Setter Property="StrokeThickness" Value="1"/>
        </Style>

        <Style x:Key="InteractiveRectangleStyle" TargetType="Rectangle">
            <Setter Property="Fill" Value="Transparent"/>
            <Setter Property="Stroke" Value="Transparent"/>
            <Setter Property="StrokeThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Fill" Value="#20FFFFFF"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SelectedRectangleStyle" TargetType="Rectangle" BasedOn="{StaticResource InteractiveRectangleStyle}">
            <Setter Property="Fill" Value="#30FFFFFF"/>
            <Setter Property="Stroke" Value="#007ACC"/>
            <Setter Property="StrokeThickness" Value="3"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent">
        <Viewbox Stretch="Uniform">
            <Grid x:Name="ControllerVisualSvgRoot" Width="300" Height="250">
                <Image x:Name="ControllerSvgImage" Stretch="Uniform" />

                <Canvas x:Name="InteractionLayer" Width="300" Height="250" Background="Transparent" />
            </Grid>
        </Viewbox>

        <!-- Floating Callout Overlay -->
        <Canvas IsHitTestVisible="False">
            <ItemsControl ItemsSource="{Binding MappedElements}">
                <!-- This would require a more complex setup to position callouts correctly -->
            </ItemsControl>
        </Canvas>
        
        <!-- Hover Tooltip -->
        <Border Visibility="{Binding HoveredElementName, Converter={StaticResource NullToVisibilityConverter}}"
                HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10"
                Background="#CC1E1E1E" CornerRadius="4" Padding="12,6" BorderBrush="#3F3F46" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding HoveredElementName}" Foreground="White" FontSize="13" FontWeight="SemiBold"/>
                <TextBlock Text=" - Click to map" Foreground="#AAAAAA" FontSize="11" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
