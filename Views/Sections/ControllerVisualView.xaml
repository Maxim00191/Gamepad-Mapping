<UserControl x:Class="Gamepad_Mapping.Views.Sections.ControllerVisualView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Gamepad_Mapping.Views.Sections"
             xmlns:viewmodels="clr-namespace:Gamepad_Mapping.ViewModels"
             xmlns:utils="clr-namespace:Gamepad_Mapping.Utils"
             xmlns:converters="clr-namespace:Gamepad_Mapping.Utils.Converters"
             xmlns:svgutils="clr-namespace:Gamepad_Mapping.Utils.ControllerSvg"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400"
             d:DataContext="{d:DesignInstance Type=viewmodels:ControllerVisualViewModel}">
    <UserControl.Resources>
        <utils:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <converters:DimmingConverter x:Key="DimmingConverter" />
        <converters:InverseUniformScaleConverter x:Key="InverseUniformScaleConverter" />
        <converters:PointsToPathGeometryConverter x:Key="PointsToPathGeometryConverter" />
        <x:Static x:Key="OverlayPrimaryFontSize" Member="svgutils:ControllerMappingOverlayLabelMetrics.PrimaryFontSize" />
        <x:Static x:Key="OverlaySecondaryFontSize" Member="svgutils:ControllerMappingOverlayLabelMetrics.SecondaryFontSize" />
        <sys:Double x:Key="HoverHintPrimaryFontSize">13</sys:Double>
        <sys:Double x:Key="HoverHintSecondaryFontSize">11</sys:Double>
        <x:Static x:Key="OverlayLabelMaxWidth" Member="svgutils:ControllerMappingOverlayLabelMetrics.MaxTextBlockWidth" />
        <x:Static x:Key="OverlayBorderPadding" Member="svgutils:ControllerMappingOverlayLabelMetrics.BorderPaddingThickness" />
        
        <Style x:Key="InteractivePathStyle" TargetType="Path">
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="Fill" Value="Transparent"/>
            <Setter Property="Stroke" Value="Transparent"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Fill" Value="#20FFFFFF"/>
                    <Setter Property="Stroke" Value="#007ACC"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChordPartPathStyle" TargetType="Path" BasedOn="{StaticResource InteractivePathStyle}">
            <Setter Property="Stroke" Value="#007ACC"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Setter Property="StrokeDashArray" Value="2,1"/>
            <Setter Property="Fill" Value="#15007ACC"/>
        </Style>

        <Style x:Key="SelectedPathStyle" TargetType="Path" BasedOn="{StaticResource InteractivePathStyle}">
            <Setter Property="Stroke" Value="#007ACC"/>
            <Setter Property="StrokeThickness" Value="3"/>
            <Setter Property="Fill" Value="#30FFFFFF"/>
        </Style>

        <Style x:Key="InteractiveRectangleStyle" TargetType="Rectangle">
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="Fill" Value="Transparent"/>
            <Setter Property="Stroke" Value="Transparent"/>
            <Setter Property="StrokeThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Fill" Value="#20FFFFFF"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SelectedRectangleStyle" TargetType="Rectangle" BasedOn="{StaticResource InteractiveRectangleStyle}">
            <Setter Property="Fill" Value="#30FFFFFF"/>
            <Setter Property="Stroke" Value="#007ACC"/>
            <Setter Property="StrokeThickness" Value="3"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent" x:Name="MainRoot">
        <Grid x:Name="TransformContainer" Background="Transparent">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="MainScaleTransform" />
                    <TranslateTransform x:Name="MainTranslateTransform" />
                </TransformGroup>
            </Grid.RenderTransform>
            <Grid x:Name="ControllerVisualSvgRoot" Width="300" Height="250">
                <Image x:Name="ControllerSvgImage" Stretch="Uniform" />

                <Canvas x:Name="InteractionLayer" Width="300" Height="250" Background="Transparent" />

                <ItemsControl x:Name="OverlayLayer" ItemsSource="{Binding OverlayItems}" IsHitTestVisible="False">
                    <AutomationProperties.Name>Controller Mapping Overlay</AutomationProperties.Name>
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <Canvas />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Canvas.Left" Value="{Binding X}" />
                            <Setter Property="Canvas.Top" Value="{Binding Y}" />
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Grid>
                                <!-- Leader Line -->
                                <Polyline Points="{Binding LeaderLinePoints, Converter={StaticResource PointsToPathGeometryConverter}}" 
                                          Stroke="#44FFFFFF" StrokeThickness="1" StrokeDashArray="2,2" />

                                <Grid RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <TranslateTransform X="{Binding LabelX}" Y="{Binding LabelY}" />
                                    </Grid.RenderTransform>
                                    <Button Background="Transparent" BorderThickness="0" Padding="0"
                                            Command="{Binding DataContext.SelectElementCommand, RelativeSource={RelativeSource AncestorType=local:ControllerVisualView}}"
                                            CommandParameter="{Binding ElementId}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Border Background="#EE1E1E1E" CornerRadius="3" Padding="{StaticResource OverlayBorderPadding}" BorderBrush="#3F3F46" BorderThickness="1"
                                                Opacity="{Binding IsDimmed, Converter={StaticResource DimmingConverter}}"
                                                AutomationProperties.Name="{Binding PrimaryLabel}"
                                                ToolTip="{Binding OverlayToolTip}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#007ACC" />
                                                            <Setter Property="BorderThickness" Value="2" />
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#FF2D2D30" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="{Binding PrimaryLabel}" Foreground="White" FontSize="{StaticResource OverlayPrimaryFontSize}" FontWeight="Bold"
                                                           MaxWidth="{StaticResource OverlayLabelMaxWidth}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"/>
                                                <TextBlock Text="{Binding SecondaryLabel}" Foreground="#007ACC" FontSize="{StaticResource OverlaySecondaryFontSize}" Margin="3,0,0,0" 
                                                           MaxWidth="{StaticResource OverlayLabelMaxWidth}" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                                           Visibility="{Binding SecondaryLabel, Converter={StaticResource NullToVisibilityConverter}}"/>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </Grid>
                            </Grid>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </Grid>
        
        <Border Visibility="{Binding HoveredElementName, Converter={StaticResource NullToVisibilityConverter}}"
                HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10"
                Background="#CC1E1E1E" CornerRadius="4" Padding="12,6" BorderBrush="#3F3F46" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding HoveredElementName}" Foreground="White" FontSize="{StaticResource HoverHintPrimaryFontSize}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ControllerVisualClickToMapHint]}"
                           Foreground="#AAAAAA" FontSize="{StaticResource HoverHintSecondaryFontSize}" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
