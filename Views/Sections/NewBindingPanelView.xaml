<UserControl x:Class="Gamepad_Mapping.Views.Sections.NewBindingPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="12"
            Margin="0,0,0,12">
        <StackPanel>
            <TextBlock Text="Create New KB/M Binding"
                       FontWeight="SemiBold"
                       Margin="0,0,0,10" />

            <TextBlock Text="Button" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding AvailableGamepadButtons}"
                      SelectedItem="{Binding NewBindingFromButton, Mode=TwoWay}" />

            <TextBlock Text="Trigger" Margin="0,8,0,4" />
            <ComboBox ItemsSource="{Binding AvailableTriggerModes}"
                      SelectedItem="{Binding NewBindingTrigger, Mode=TwoWay}" />

            <TextBlock Text="KB/M output (e.g. Space, LeftClick, WheelUp)" Margin="0,8,0,4" />
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding NewBindingKeyboardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1"
                        Content="Record key"
                        Command="{Binding RecordNewBindingKeyCommand}"
                        Margin="8,0,0,0" />
            </Grid>

            <Button Content="Create binding"
                    Command="{Binding CreateKeyBindingCommand}"
                    Margin="0,12,0,0"
                    HorizontalAlignment="Left" />
        </StackPanel>
    </Border>
</UserControl>
