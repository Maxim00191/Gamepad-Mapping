<UserControl x:Class="Gamepad_Mapping.Views.Sections.NewBindingPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="0,0,0,12">
        <Separator Margin="0,0,0,12" />

        <TextBlock Text="New key binding" FontWeight="SemiBold" Margin="0,0,0,6" />
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="95" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Button:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <ComboBox Grid.Row="0" Grid.Column="1"
                      ItemsSource="{Binding AvailableGamepadButtons}"
                      SelectedItem="{Binding NewBindingFromButton, Mode=TwoWay}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Trigger:" VerticalAlignment="Center" Margin="0,8,8,0" />
            <ComboBox Grid.Row="1" Grid.Column="1" Margin="0,8,0,0"
                      ItemsSource="{Binding AvailableTriggerModes}"
                      SelectedItem="{Binding NewBindingTrigger, Mode=TwoWay}" />

            <TextBlock Grid.Row="2" Grid.Column="0" Text="Key:" VerticalAlignment="Center" Margin="0,8,8,0" />
            <Grid Grid.Row="2" Grid.Column="1" Margin="0,8,0,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0"
                         Text="{Binding NewBindingKeyboardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                <Button Grid.Column="1"
                        Content="Record key"
                        Command="{Binding RecordNewBindingKeyCommand}"
                        Margin="8,0,0,0" />
            </Grid>

            <Button Grid.Row="3" Grid.Column="1"
                    Content="Create key binding"
                    Command="{Binding CreateKeyBindingCommand}"
                    Margin="0,12,0,0"
                    HorizontalAlignment="Left" />
        </Grid>
    </StackPanel>
</UserControl>
