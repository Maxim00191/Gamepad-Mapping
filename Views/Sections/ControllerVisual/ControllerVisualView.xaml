<UserControl x:Class="Gamepad_Mapping.Views.Sections.ControllerVisual.ControllerVisualView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Gamepad_Mapping.Views.Sections.ControllerVisual"
             xmlns:viewmodels="clr-namespace:Gamepad_Mapping.ViewModels.ControllerVisual"
             xmlns:utils="clr-namespace:Gamepad_Mapping.Utils"
             xmlns:converters="clr-namespace:Gamepad_Mapping.Utils.Converters"
             xmlns:svgutils="clr-namespace:Gamepad_Mapping.Utils.ControllerVisual"
             mc:Ignorable="d" 
             d:DesignHeight="300" d:DesignWidth="400"
             d:DataContext="{d:DesignInstance Type=viewmodels:ControllerVisualViewModel}">
    <UserControl.Resources>
        <utils:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <converters:DimmingConverter x:Key="DimmingConverter" />
        <converters:InverseUniformScaleConverter x:Key="InverseUniformScaleConverter" />
        <x:Static x:Key="OverlayPrimaryFontSize" Member="svgutils:ControllerMappingOverlayLabelMetrics.PrimaryFontSize" />
        <x:Static x:Key="OverlaySecondaryFontSize" Member="svgutils:ControllerMappingOverlayLabelMetrics.SecondaryFontSize" />
        <sys:Double x:Key="HoverHintPrimaryFontSize">13</sys:Double>
        <sys:Double x:Key="HoverHintSecondaryFontSize">11</sys:Double>
        <x:Static x:Key="OverlayLabelMaxWidth" Member="svgutils:ControllerMappingOverlayLabelMetrics.MaxTextBlockWidth" />
        <x:Static x:Key="OverlayLabelMaxBoxWidth" Member="svgutils:ControllerMappingOverlayLabelMetrics.MaxLabelBoxWidth" />
        <x:Static x:Key="OverlayBorderPadding" Member="svgutils:ControllerMappingOverlayLabelMetrics.BorderPaddingThickness" />
        
        <Style x:Key="InteractivePathStyle" TargetType="Path">
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="Fill" Value="Transparent"/>
            <Setter Property="Stroke" Value="Transparent"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Fill" Value="#20FFFFFF"/>
                    <Setter Property="Stroke" Value="#007ACC"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ChordPartPathStyle" TargetType="Path" BasedOn="{StaticResource InteractivePathStyle}">
            <Setter Property="Stroke" Value="#007ACC"/>
            <Setter Property="StrokeThickness" Value="2"/>
            <Setter Property="StrokeDashArray" Value="2,1"/>
            <Setter Property="Fill" Value="#15007ACC"/>
        </Style>

        <Style x:Key="SelectedPathStyle" TargetType="Path" BasedOn="{StaticResource InteractivePathStyle}">
            <Setter Property="Stroke" Value="#007ACC"/>
            <Setter Property="StrokeThickness" Value="3"/>
            <Setter Property="Fill" Value="#30FFFFFF"/>
        </Style>

        <Style x:Key="InteractiveRectangleStyle" TargetType="Rectangle">
            <Setter Property="Focusable" Value="True"/>
            <Setter Property="Fill" Value="Transparent"/>
            <Setter Property="Stroke" Value="Transparent"/>
            <Setter Property="StrokeThickness" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Fill" Value="#20FFFFFF"/>
                    <Setter Property="Cursor" Value="Hand"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="SelectedRectangleStyle" TargetType="Rectangle" BasedOn="{StaticResource InteractiveRectangleStyle}">
            <Setter Property="Fill" Value="#30FFFFFF"/>
            <Setter Property="Stroke" Value="#007ACC"/>
            <Setter Property="StrokeThickness" Value="3"/>
        </Style>
    </UserControl.Resources>

    <Grid Background="Transparent"
          x:Name="MainRoot"
          MouseLeftButtonDown="MainRoot_MouseLeftButtonDown">
        <Grid x:Name="TransformContainer" Background="Transparent">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform x:Name="MainScaleTransform" />
                    <TranslateTransform x:Name="MainTranslateTransform" />
                </TransformGroup>
            </Grid.RenderTransform>
            <Grid x:Name="ControllerVisualSvgRoot" Width="300" Height="250" ClipToBounds="False">
                <Image x:Name="ControllerSvgImage" Stretch="Uniform" Panel.ZIndex="0" />

                <Canvas x:Name="InteractionLayer" Width="300" Height="250" Background="Transparent" Panel.ZIndex="1" />

                <Grid x:Name="OverlayLayer" Width="300" Height="250" Panel.ZIndex="2" ClipToBounds="False">
                    <AutomationProperties.Name>Controller Mapping Overlay</AutomationProperties.Name>
                    <ItemsControl ItemsSource="{Binding OverlayItems}" IsHitTestVisible="False">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas ClipToBounds="False" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Left" VerticalAlignment="Top">
                                    <Path Data="{Binding LeaderLineGeometry}"
                                          StrokeThickness="1.2"
                                          SnapsToDevicePixels="True"
                                          StrokeStartLineCap="Round"
                                          StrokeEndLineCap="Round"
                                          StrokeLineJoin="Round"
                                          Fill="{x:Null}"
                                          Visibility="{Binding IsLeaderLineVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Path.Style>
                                            <Style TargetType="Path">
                                                <Setter Property="Stroke" Value="#66FFFFFF" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHovered}" Value="True">
                                                        <Setter Property="Stroke" Value="#007ACC" />
                                                        <Setter Property="StrokeThickness" Value="2.5" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Stroke" Value="#007ACC" />
                                                        <Setter Property="StrokeThickness" Value="2" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Path.Style>
                                    </Path>
                                    <Ellipse Width="3" Height="3" Fill="#44FFFFFF"
                                             HorizontalAlignment="Left" VerticalAlignment="Top"
                                             IsHitTestVisible="False"
                                             Visibility="{Binding IsLeaderLineVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                                        <Ellipse.RenderTransform>
                                            <TranslateTransform X="-1.5" Y="-1.5" />
                                        </Ellipse.RenderTransform>
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsHovered}" Value="True">
                                                        <Setter Property="Fill" Value="#007ACC" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                        <Setter Property="Fill" Value="#007ACC" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                    <ItemsControl ItemsSource="{Binding OverlayItems}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <Canvas ClipToBounds="False" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemContainerStyle>
                            <Style TargetType="ContentPresenter">
                                <Setter Property="Canvas.Left" Value="{Binding X}" />
                                <Setter Property="Canvas.Top" Value="{Binding Y}" />
                            </Style>
                        </ItemsControl.ItemContainerStyle>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid HorizontalAlignment="Left" VerticalAlignment="Top" RenderTransformOrigin="0.5,0.5">
                                    <Grid.RenderTransform>
                                        <TranslateTransform X="{Binding LabelX}" Y="{Binding LabelY}" />
                                    </Grid.RenderTransform>
                                    <Button Background="Transparent" BorderThickness="0" Padding="0"
                                            Command="{Binding DataContext.SelectElementCommand, RelativeSource={RelativeSource AncestorType=local:ControllerVisualView}}"
                                            CommandParameter="{Binding ElementId}"
                                            IsHitTestVisible="True">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <ContentPresenter />
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Border ClipToBounds="True"
                                                CornerRadius="2" Padding="{StaticResource OverlayBorderPadding}"
                                                BorderThickness="0,0,0,1"
                                                Width="{Binding EstimatedWidth}" MaxWidth="{StaticResource OverlayLabelMaxBoxWidth}"
                                                MinWidth="28"
                                                Height="{Binding EstimatedHeight}"
                                                Opacity="{Binding IsDimmed, Converter={StaticResource DimmingConverter}}"
                                                AutomationProperties.Name="{Binding PrimaryLabel}"
                                                ToolTip="{Binding OverlayToolTip}">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#45282828" />
                                                    <Setter Property="BorderBrush" Value="#55FFFFFF" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding HasExtraMappings}" Value="True">
                                                            <Setter Property="Background" Value="#402A3F5C" />
                                                            <Setter Property="BorderBrush" Value="#664785C4" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="BorderBrush" Value="#CC007ACC" />
                                                            <Setter Property="BorderThickness" Value="0,0,0,2" />
                                                        </DataTrigger>
                                                        <Trigger Property="IsMouseOver" Value="True">
                                                            <Setter Property="Background" Value="#602D2D30" />
                                                        </Trigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel VerticalAlignment="Center">
                                                <StackPanel.Style>
                                                    <Style TargetType="StackPanel">
                                                        <Setter Property="Orientation" Value="Horizontal" />
                                                        <Setter Property="HorizontalAlignment" Value="Left" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding StackPrimaryAndSecondary}" Value="True">
                                                                <Setter Property="Orientation" Value="Vertical" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsLeftColumn}" Value="True">
                                                                <Setter Property="HorizontalAlignment" Value="Right" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </StackPanel.Style>
                                                <TextBlock Text="{Binding PrimaryLabel}" Foreground="White" FontSize="{StaticResource OverlayPrimaryFontSize}" FontWeight="Bold"
                                                           HorizontalAlignment="Stretch" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="TextAlignment" Value="Left" />
                                                            <Setter Property="Margin" Value="0" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsLeftColumn}" Value="True">
                                                                    <Setter Property="TextAlignment" Value="Right" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <TextBlock Text="{Binding SecondaryLabel}" FontSize="{StaticResource OverlaySecondaryFontSize}"
                                                           HorizontalAlignment="Stretch" TextTrimming="CharacterEllipsis" TextWrapping="NoWrap"
                                                           Visibility="{Binding SecondaryLabel, Converter={StaticResource NullToVisibilityConverter}}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="#007ACC" />
                                                            <Setter Property="Margin" Value="3,0,0,0" />
                                                            <Setter Property="TextAlignment" Value="Left" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding StackPrimaryAndSecondary}" Value="True">
                                                                    <Setter Property="Foreground" Value="#B0B0B0" />
                                                                    <Setter Property="Margin" Value="0,2,0,0" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsLeftColumn}" Value="True">
                                                                    <Setter Property="TextAlignment" Value="Right" />
                                                                    <Setter Property="Margin" Value="0,0,0,0" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </StackPanel>
                                        </Border>
                                    </Button>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Grid>
        </Grid>
        
        <Border x:Name="HoverHintBar"
                Visibility="{Binding HoveredElementName, Converter={StaticResource NullToVisibilityConverter}}"
                HorizontalAlignment="Center" VerticalAlignment="Bottom" Margin="0,0,0,10"
                Background="#CC1E1E1E" CornerRadius="4" Padding="12,6" BorderBrush="#3F3F46" BorderThickness="1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding HoveredElementName}" Foreground="White" FontSize="{StaticResource HoverHintPrimaryFontSize}" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ControllerVisualClickToMapHint]}"
                           Foreground="#AAAAAA" FontSize="{StaticResource HoverHintSecondaryFontSize}" Margin="8,0,0,0" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
