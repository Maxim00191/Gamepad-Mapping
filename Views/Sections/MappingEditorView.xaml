<UserControl x:Class="Gamepad_Mapping.Views.Sections.MappingEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0"
                      ItemsSource="{Binding Mappings}"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      SelectedItem="{Binding SelectedMapping, Mode=TwoWay}"
                      SelectionUnit="FullRow"
                      Margin="0"
                      VerticalAlignment="Stretch"
                      MinHeight="200">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="{Binding Source={StaticResource Loc}, Path=[FromType]}"
                                        Binding="{Binding From.Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="1.1*" />
                    <DataGridTemplateColumn Header="{Binding Source={StaticResource Loc}, Path=[FromValue]}" Width="1.2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding From.Value}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.AvailableGamepadButtons, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedItem="{Binding From.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{Binding Source={StaticResource Loc}, Path=[KbmOutputShort]}"
                                        IsReadOnly="True"
                                        Binding="{Binding KeyboardKey, Mode=OneWay}"
                                        Width="1.2*" />
                    <DataGridTextColumn Header="{Binding Source={StaticResource Loc}, Path=[HoldOutput]}"
                                        Binding="{Binding HoldKeyboardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" />
                    <DataGridTextColumn Header="{Binding Source={StaticResource Loc}, Path=[HoldMs]}"
                                        Binding="{Binding HoldThresholdMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="0.8*" />
                    <DataGridTextColumn Header="{Binding Source={StaticResource Loc}, Path=[Description]}"
                                        Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="1.6*" />
                    <DataGridTemplateColumn Header="{Binding Source={StaticResource Loc}, Path=[Trigger]}" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Trigger}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.AvailableTriggerModes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedItem="{Binding Trigger, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{Binding Source={StaticResource Loc}, Path=[Threshold]}"
                                        Binding="{Binding AnalogThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="1.1*" />
                </DataGrid.Columns>
            </DataGrid>

            <Expander Grid.Row="1"
                      Header="{Binding Source={StaticResource Loc}, Path=[SelectedMappingDetails]}"
                      IsExpanded="False"
                      Margin="0,10,0,0">
                <Expander.Style>
                    <Style TargetType="{x:Type Expander}">
                        <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type Expander}">
                                    <StackPanel>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <ToggleButton x:Name="HeaderSite"
                                                          Grid.Column="0"
                                                          Width="18"
                                                          Height="18"
                                                          Margin="0,0,8,0"
                                                          VerticalAlignment="Center"
                                                          Background="{DynamicResource AppControlSurfaceAltBrush}"
                                                          BorderBrush="{DynamicResource AppBorderBrush}"
                                                          BorderThickness="1"
                                                          Padding="0"
                                                          IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}, Mode=TwoWay}">
                                                <ToggleButton.Template>
                                                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                                                        <Border x:Name="ArrowCircle"
                                                                Background="{TemplateBinding Background}"
                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                CornerRadius="9">
                                                            <Path x:Name="Arrow"
                                                                  Width="8"
                                                                  Height="5"
                                                                  VerticalAlignment="Center"
                                                                  HorizontalAlignment="Center"
                                                                  Fill="{DynamicResource AppSecondaryTextBrush}"
                                                                  Data="M 0 5 L 8 5 L 4 0 Z" />
                                                        </Border>
                                                        <ControlTemplate.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter TargetName="ArrowCircle" Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                                                                <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource AppAccentBrush}" />
                                                            </Trigger>
                                                            <Trigger Property="IsChecked" Value="True">
                                                                <Setter TargetName="Arrow" Property="Data" Value="M 0 0 L 8 0 L 4 5 Z" />
                                                            </Trigger>
                                                        </ControlTemplate.Triggers>
                                                    </ControlTemplate>
                                                </ToggleButton.Template>
                                            </ToggleButton>
                                            <ContentPresenter Grid.Column="1"
                                                              ContentSource="Header"
                                                              VerticalAlignment="Center"
                                                              RecognizesAccessKey="True" />
                                        </Grid>
                                        <ContentPresenter x:Name="ExpandSite"
                                                          Margin="{TemplateBinding Padding}"
                                                          Visibility="Collapsed" />
                                    </StackPanel>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsExpanded" Value="True">
                                            <Setter TargetName="ExpandSite" Property="Visibility" Value="Visible" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </Expander.Style>
                <StackPanel Margin="0,8,0,0">
                    <TextBlock Text="{Binding KeyboardKeyCapturePrompt}"
                               Foreground="{DynamicResource AppAccentTextBrush}"
                               Margin="0,0,0,8" />

                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Source]}" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding AvailableGamepadButtons}"
                              IsEditable="True"
                              SelectedItem="{Binding EditBindingFromButton, Mode=TwoWay}" />

                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Trigger]}" Margin="0,8,0,4" />
                    <ComboBox ItemsSource="{Binding AvailableTriggerModes}"
                              SelectedItem="{Binding EditBindingTrigger, Mode=TwoWay}" />

                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[KbmOutputTap]}" Margin="0,8,0,4" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding EditBindingKeyboardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Content="{Binding Source={StaticResource Loc}, Path=[RecordKey]}"
                                Command="{Binding RecordKeyboardKeyCommand}"
                                Margin="8,0,0,0" />
                        <Button Grid.Column="2"
                                Content="{Binding Source={StaticResource Loc}, Path=[UpdateSelectedBinding]}"
                                Command="{Binding UpdateSelectedBindingCommand}"
                                Margin="8,0,0,0" />
                    </Grid>

                    <TextBlock TextWrapping="Wrap"
                               Margin="0,10,0,4"
                               Opacity="0.85">
                        <Run Text="{Binding Source={StaticResource Loc}, Path=[HoldBindHelp], Mode=OneWay}" />
                    </TextBlock>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[HoldOutputLongPress]}" Margin="0,0,0,4" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding EditBindingHoldKeyboardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Content="{Binding Source={StaticResource Loc}, Path=[Record]}"
                                Command="{Binding RecordHoldKeyboardKeyCommand}"
                                Margin="8,0,0,0" />
                    </Grid>
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[HoldThresholdDefault]}" Margin="0,8,0,4" />
                    <TextBox Text="{Binding EditBindingHoldThresholdText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Description]}" Margin="0,8,0,4" />
                    <TextBox Text="{Binding EditBindingDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Expander>

            <WrapPanel Grid.Row="2" Margin="0,10,0,0">
                <Button Content="{Binding Source={StaticResource Loc}, Path=[AddMapping]}"
                        Command="{Binding AddMappingCommand}"
                        Margin="0,0,10,0" />
                <Button Content="{Binding Source={StaticResource Loc}, Path=[RemoveSelected]}"
                        Command="{Binding RemoveSelectedMappingCommand}"
                        Margin="0,0,10,0" />
            </WrapPanel>
        </Grid>
    </Border>
</UserControl>
