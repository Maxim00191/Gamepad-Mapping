<UserControl x:Class="Gamepad_Mapping.Views.Sections.MappingEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:models="clr-namespace:GamepadMapperGUI.Models"
             xmlns:utils="clr-namespace:Gamepad_Mapping.Utils"
             MinHeight="0"
             VerticalAlignment="Stretch">
    <UserControl.Resources>
        <utils:GamepadBindingTypeToLocalizationConverter x:Key="GamepadBindingTypeToLoc" />
        <utils:MappingFromValueItemsSourceConverter x:Key="FromValueItems" />
    </UserControl.Resources>
    <Grid VerticalAlignment="Stretch">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <DataGrid ItemsSource="{Binding Mappings}"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  SelectedItem="{Binding SelectedMapping, Mode=TwoWay}"
                  SelectionUnit="FullRow"
                  Margin="0"
                  VerticalAlignment="Stretch"
                  MinHeight="200"
                  VerticalScrollBarVisibility="Auto">
            <!-- ... existing columns ... -->
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="{Binding Source={StaticResource Loc}, Path=[FromType]}"
                                        Width="1.1*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center"
                                       Text="{Binding From.Type, Converter={StaticResource GamepadBindingTypeToLoc}}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DataContext.AvailableGamepadBindingTypes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedItem="{Binding From.Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate DataType="{x:Type models:GamepadBindingType}">
                                        <TextBlock Text="{Binding Converter={StaticResource GamepadBindingTypeToLoc}}" />
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="{Binding Source={StaticResource Loc}, Path=[FromValue]}" Width="1.2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center" Text="{Binding From.Value}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <Grid>
                                <TextBlock VerticalAlignment="Center"
                                           Text="{Binding From.Value}">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding From.Type}" Value="{x:Static models:GamepadBindingType.LeftTrigger}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding From.Type}" Value="{x:Static models:GamepadBindingType.RightTrigger}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ComboBox IsEditable="True"
                                          Text="{Binding From.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBox.Style>
                                        <Style TargetType="ComboBox">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding From.Type}" Value="{x:Static models:GamepadBindingType.Button}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ComboBox.Style>
                                    <ComboBox.ItemsSource>
                                        <MultiBinding Converter="{StaticResource FromValueItems}">
                                            <Binding Path="From.Type" />
                                            <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                        </MultiBinding>
                                    </ComboBox.ItemsSource>
                                </ComboBox>
                                <ComboBox SelectedItem="{Binding From.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBox.Style>
                                        <Style TargetType="ComboBox">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding From.Type}" Value="{x:Static models:GamepadBindingType.LeftThumbstick}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                                <DataTrigger Binding="{Binding From.Type}" Value="{x:Static models:GamepadBindingType.RightThumbstick}">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ComboBox.Style>
                                    <ComboBox.ItemsSource>
                                        <MultiBinding Converter="{StaticResource FromValueItems}">
                                            <Binding Path="From.Type" />
                                            <Binding Path="DataContext" RelativeSource="{RelativeSource AncestorType=UserControl}" />
                                        </MultiBinding>
                                    </ComboBox.ItemsSource>
                                </ComboBox>
                            </Grid>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="{Binding Source={StaticResource Loc}, Path=[CatalogColumnActionId]}"
                                        Width="1*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding ActionId}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ActionId}" Value="{x:Null}">
                                                <Setter Property="Text" Value="{Binding Source={StaticResource Loc}, Path=[MappingActionIdManual]}" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding ActionId}" Value="">
                                                <Setter Property="Text" Value="{Binding Source={StaticResource Loc}, Path=[MappingActionIdManual]}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DataContext.KeyboardActionsForPicker, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedValuePath="Id"
                                      SelectedValue="{Binding ActionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged, TargetNullValue=''}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Text" Value="{Binding Id}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Id}" Value="">
                                                            <Setter Property="Text" Value="{Binding Source={StaticResource Loc}, Path=[MappingActionIdManual]}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{Binding Source={StaticResource Loc}, Path=[KbmOutputShort]}"
                                    IsReadOnly="True"
                                    Binding="{Binding OutputSummaryForGrid, Mode=OneWay}"
                                    Width="1.2*" />
                <DataGridTextColumn Header="{Binding Source={StaticResource Loc}, Path=[HoldOutput]}"
                                    Binding="{Binding HoldKeyboardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="*" />
                <DataGridTextColumn Header="{Binding Source={StaticResource Loc}, Path=[HoldMs]}"
                                    Binding="{Binding HoldThresholdMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="0.8*" />
                <DataGridTextColumn Header="{Binding Source={StaticResource Loc}, Path=[Description]}"
                                    Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="1.6*" />
                <DataGridTemplateColumn Header="{Binding Source={StaticResource Loc}, Path=[Trigger]}" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Trigger}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DataContext.AvailableTriggerModes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedItem="{Binding Trigger, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="{Binding Source={StaticResource Loc}, Path=[Threshold]}"
                                    Binding="{Binding AnalogThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="1.1*" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="1" 
                Background="#2D2D30" 
                BorderBrush="#3F3F46" 
                BorderThickness="0,1,0,0"
                Padding="8,4">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Visibility="{Binding HasUnusedActionIds, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <TextBlock Text="&#xE946;" 
                               FontFamily="Segoe MDL2 Assets" 
                               Foreground="#007ACC" 
                               VerticalAlignment="Center" 
                               Margin="0,0,8,0"/>
                    <TextBlock Text="{Binding UnusedActionIdsHint}" 
                               Foreground="#CCCCCC" 
                               FontSize="12"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               ToolTipService.InitialShowDelay="100">
                        <TextBlock.ToolTip>
                            <ToolTip Background="#252526" Foreground="#F1F1F1" BorderBrush="#3F3F46">
                                <StackPanel Margin="4">
                                    <TextBlock Text="Unused Action IDs in Catalog:" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding UnusedActionIdsTooltip}"/>
                                </StackPanel>
                            </ToolTip>
                        </TextBlock.ToolTip>
                    </TextBlock>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Visibility="{Binding HasValidationError, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,4,0,0">
                    <TextBlock Text="&#xE783;" 
                               FontFamily="Segoe MDL2 Assets" 
                               Foreground="Red" 
                               VerticalAlignment="Center" 
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Validation Errors" 
                               Foreground="Red" 
                               FontSize="12"
                               VerticalAlignment="Center">
                        <TextBlock.ToolTip>
                            <ToolTip Background="#252526" Foreground="#F1F1F1" BorderBrush="#3F3F46">
                                <StackPanel Margin="4">
                                    <TextBlock Text="Profile Validation Errors:" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding ValidationError}"/>
                                </StackPanel>
                            </ToolTip>
                        </TextBlock.ToolTip>
                    </TextBlock>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Visibility="{Binding HasValidationWarning, Converter={StaticResource BooleanToVisibilityConverter}}" Margin="0,4,0,0">
                    <TextBlock Text="&#xE7BA;" 
                               FontFamily="Segoe MDL2 Assets" 
                               Foreground="Orange" 
                               VerticalAlignment="Center" 
                               Margin="0,0,8,0"/>
                    <TextBlock Text="Validation Warnings" 
                               Foreground="Orange" 
                               FontSize="12"
                               VerticalAlignment="Center">
                        <TextBlock.ToolTip>
                            <ToolTip Background="#252526" Foreground="#F1F1F1" BorderBrush="#3F3F46">
                                <StackPanel Margin="4">
                                    <TextBlock Text="Profile Validation Warnings:" FontWeight="Bold" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding ValidationWarning}"/>
                                </StackPanel>
                            </ToolTip>
                        </TextBlock.ToolTip>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
