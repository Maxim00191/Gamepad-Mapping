<UserControl x:Class="Gamepad_Mapping.Views.Sections.MappingEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel LastChildFill="True">
        <DockPanel DockPanel.Dock="Bottom" LastChildFill="True" Margin="0,12,0,0">
            <StackPanel>
                <TextBlock Text="{Binding KeyboardKeyCapturePrompt}"
                           Foreground="{DynamicResource AppAccentTextBrush}"
                           Margin="0,0,0,8" />

                <TextBlock Text="Edit selected binding"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6" />
                <Grid Margin="0,0,0,8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="95" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0"
                               Grid.Column="0"
                               Text="Button:"
                               VerticalAlignment="Center"
                               Margin="0,0,8,0" />
                    <ComboBox Grid.Row="0"
                              Grid.Column="1"
                              ItemsSource="{Binding AvailableGamepadButtons}"
                              SelectedItem="{Binding EditBindingFromButton, Mode=TwoWay}" />

                    <TextBlock Grid.Row="1"
                               Grid.Column="0"
                               Text="Trigger:"
                               VerticalAlignment="Center"
                               Margin="0,8,8,0" />
                    <ComboBox Grid.Row="1"
                              Grid.Column="1"
                              Margin="0,8,0,0"
                              ItemsSource="{Binding AvailableTriggerModes}"
                              SelectedItem="{Binding EditBindingTrigger, Mode=TwoWay}" />

                    <TextBlock Grid.Row="2"
                               Grid.Column="0"
                               Text="Key:"
                               VerticalAlignment="Center"
                               Margin="0,8,8,0" />
                    <Grid Grid.Row="2"
                          Grid.Column="1"
                          Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding EditBindingKeyboardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Content="Record key"
                                Command="{Binding RecordKeyboardKeyCommand}"
                                Margin="8,0,0,0" />
                        <Button Grid.Column="2"
                                Content="Update selected binding"
                                Command="{Binding UpdateSelectedBindingCommand}"
                                Margin="8,0,0,0" />
                    </Grid>
                </Grid>

                <WrapPanel>
                    <Button Content="Add mapping"
                            Command="{Binding AddMappingCommand}"
                            Margin="0,0,10,0" />
                    <Button Content="Remove selected"
                            Command="{Binding RemoveSelectedMappingCommand}"
                            Margin="0,0,10,0" />
                </WrapPanel>
            </StackPanel>
        </DockPanel>

        <DataGrid ItemsSource="{Binding Mappings}"
                  AutoGenerateColumns="False"
                  IsReadOnly="False"
                  CanUserAddRows="False"
                  HeadersVisibility="Column"
                  SelectedItem="{Binding SelectedMapping, Mode=TwoWay}"
                  SelectionUnit="FullRow"
                  Margin="0"
                  VerticalAlignment="Stretch">
            <DataGrid.Columns>
                <DataGridTextColumn Header="From Type"
                                    Binding="{Binding From.Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="1.2*" />
                <DataGridTemplateColumn Header="From Value" Width="1.2*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding From.Value}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DataContext.AvailableGamepadButtons, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedItem="{Binding From.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Keyboard Key"
                                    IsReadOnly="True"
                                    Binding="{Binding KeyboardKey, Mode=OneWay}"
                                    Width="1.6*" />
                <DataGridTemplateColumn Header="Trigger (Pressed/Released/Tap)" Width="*">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Trigger}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                    <DataGridTemplateColumn.CellEditingTemplate>
                        <DataTemplate>
                            <ComboBox ItemsSource="{Binding DataContext.AvailableTriggerModes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                      SelectedItem="{Binding Trigger, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellEditingTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="Analog Threshold"
                                    Binding="{Binding AnalogThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                    Width="1.5*" />
            </DataGrid.Columns>
        </DataGrid>
    </DockPanel>
</UserControl>
