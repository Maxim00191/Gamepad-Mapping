<UserControl x:Class="Gamepad_Mapping.Views.Sections.MappingEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="12">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DataGrid Grid.Row="0"
                      ItemsSource="{Binding Mappings}"
                      AutoGenerateColumns="False"
                      IsReadOnly="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      SelectedItem="{Binding SelectedMapping, Mode=TwoWay}"
                      SelectionUnit="FullRow"
                      Margin="0"
                      VerticalAlignment="Stretch"
                      MinHeight="200">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="From Type"
                                        Binding="{Binding From.Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="1.1*" />
                    <DataGridTemplateColumn Header="From Value" Width="1.2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding From.Value}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.AvailableGamepadButtons, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedItem="{Binding From.Value, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="KB/M Output"
                                        IsReadOnly="True"
                                        Binding="{Binding KeyboardKey, Mode=OneWay}"
                                        Width="1.2*" />
                    <DataGridTextColumn Header="Hold output"
                                        Binding="{Binding HoldKeyboardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="*" />
                    <DataGridTextColumn Header="Hold ms"
                                        Binding="{Binding HoldThresholdMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="0.8*" />
                    <DataGridTextColumn Header="Description"
                                        Binding="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="1.6*" />
                    <DataGridTemplateColumn Header="Trigger" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Trigger}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.AvailableTriggerModes, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedItem="{Binding Trigger, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="Threshold"
                                        Binding="{Binding AnalogThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="1.1*" />
                </DataGrid.Columns>
            </DataGrid>

            <Expander Grid.Row="1"
                      Header="Selected Mapping Details"
                      IsExpanded="False"
                      Margin="0,10,0,0">
                <StackPanel Margin="0,8,0,0">
                    <TextBlock Text="{Binding KeyboardKeyCapturePrompt}"
                               Foreground="{DynamicResource AppAccentTextBrush}"
                               Margin="0,0,0,8" />

                    <TextBlock Text="Source" Margin="0,0,0,4" />
                    <ComboBox ItemsSource="{Binding AvailableGamepadButtons}"
                              IsEditable="True"
                              SelectedItem="{Binding EditBindingFromButton, Mode=TwoWay}" />

                    <TextBlock Text="Trigger" Margin="0,8,0,4" />
                    <ComboBox ItemsSource="{Binding AvailableTriggerModes}"
                              SelectedItem="{Binding EditBindingTrigger, Mode=TwoWay}" />

                    <TextBlock Text="KB/M output (short press / tap)" Margin="0,8,0,4" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding EditBindingKeyboardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Content="Record key"
                                Command="{Binding RecordKeyboardKeyCommand}"
                                Margin="8,0,0,0" />
                        <Button Grid.Column="2"
                                Content="Update selected binding"
                                Command="{Binding UpdateSelectedBindingCommand}"
                                Margin="8,0,0,0" />
                    </Grid>

                    <TextBlock TextWrapping="Wrap"
                               Margin="0,10,0,4"
                               Opacity="0.85">
                        Hold bind (optional): Trigger must be Tap. Hold the button at least the threshold to send the hold key once; quick release sends the short key. Button-only chords (no LT/RT in the chord).
                    </TextBlock>
                    <TextBlock Text="Hold output (long press)" Margin="0,0,0,4" />
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0"
                                 Text="{Binding EditBindingHoldKeyboardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Grid.Column="1"
                                Content="Record"
                                Command="{Binding RecordHoldKeyboardKeyCommand}"
                                Margin="8,0,0,0" />
                    </Grid>
                    <TextBlock Text="Hold threshold (ms, empty = default ~450)" Margin="0,8,0,4" />
                    <TextBox Text="{Binding EditBindingHoldThresholdText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                    <TextBlock Text="Description" Margin="0,8,0,4" />
                    <TextBox Text="{Binding EditBindingDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </Expander>

            <WrapPanel Grid.Row="2" Margin="0,10,0,0">
                <Button Content="Add mapping"
                        Command="{Binding AddMappingCommand}"
                        Margin="0,0,10,0" />
                <Button Content="Remove selected"
                        Command="{Binding RemoveSelectedMappingCommand}"
                        Margin="0,0,10,0" />
            </WrapPanel>
        </Grid>
    </Border>
</UserControl>
