<UserControl x:Class="Gamepad_Mapping.Views.Sections.ProfileTemplatePanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border Background="{DynamicResource AppSurfaceBrush}"
            BorderBrush="{DynamicResource AppBorderBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="12"
            Margin="0,0,0,12">
        <StackPanel>
            <TextBlock Text="Profile and Template"
                       FontWeight="Bold"
                       Margin="0,0,0,10" />

            <TextBlock Text="Template" Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding AvailableTemplates}"
                      DisplayMemberPath="DisplayName"
                      SelectedItem="{Binding SelectedTemplate}" />

            <TextBlock Text="Display name" Margin="0,10,0,4" />
            <TextBox Text="{Binding CurrentTemplateDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="{Binding MappingCount, StringFormat=Mappings: {0}}"
                       Margin="0,8,0,0" />

            <WrapPanel Margin="0,10,0,0">
                <Button Content="Save profile"
                        Command="{Binding SaveProfileCommand}"
                        Margin="0,0,10,0"
                        HorizontalAlignment="Left" />

                <Button Content="Delete profile"
                        Command="{Binding DeleteSelectedProfileCommand}"
                        HorizontalAlignment="Left" />
            </WrapPanel>

            <Separator Margin="0,12,0,12" />

            <TextBlock Text="Create New Profile"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <TextBlock Text="Game key" Margin="0,0,0,4" />
            <TextBox Text="{Binding NewProfileGameId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Text="Display name" Margin="0,8,0,4" />
            <TextBox Text="{Binding NewProfileDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <WrapPanel Margin="0,12,0,0">
                <Button Content="Create profile"
                        Command="{Binding CreateProfileCommand}"
                        Margin="0,0,10,0"
                        HorizontalAlignment="Left" />
                <Button Content="Reload template"
                        Command="{Binding ReloadTemplateCommand}"
                        HorizontalAlignment="Left" />
            </WrapPanel>
        </StackPanel>
    </Border>
</UserControl>
