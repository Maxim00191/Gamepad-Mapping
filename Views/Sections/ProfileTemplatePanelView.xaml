<UserControl x:Class="Gamepad_Mapping.Views.Sections.ProfileTemplatePanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sections="clr-namespace:Gamepad_Mapping.Views.Sections">
    <Border Style="{StaticResource SectionCardBorder}"
            Margin="0,0,0,12">
        <StackPanel Grid.IsSharedSizeScope="True">
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ProfileAndTemplate]}"
                       FontWeight="Bold"
                       Margin="0,0,0,10" />

            <Grid Margin="0,0,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"
                                      SharedSizeGroup="ProfileTemplateLabelCol" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                           Text="{Binding Source={StaticResource Loc}, Path=[Template]}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                <ComboBox Grid.Column="1"
                          Height="32"
                          VerticalContentAlignment="Center"
                          ItemsSource="{Binding AvailableTemplates}"
                          DisplayMemberPath="TemplatePickerLabel"
                          SelectedItem="{Binding SelectedTemplate}" />
            </Grid>

            <sections:TemplateIdentityFormView Margin="0,10,0,0"
                                              DataContext="{Binding}" />

            <TextBlock Text="{Binding MappingCount, StringFormat=Mappings: {0}}"
                       Margin="0,10,0,0"
                       Opacity="0.85" />

            <WrapPanel Margin="0,10,0,0">
                <Button Content="{Binding Source={StaticResource Loc}, Path=[SaveProfile]}"
                        Command="{Binding SaveProfileCommand}"
                        Margin="0,0,10,0"
                        HorizontalAlignment="Left" />

                <Button Content="{Binding Source={StaticResource Loc}, Path=[DeleteProfile]}"
                        Command="{Binding DeleteSelectedProfileCommand}"
                        HorizontalAlignment="Left" />
            </WrapPanel>

            <Separator Margin="0,12,0,12" />

            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CreateNewProfile]}"
                       FontWeight="SemiBold"
                       Margin="0,0,0,8" />

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"
                                      SharedSizeGroup="ProfileTemplateLabelCol" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{Binding Source={StaticResource Loc}, Path=[ProfileId]}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,8" />
                <TextBox Grid.Row="0"
                         Grid.Column="1"
                         MinHeight="28"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,8"
                         Text="{Binding NewProfileId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Text="{Binding Source={StaticResource Loc}, Path=[GameKey]}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,8" />
                <TextBox Grid.Row="1"
                         Grid.Column="1"
                         MinHeight="28"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,8"
                         Text="{Binding NewProfileTemplateGroupId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Text="{Binding Source={StaticResource Loc}, Path=[TemplateCatalogFolder]}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,8" />
                <TextBox Grid.Row="2"
                         Grid.Column="1"
                         MinHeight="28"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,8"
                         Text="{Binding NewProfileCatalogFolder, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="3"
                           Grid.Column="0"
                           Text="{Binding Source={StaticResource Loc}, Path=[DisplayName]}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,8" />
                <TextBox Grid.Row="3"
                         Grid.Column="1"
                         MinHeight="28"
                         VerticalContentAlignment="Center"
                         Margin="0,0,0,8"
                         Text="{Binding NewProfileDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="4"
                           Grid.Column="0"
                           Text="{Binding Source={StaticResource Loc}, Path=[TemplateAuthor]}"
                           VerticalAlignment="Center"
                           Margin="0,0,12,0" />
                <TextBox Grid.Row="4"
                         Grid.Column="1"
                         MinHeight="28"
                         VerticalContentAlignment="Center"
                         Text="{Binding NewProfileAuthor, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </Grid>

            <WrapPanel Margin="0,12,0,0">
                <Button Content="{Binding Source={StaticResource Loc}, Path=[CreateProfile]}"
                        Command="{Binding CreateProfileCommand}"
                        Margin="0,0,10,0"
                        HorizontalAlignment="Left" />
                <Button Content="{Binding Source={StaticResource Loc}, Path=[ReloadTemplate]}"
                        Command="{Binding ReloadTemplateCommand}"
                        HorizontalAlignment="Left" />
            </WrapPanel>
        </StackPanel>
    </Border>
</UserControl>
