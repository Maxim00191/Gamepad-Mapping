<UserControl x:Class="Gamepad_Mapping.Views.Sections.ProfileTemplatePanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="0,0,0,12">
        <TextBlock Text="Template" FontWeight="Bold" Margin="0,0,0,6" />
        <ComboBox ItemsSource="{Binding AvailableTemplates}"
                  DisplayMemberPath="DisplayName"
                  SelectedItem="{Binding SelectedTemplate}" />

        <Grid Margin="0,10,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="Display name:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Grid.Column="1"
                     Text="{Binding CurrentTemplateDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
        </Grid>

        <TextBlock Text="{Binding MappingCount, StringFormat=Mappings: {0}}"
                   Margin="0,6,0,0" />

        <WrapPanel Margin="0,10,0,0">
            <Button Content="Save profile"
                    Command="{Binding SaveProfileCommand}"
                    Margin="0,0,10,0"
                    HorizontalAlignment="Left" />

            <Button Content="Delete profile"
                    Command="{Binding DeleteSelectedProfileCommand}"
                    HorizontalAlignment="Left" />
        </WrapPanel>

        <Separator Margin="0,12,0,12" />

        <TextBlock Text="New profile" FontWeight="SemiBold" Margin="0,0,0,6" />
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="80" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Game key:" VerticalAlignment="Center" Margin="0,0,8,0" />
            <TextBox Grid.Row="0" Grid.Column="1"
                     Text="{Binding NewProfileGameId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock Grid.Row="1" Grid.Column="0" Text="Display:" VerticalAlignment="Center" Margin="0,8,8,0" />
            <TextBox Grid.Row="1" Grid.Column="1" Margin="0,8,0,0"
                     Text="{Binding NewProfileDisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

            <Button Grid.Row="2" Grid.Column="1"
                    Content="Create profile"
                    Command="{Binding CreateProfileCommand}"
                    Margin="0,12,0,0"
                    HorizontalAlignment="Left" />
        </Grid>

        <Button Content="Reload template"
                Command="{Binding ReloadTemplateCommand}"
                Margin="0,12,0,0"
                HorizontalAlignment="Left" />
    </StackPanel>
</UserControl>
