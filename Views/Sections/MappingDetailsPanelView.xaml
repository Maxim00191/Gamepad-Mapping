<UserControl x:Class="Gamepad_Mapping.Views.Sections.MappingDetailsPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:strategies="clr-namespace:Gamepad_Mapping.ViewModels.Strategies"
             xmlns:models="clr-namespace:GamepadMapperGUI.Models"
             xmlns:utils="clr-namespace:Gamepad_Mapping.Utils">
    <UserControl.Resources>
        <utils:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
        <utils:MappingActionTypeToLocalizationConverter x:Key="ActionTypeToLoc" />
        <utils:ItemCycleDirectionToLocalizationConverter x:Key="ItemCycleDirToLoc" />
        <utils:TriggerMomentToLocalizationConverter x:Key="TriggerMomentToLoc" />
        <!-- Keyboard Strategy Template -->
        <DataTemplate DataType="{x:Type strategies:KeyboardActionEditorViewModel}">
            <StackPanel>
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CatalogColumnActionId]}"
                           Margin="0,8,0,4" />
                <ComboBox Margin="0,0,0,4"
                          ItemsSource="{Binding DataContext.KeyboardActionsForPicker, RelativeSource={RelativeSource AncestorType=UserControl, Mode=FindAncestor}}"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding ActionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="{Binding Id}" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding Id}" Value="">
                                                <Setter Property="Text" Value="{Binding Source={StaticResource Loc}, Path=[MappingActionIdManual]}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[KbmOutputTap]}" Margin="0,8,0,4" />
                <Grid>
                    <Grid.Style>
                        <Style TargetType="Grid">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsKeyboardKeyReadOnly}" Value="True">
                                    <Setter Property="IsEnabled" Value="False" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Grid.Style>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             IsReadOnly="{Binding IsKeyboardKeyReadOnly}"
                             Text="{Binding KeyboardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Content="{Binding Source={StaticResource Loc}, Path=[RecordKey]}"
                            Command="{Binding RecordKeyboardKeyCommand}"
                            Margin="8,0,0,0" />
                </Grid>

                <TextBlock TextWrapping="Wrap"
                           Margin="0,10,0,4"
                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                           FontSize="12">
                    <Run Text="{Binding Source={StaticResource Loc}, Path=[HoldBindHelp], Mode=OneWay}" />
                </TextBlock>
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[HoldOutputLongPress]}" Margin="0,0,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding HoldKeyboardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Content="{Binding Source={StaticResource Loc}, Path=[Record]}"
                            Command="{Binding RecordHoldKeyboardKeyCommand}"
                            Margin="8,0,0,0" />
                </Grid>

                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[HoldThresholdDefault]}" Margin="0,8,0,4" />
                <TextBox Text="{Binding HoldThresholdText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </DataTemplate>

        <!-- Item Cycle Strategy Template -->
        <DataTemplate DataType="{x:Type strategies:ItemCycleActionEditorViewModel}">
            <StackPanel>
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ItemCycleDirection]}" Margin="0,8,0,4" />
                <ComboBox ItemsSource="{Binding DataContext.AvailableItemCycleDirections, RelativeSource={RelativeSource AncestorType=UserControl, Mode=FindAncestor}}"
                          SelectedItem="{Binding Direction, Mode=TwoWay}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource ItemCycleDirToLoc}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ItemCycleSlotCount]}" Margin="0,8,0,4" />
                <TextBox Text="{Binding SlotCountText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock TextWrapping="Wrap"
                           Text="{Binding Source={StaticResource Loc}, Path=[ItemCycleWithKeys]}"
                           Margin="0,8,0,4" />
                <TextBox Text="{Binding WithKeys, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock TextWrapping="Wrap"
                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                           FontSize="12"
                           Text="{Binding Source={StaticResource Loc}, Path=[ItemCycleDefaultBehavior]}"
                           Margin="0,10,0,0" />

                <TextBlock TextWrapping="Wrap"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource AppTextBrush}"
                           Text="{Binding Source={StaticResource Loc}, Path=[ItemCycleCustomOutputsSection]}"
                           Margin="0,12,0,4" />
                <TextBlock TextWrapping="Wrap"
                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                           FontSize="12"
                           Text="{Binding Source={StaticResource Loc}, Path=[ItemCycleLoopKeysHint]}"
                           Margin="0,0,0,6" />

                <TextBlock TextWrapping="Wrap"
                           Text="{Binding Source={StaticResource Loc}, Path=[ItemCycleLoopForwardKey]}"
                           Margin="0,0,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding ForwardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Content="{Binding Source={StaticResource Loc}, Path=[RecordKey]}"
                            Command="{Binding RecordForwardKeyCommand}"
                            Margin="8,0,0,0" />
                </Grid>

                <TextBlock TextWrapping="Wrap"
                           Text="{Binding Source={StaticResource Loc}, Path=[ItemCycleLoopBackwardKey]}"
                           Margin="0,8,0,4" />
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding BackwardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Content="{Binding Source={StaticResource Loc}, Path=[RecordKey]}"
                            Command="{Binding RecordBackwardKeyCommand}"
                            Margin="8,0,0,0" />
                </Grid>
            </StackPanel>
        </DataTemplate>

        <!-- Template Toggle Strategy Template -->
        <DataTemplate DataType="{x:Type strategies:TemplateToggleActionEditorViewModel}">
            <StackPanel>
                <TextBlock TextWrapping="Wrap"
                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                           FontSize="12"
                           Text="{Binding Source={StaticResource Loc}, Path=[TemplateToggleHint]}"
                           Margin="0,8,0,8" />
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TemplateToggleAlternateProfile]}"
                           Margin="0,0,0,4" />
                <ComboBox ItemsSource="{Binding DataContext.AvailableProfileTemplates, RelativeSource={RelativeSource AncestorType=UserControl, Mode=FindAncestor}}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="ProfileId"
                          SelectedValue="{Binding AlternateProfileId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </DataTemplate>

        <!-- Radial Menu Strategy Template -->
        <DataTemplate DataType="{x:Type strategies:RadialMenuActionEditorViewModel}">
            <StackPanel>
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[MappingSelectRadialMenu]}"
                           Margin="0,8,0,4" />
                <ComboBox ItemsSource="{Binding DataContext.AvailableRadialMenus, RelativeSource={RelativeSource AncestorType=UserControl, Mode=FindAncestor}}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding RadialMenuId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
        </DataTemplate>
    </UserControl.Resources>
    <Grid MinHeight="0"
          ClipToBounds="True">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" MinHeight="0" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <ScrollViewer Grid.Row="0"
                          MinHeight="0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   Text="{Binding Source={StaticResource Loc}, Path=[SelectedMappingDetails]}">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCreatingNewMapping}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock FontWeight="SemiBold"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   Text="{Binding Source={StaticResource Loc}, Path=[NewMappingDetailsHeader]}">
                            <TextBlock.Style>
                                <Style TargetType="{x:Type TextBlock}">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsCreatingNewMapping}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>

                    <TextBlock Text="{Binding KeyboardKeyCapturePrompt}"
                               Foreground="{DynamicResource AppAccentTextBrush}"
                               Margin="0,0,0,8" />

                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Source]}" Margin="0,0,0,4" />

                    <CheckBox Margin="0,0,0,4"
                              Content="{Binding Source={StaticResource Loc}, Path=[SourceIsCombination]}"
                              IsChecked="{Binding InputTrigger.EditSourceIsCombination, Mode=TwoWay}" />

                    <Grid Visibility="{Binding InputTrigger.EditSourceIsCombination, Converter={StaticResource InverseBoolToVis}, ConverterParameter=Inverse}">
                        <ComboBox ItemsSource="{Binding InputTrigger.AvailableGamepadButtons}"
                                  IsEditable="True"
                                  SelectedItem="{Binding InputTrigger.EditBindingFromButton, Mode=TwoWay}" />
                    </Grid>

                    <Grid Visibility="{Binding InputTrigger.EditSourceIsCombination, Converter={StaticResource InverseBoolToVis}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <ComboBox Grid.Column="0"
                                  ItemsSource="{Binding InputTrigger.AvailableGamepadButtons}"
                                  SelectedItem="{Binding InputTrigger.EditBindingComboButton1, Mode=TwoWay}" />
                        <TextBlock Grid.Column="1" Text="+" VerticalAlignment="Center" Margin="8,0" />
                        <ComboBox Grid.Column="2"
                                  ItemsSource="{Binding InputTrigger.AvailableGamepadButtons}"
                                  SelectedItem="{Binding InputTrigger.EditBindingComboButton2, Mode=TwoWay}" />
                    </Grid>

                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                               FontSize="12"
                               Margin="0,2,0,4"
                               Text="{Binding Source={StaticResource Loc}, Path=[SourceCombinationHint]}"
                               Visibility="{Binding InputTrigger.EditSourceIsCombination, Converter={StaticResource InverseBoolToVis}}" />

                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Trigger]}" Margin="0,8,0,4" />
                    <ComboBox ItemsSource="{Binding AvailableTriggerModes}"
                              SelectedItem="{Binding EditBindingTrigger, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource TriggerMomentToLoc}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ActionType]}" Margin="0,8,0,4" />
                    <ComboBox ItemsSource="{Binding AvailableActionTypes}"
                              SelectedItem="{Binding SelectedActionType, Mode=TwoWay}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Converter={StaticResource ActionTypeToLoc}}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <ContentControl Content="{Binding CurrentActionEditor}" Margin="0,8,0,0" />

                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[Description]}" Margin="0,8,0,4" />
                    <TextBox Text="{Binding EditBindingDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                </StackPanel>
            </ScrollViewer>

            <Grid Grid.Row="1" Margin="0,10,0,0">
                <WrapPanel x:Name="EditButtons">
                    <WrapPanel.Style>
                        <Style TargetType="{x:Type WrapPanel}">
                            <Setter Property="Visibility" Value="Visible" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCreatingNewMapping}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </WrapPanel.Style>
                    <Button Content="{Binding Source={StaticResource Loc}, Path=[UpdateSelectedBinding]}"
                            Command="{Binding UpdateSelectedBindingCommand}"
                            Margin="0,0,10,0" />
                    <Button Content="{Binding Source={StaticResource Loc}, Path=[RemoveSelected]}"
                            Command="{Binding RemoveSelectedMappingCommand}" />
                </WrapPanel>

                <WrapPanel x:Name="CreateButtons">
                    <WrapPanel.Style>
                        <Style TargetType="{x:Type WrapPanel}">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsCreatingNewMapping}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </WrapPanel.Style>
                    <Button Content="{Binding Source={StaticResource Loc}, Path=[SaveNewMapping]}"
                            Command="{Binding SaveNewMappingCommand}"
                            Margin="0,0,10,0" />
                    <Button Content="{Binding Source={StaticResource Loc}, Path=[Cancel]}"
                            Command="{Binding CancelCreateNewMappingCommand}" />
                </WrapPanel>
            </Grid>
        </Grid>
</UserControl>
