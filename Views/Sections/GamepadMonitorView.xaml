<UserControl x:Class="Gamepad_Mapping.Views.Sections.GamepadMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             VerticalAlignment="Stretch">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalAlignment="Stretch"
                      PanningMode="VerticalOnly">
            <StackPanel>
                <TextBlock Text="{Binding IsGamepadRunning, StringFormat=Reader running: {0}}" />

                <Grid Margin="0,8,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="{Binding Source={StaticResource Loc}, Path=[AnalogSettings]}"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppSecondaryTextBrush}" />
                    <Grid Grid.Column="1"
                          HorizontalAlignment="Right">
                        <ToggleButton x:Name="AnalogSettingsButton"
                                      Style="{StaticResource ToolbarToggleButtonStyle}"
                                      Width="28"
                                      Height="28"
                                      HorizontalAlignment="Right">
                            <Path Width="10"
                                  Height="10"
                                  Stretch="Uniform"
                                  Stroke="{DynamicResource AppSecondaryTextBrush}"
                                  StrokeThickness="1.4"
                                  Data="M2,5 L8,5 M5,2 L5,8" />
                        </ToggleButton>
                        <Popup Placement="Bottom"
                               PlacementTarget="{Binding ElementName=AnalogSettingsButton}"
                               StaysOpen="False"
                               IsOpen="{Binding IsChecked, ElementName=AnalogSettingsButton, Mode=TwoWay}">
                            <Border Style="{StaticResource SectionCardBorder}"
                                    MinWidth="260">
                                <StackPanel>
                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ThumbstickDeadzoneHeader]}"
                                               FontWeight="SemiBold"
                                               Margin="0,0,0,8" />

                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[LeftStickLabel]}"
                                               Margin="0,0,0,2" />
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="0,0,0,6">
                                        <Slider Minimum="0"
                                                Maximum="0.4"
                                                Value="{Binding LeftThumbstickDeadzone, Mode=TwoWay}"
                                                TickFrequency="0.01"
                                                IsSnapToTickEnabled="True"
                                                Width="160" />
                                        <TextBlock Text="{Binding LeftThumbstickDeadzone, StringFormat={}{0:0.00}}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[RightStickLabel]}"
                                               Margin="0,4,0,2" />
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Slider Minimum="0"
                                                Maximum="0.4"
                                                Value="{Binding RightThumbstickDeadzone, Mode=TwoWay}"
                                                TickFrequency="0.01"
                                                IsSnapToTickEnabled="True"
                                                Width="160" />
                                        <TextBlock Text="{Binding RightThumbstickDeadzone, StringFormat={}{0:0.00}}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TriggerDeadzoneHeader]}"
                                               FontWeight="SemiBold"
                                               Margin="0,12,0,8" />

                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[LeftTriggerLabel]}"
                                               Margin="0,0,0,2" />
                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TriggerInnerDeadzoneShort]}"
                                               Margin="0,0,0,2"
                                               Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="0,0,0,4">
                                        <Slider Minimum="0"
                                                Maximum="0.4"
                                                Value="{Binding LeftTriggerInnerDeadzone, Mode=TwoWay}"
                                                TickFrequency="0.01"
                                                IsSnapToTickEnabled="True"
                                                Width="160" />
                                        <TextBlock Text="{Binding LeftTriggerInnerDeadzone, StringFormat={}{0:0.00}}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TriggerOuterDeadzoneShort]}"
                                               Margin="0,0,0,2"
                                               Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="0,0,0,6">
                                        <Slider Minimum="0.02"
                                                Maximum="1"
                                                Value="{Binding LeftTriggerOuterDeadzone, Mode=TwoWay}"
                                                TickFrequency="0.01"
                                                IsSnapToTickEnabled="True"
                                                Width="160" />
                                        <TextBlock Text="{Binding LeftTriggerOuterDeadzone, StringFormat={}{0:0.00}}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>

                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[RightTriggerLabel]}"
                                               Margin="0,4,0,2" />
                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TriggerInnerDeadzoneShort]}"
                                               Margin="0,0,0,2"
                                               Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center"
                                                Margin="0,0,0,4">
                                        <Slider Minimum="0"
                                                Maximum="0.4"
                                                Value="{Binding RightTriggerInnerDeadzone, Mode=TwoWay}"
                                                TickFrequency="0.01"
                                                IsSnapToTickEnabled="True"
                                                Width="160" />
                                        <TextBlock Text="{Binding RightTriggerInnerDeadzone, StringFormat={}{0:0.00}}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TriggerOuterDeadzoneShort]}"
                                               Margin="0,0,0,2"
                                               Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                    <StackPanel Orientation="Horizontal"
                                                VerticalAlignment="Center">
                                        <Slider Minimum="0.02"
                                                Maximum="1"
                                                Value="{Binding RightTriggerOuterDeadzone, Mode=TwoWay}"
                                                TickFrequency="0.01"
                                                IsSnapToTickEnabled="True"
                                                Width="160" />
                                        <TextBlock Text="{Binding RightTriggerOuterDeadzone, StringFormat={}{0:0.00}}"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>
                        </Popup>
                    </Grid>
                </Grid>

                <Separator Margin="0,10,0,10" />

                <TextBlock Text="{Binding LastButtonPressed, StringFormat=Pressed: {0}}" />
                <TextBlock Text="{Binding LastButtonReleased, StringFormat=Released: {0}}" Margin="0,2,0,0" />
                <TextBlock Text="{Binding LastMappedOutput, StringFormat=Mapped output: {0}}" Margin="0,2,0,0" />
                <TextBlock Text="{Binding LastMappingStatus, StringFormat=Output status: {0}}" Margin="0,2,0,0" TextWrapping="Wrap" />

                <Separator Margin="0,10,0,10" />

                <TextBlock Text="{Binding LeftThumbX, StringFormat=Left Thumb X: {0:0.00}}" />
                <TextBlock Text="{Binding LeftThumbY, StringFormat=Left Thumb Y: {0:0.00}}" />
                <TextBlock Text="{Binding RightThumbX, StringFormat=Right Thumb X: {0:0.00}}" />
                <TextBlock Text="{Binding RightThumbY, StringFormat=Right Thumb Y: {0:0.00}}" />

                <Separator Margin="0,10,0,10" />

                <TextBlock Text="{Binding LeftTrigger, StringFormat=Left Trigger: {0:0.00}}" />
                <TextBlock Text="{Binding RightTrigger, StringFormat=Right Trigger: {0:0.00}}" />

                <StackPanel Margin="0,16,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button Content="{Binding Source={StaticResource Loc}, Path=[StopReader]}"
                            Command="{Binding StopGamepadCommand}"
                            MinWidth="72"
                            Padding="10,0"
                            Height="32"
                            VerticalContentAlignment="Center" />
                    <Button Content="{Binding Source={StaticResource Loc}, Path=[StartReader]}"
                            Command="{Binding StartGamepadCommand}"
                            MinWidth="72"
                            Padding="10,0"
                            Height="32"
                            Margin="8,0,0,0"
                            VerticalContentAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
</UserControl>
