<UserControl x:Class="Gamepad_Mapping.Views.Sections.GamepadMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utils="clr-namespace:Gamepad_Mapping.Utils"
             VerticalAlignment="Stretch">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <utils:InverseBooleanToVisibilityConverter x:Key="InverseBoolToVis" />
    </UserControl.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalAlignment="Stretch"
                  PanningMode="VerticalOnly">
        <StackPanel>
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="6"
                         Height="6"
                         VerticalAlignment="Center"
                         Margin="0,0,6,0">
                    <Ellipse.Style>
                        <Style TargetType="Ellipse">
                            <Setter Property="Fill" Value="{DynamicResource AppAccentTextBrush}" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsGamepadRunning}" Value="False">
                                    <Setter Property="Fill" Value="{DynamicResource AppSecondaryTextBrush}" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Ellipse.Style>
                </Ellipse>
                <TextBlock FontSize="11"
                           VerticalAlignment="Center"
                           Text="{Binding Source={StaticResource Loc}, Path=[GamepadMonitorReaderOn]}"
                           Visibility="{Binding IsGamepadRunning, Converter={StaticResource BoolToVis}}" />
                <TextBlock FontSize="11"
                           VerticalAlignment="Center"
                           Text="{Binding Source={StaticResource Loc}, Path=[GamepadMonitorReaderOff]}"
                           Visibility="{Binding IsGamepadRunning, Converter={StaticResource InverseBoolToVis}, ConverterParameter=Inverse}" />
            </StackPanel>

            <Grid Margin="0,6,0,0" HorizontalAlignment="Left">
                <ToggleButton x:Name="AnalogSettingsButton"
                              Style="{StaticResource AppSettingsToolbarToggleStyle}"
                              HorizontalAlignment="Left"
                              MinWidth="0"
                              ToolTip="{Binding Source={StaticResource Loc}, Path=[AnalogSettings]}">
                    <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[AnalogSettings]}"
                               VerticalAlignment="Center" />
                </ToggleButton>
                <Popup Placement="Bottom"
                       PlacementTarget="{Binding ElementName=AnalogSettingsButton}"
                       StaysOpen="False"
                       IsOpen="{Binding IsChecked, ElementName=AnalogSettingsButton, Mode=TwoWay}">
                    <Border Style="{StaticResource SectionCardBorder}"
                            MinWidth="280"
                            MaxWidth="360"
                            Padding="12"
                            DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=UserControl}}">
                        <ScrollViewer VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Disabled"
                                      MaxHeight="480">
                            <StackPanel>
                                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ThumbstickDeadzoneHeader]}"
                                           FontWeight="SemiBold"
                                           Margin="0,0,0,8" />

                                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[LeftStickLabel]}"
                                           Margin="0,0,0,2" />
                                <DockPanel Margin="0,0,0,6" LastChildFill="True">
                                    <Slider DockPanel.Dock="Left"
                                            Minimum="0"
                                            Maximum="0.4"
                                            Value="{Binding LeftThumbstickDeadzone, Mode=TwoWay}"
                                            TickFrequency="0.01"
                                            IsSnapToTickEnabled="True"
                                            Width="160" />
                                    <TextBlock Text="{Binding LeftThumbstickDeadzone, StringFormat={}{0:0.00}}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" />
                                </DockPanel>

                                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[RightStickLabel]}"
                                           Margin="0,4,0,2" />
                                <DockPanel Margin="0,0,0,8" LastChildFill="True">
                                    <Slider DockPanel.Dock="Left"
                                            Minimum="0"
                                            Maximum="0.4"
                                            Value="{Binding RightThumbstickDeadzone, Mode=TwoWay}"
                                            TickFrequency="0.01"
                                            IsSnapToTickEnabled="True"
                                            Width="160" />
                                    <TextBlock Text="{Binding RightThumbstickDeadzone, StringFormat={}{0:0.00}}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" />
                                </DockPanel>

                                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TriggerDeadzoneHeader]}"
                                           FontWeight="SemiBold"
                                           Margin="0,12,0,8" />

                                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[LeftTriggerLabel]}"
                                           Margin="0,0,0,2" />
                                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TriggerInnerDeadzoneShort]}"
                                           Margin="0,0,0,2"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                <DockPanel Margin="0,0,0,4" LastChildFill="True">
                                    <Slider DockPanel.Dock="Left"
                                            Minimum="0"
                                            Maximum="0.4"
                                            Value="{Binding LeftTriggerInnerDeadzone, Mode=TwoWay}"
                                            TickFrequency="0.01"
                                            IsSnapToTickEnabled="True"
                                            Width="160" />
                                    <TextBlock Text="{Binding LeftTriggerInnerDeadzone, StringFormat={}{0:0.00}}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" />
                                </DockPanel>
                                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TriggerOuterDeadzoneShort]}"
                                           Margin="0,0,0,2"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                <DockPanel Margin="0,0,0,6" LastChildFill="True">
                                    <Slider DockPanel.Dock="Left"
                                            Minimum="0.02"
                                            Maximum="1"
                                            Value="{Binding LeftTriggerOuterDeadzone, Mode=TwoWay}"
                                            TickFrequency="0.01"
                                            IsSnapToTickEnabled="True"
                                            Width="160" />
                                    <TextBlock Text="{Binding LeftTriggerOuterDeadzone, StringFormat={}{0:0.00}}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" />
                                </DockPanel>

                                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[RightTriggerLabel]}"
                                           Margin="0,4,0,2" />
                                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TriggerInnerDeadzoneShort]}"
                                           Margin="0,0,0,2"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                <DockPanel Margin="0,0,0,4" LastChildFill="True">
                                    <Slider DockPanel.Dock="Left"
                                            Minimum="0"
                                            Maximum="0.4"
                                            Value="{Binding RightTriggerInnerDeadzone, Mode=TwoWay}"
                                            TickFrequency="0.01"
                                            IsSnapToTickEnabled="True"
                                            Width="160" />
                                    <TextBlock Text="{Binding RightTriggerInnerDeadzone, StringFormat={}{0:0.00}}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" />
                                </DockPanel>
                                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TriggerOuterDeadzoneShort]}"
                                           Margin="0,0,0,2"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                <DockPanel LastChildFill="True">
                                    <Slider DockPanel.Dock="Left"
                                            Minimum="0.02"
                                            Maximum="1"
                                            Value="{Binding RightTriggerOuterDeadzone, Mode=TwoWay}"
                                            TickFrequency="0.01"
                                            IsSnapToTickEnabled="True"
                                            Width="160" />
                                    <TextBlock Text="{Binding RightTriggerOuterDeadzone, StringFormat={}{0:0.00}}"
                                               Margin="8,0,0,0"
                                               VerticalAlignment="Center"
                                               HorizontalAlignment="Right" />
                                </DockPanel>
                            </StackPanel>
                        </ScrollViewer>
                    </Border>
                </Popup>
            </Grid>

            <TextBlock Margin="0,8,0,4"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Text="{Binding Source={StaticResource Loc}, Path=[GamepadMonitorAnalogMetersHeader]}" />

            <Grid TextElement.FontSize="11">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Grid.Column="0"
                           Text="{Binding LeftThumbX, StringFormat=LX {0:0.00}}" />
                <TextBlock Grid.Row="0"
                           Grid.Column="1"
                           Text="{Binding RightThumbX, StringFormat=RX {0:0.00}}" />
                <TextBlock Grid.Row="1"
                           Grid.Column="0"
                           Margin="0,2,0,0"
                           Text="{Binding LeftThumbY, StringFormat=LY {0:0.00}}" />
                <TextBlock Grid.Row="1"
                           Grid.Column="1"
                           Margin="0,2,0,0"
                           Text="{Binding RightThumbY, StringFormat=RY {0:0.00}}" />
                <TextBlock Grid.Row="2"
                           Grid.Column="0"
                           Margin="0,4,0,0"
                           Text="{Binding LeftTrigger, StringFormat=LT {0:0.00}}" />
                <TextBlock Grid.Row="2"
                           Grid.Column="1"
                           Margin="0,4,0,0"
                           Text="{Binding RightTrigger, StringFormat=RT {0:0.00}}" />
            </Grid>

            <TextBlock Margin="0,10,0,4"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Text="{Binding Source={StaticResource Loc}, Path=[GamepadMonitorActivityExpander]}" />

            <TextBlock FontSize="11"
                       Text="{Binding LastButtonPressed, StringFormat=Pressed: {0}}"
                       TextWrapping="Wrap" />
            <TextBlock FontSize="11"
                       Text="{Binding LastButtonReleased, StringFormat=Released: {0}}"
                       Margin="0,2,0,0"
                       TextWrapping="Wrap" />
            <TextBlock FontSize="11"
                       Text="{Binding LastMappedOutput, StringFormat=Mapped: {0}}"
                       Margin="0,2,0,0"
                       TextWrapping="Wrap" />
            <TextBlock FontSize="11"
                       Text="{Binding LastMappingStatus, StringFormat=Status: {0}}"
                       Margin="0,2,0,0"
                       TextWrapping="Wrap" />
            <TextBlock FontSize="11"
                       Text="{Binding ComboHudGateHint}"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource AppAccentTextBrush}" />

            <StackPanel Margin="0,10,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Left">
                <Button Content="{Binding Source={StaticResource Loc}, Path=[StopReader]}"
                        Command="{Binding StopGamepadCommand}"
                        MinWidth="68"
                        Padding="8,0"
                        Height="28"
                        FontSize="11"
                        VerticalContentAlignment="Center" />
                <Button Content="{Binding Source={StaticResource Loc}, Path=[StartReader]}"
                        Command="{Binding StartGamepadCommand}"
                        MinWidth="68"
                        Padding="8,0"
                        Height="28"
                        Margin="6,0,0,0"
                        FontSize="11"
                        VerticalContentAlignment="Center" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
