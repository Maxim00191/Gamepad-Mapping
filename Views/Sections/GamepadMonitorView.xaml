<UserControl x:Class="Gamepad_Mapping.Views.Sections.GamepadMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             VerticalAlignment="Stretch">
    <Border BorderBrush="{DynamicResource AppBorderBrush}"
            Background="{DynamicResource AppSurfaceBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="12"
            VerticalAlignment="Stretch">
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      VerticalAlignment="Stretch"
                      PanningMode="VerticalOnly">
            <StackPanel>
                <TextBlock Text="{Binding IsGamepadRunning, StringFormat=Reader running: {0}}" />

                <Separator Margin="0,10,0,10" />

                <TextBlock Text="{Binding LastButtonPressed, StringFormat=Pressed: {0}}" />
                <TextBlock Text="{Binding LastButtonReleased, StringFormat=Released: {0}}" Margin="0,2,0,0" />
                <TextBlock Text="{Binding LastMappedOutput, StringFormat=Mapped output: {0}}" Margin="0,2,0,0" />
                <TextBlock Text="{Binding LastMappingStatus, StringFormat=Output status: {0}}" Margin="0,2,0,0" TextWrapping="Wrap" />

                <Separator Margin="0,10,0,10" />

                <TextBlock Text="{Binding LeftThumbX, StringFormat=Left Thumb X: {0:0.00}}" />
                <TextBlock Text="{Binding LeftThumbY, StringFormat=Left Thumb Y: {0:0.00}}" />
                <TextBlock Text="{Binding RightThumbX, StringFormat=Right Thumb X: {0:0.00}}" />
                <TextBlock Text="{Binding RightThumbY, StringFormat=Right Thumb Y: {0:0.00}}" />

                <Separator Margin="0,10,0,10" />

                <TextBlock Text="{Binding LeftTrigger, StringFormat=Left Trigger: {0:0.00}}" />
                <TextBlock Text="{Binding RightTrigger, StringFormat=Right Trigger: {0:0.00}}" />

                <StackPanel Margin="0,16,0,0"
                            Orientation="Horizontal"
                            HorizontalAlignment="Left">
                    <Button Content="{Binding Source={StaticResource Loc}, Path=[StopReader]}"
                            Command="{Binding StopGamepadCommand}"
                            MinWidth="72"
                            Padding="10,0"
                            Height="32"
                            VerticalContentAlignment="Center" />
                    <Button Content="{Binding Source={StaticResource Loc}, Path=[StartReader]}"
                            Command="{Binding StartGamepadCommand}"
                            MinWidth="72"
                            Padding="10,0"
                            Height="32"
                            Margin="8,0,0,0"
                            VerticalContentAlignment="Center" />
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>
