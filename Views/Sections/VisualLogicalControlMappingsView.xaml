<UserControl x:Class="Gamepad_Mapping.Views.Sections.VisualLogicalControlMappingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:viewmodels="clr-namespace:Gamepad_Mapping.ViewModels"
             xmlns:utils="clr-namespace:Gamepad_Mapping.Utils"
             mc:Ignorable="d"
             d:DesignHeight="400"
             d:DesignWidth="260"
             d:DataContext="{d:DesignInstance Type=viewmodels:VisualLogicalControlMappingsViewModel}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <utils:NullToVisibilityConverter x:Key="NullToVisibilityConverter" />
    </UserControl.Resources>
    <Border Padding="12,10"
            VerticalAlignment="Stretch"
            Background="{DynamicResource VisualWorkspacePanelBackgroundBrush}"
            CornerRadius="4"
            BorderBrush="{DynamicResource VisualWorkspacePanelBorderBrush}"
            BorderThickness="1">
        <Grid MinHeight="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Grid.Row="0"
                       FontWeight="SemiBold"
                       Foreground="{DynamicResource AppTextBrush}"
                       Text="{Binding Source={StaticResource Loc}, Path=[VisualEditorLogicalControlMappingsHeader]}" />

            <TextBlock Grid.Row="1"
                       Margin="0,6,0,0"
                       TextWrapping="Wrap"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                       FontSize="12"
                       Text="{Binding Source={StaticResource Loc}, Path=[VisualEditorLogicalControlMappingsSelectHint]}"
                       Visibility="{Binding ShowSelectControlHint, Converter={StaticResource BoolToVis}}" />

            <Grid Grid.Row="2"
                  Margin="0,8,0,0"
                  MinHeight="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0"
                            Visibility="{Binding ShowUnmappedHint, Converter={StaticResource BoolToVis}}">
                    <TextBlock TextWrapping="Wrap"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                               FontSize="12"
                               Text="{Binding Source={StaticResource Loc}, Path=[VisualEditorNoMappingHint]}" />
                    <Button Margin="0,10,0,0"
                            MinWidth="160"
                            HorizontalAlignment="Left"
                            Padding="12,6"
                            Content="{Binding Source={StaticResource Loc}, Path=[VisualEditorAddMappingForControl]}"
                            Command="{Binding AddMappingForSelectedControlCommand}"
                            Visibility="{Binding HasElementContext, Converter={StaticResource BoolToVis}}" />
                </StackPanel>

                <Grid Grid.Row="1"
                      MinHeight="0"
                      Visibility="{Binding ShowMappingList, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0"
                                Margin="0,0,0,8">
                        <TextBlock FontWeight="SemiBold"
                                   FontSize="14"
                                   Foreground="{DynamicResource AppTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding ControlDisplayName}" />
                        <TextBlock Margin="0,2,0,0"
                                   FontSize="12"
                                   Foreground="{DynamicResource AppSecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Text="{Binding MappingsCountSummary}" />
                    </StackPanel>

                    <ListBox Grid.Row="1"
                             MinHeight="0"
                             Background="Transparent"
                             BorderThickness="0"
                             ItemsSource="{Binding Items}"
                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.Resources>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,6" />
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <Border x:Name="Bd"
                                                    Background="{DynamicResource VisualWorkspaceListItemBackgroundBrush}"
                                                    CornerRadius="4"
                                                    Padding="10,8"
                                                    BorderThickness="1"
                                                    BorderBrush="{DynamicResource VisualWorkspacePanelBorderBrush}">
                                                <ContentPresenter />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsSelected" Value="True">
                                                    <Setter TargetName="Bd"
                                                            Property="BorderBrush"
                                                            Value="{DynamicResource VisualWorkspaceListAccentBrush}" />
                                                    <Setter TargetName="Bd"
                                                            Property="Background"
                                                            Value="{DynamicResource VisualWorkspaceListItemSelectedBackgroundBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="Bd"
                                                            Property="BorderBrush"
                                                            Value="{DynamicResource VisualWorkspaceListItemHoverBorderBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.Resources>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding ActionSummaryLine}"
                                               FontWeight="SemiBold"
                                               FontSize="14"
                                               Foreground="{DynamicResource AppTextBrush}"
                                               TextWrapping="Wrap" />
                                    <TextBlock Margin="0,4,0,0"
                                               Text="{Binding InputSummaryLine}"
                                               FontSize="12"
                                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               TextWrapping="Wrap"
                                               Visibility="{Binding InputSummaryLine, Converter={StaticResource NullToVisibilityConverter}}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <Button Grid.Row="2"
                            Margin="0,10,0,0"
                            MinWidth="160"
                            HorizontalAlignment="Left"
                            Padding="12,6"
                            Content="{Binding Source={StaticResource Loc}, Path=[VisualEditorAddMappingForControl]}"
                            Command="{Binding AddMappingForSelectedControlCommand}" />
                </Grid>
            </Grid>
        </Grid>
    </Border>
</UserControl>
