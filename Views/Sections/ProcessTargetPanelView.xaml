<UserControl x:Class="Gamepad_Mapping.Views.Sections.ProcessTargetPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border BorderBrush="{DynamicResource AppBorderBrush}"
            Background="{DynamicResource AppSurfaceBrush}"
            BorderThickness="1"
            CornerRadius="6"
            Padding="12">
        <StackPanel>
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ProcessTarget]}"
                       FontWeight="Bold"
                       Margin="0,0,0,8" />

            <TextBlock Text="{Binding TargetStatusText}"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8" />

            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TargetProcessNameLabel]}"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding TemplateTargetProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     MinHeight="32"
                     VerticalContentAlignment="Center"
                     ToolTip="{Binding Source={StaticResource Loc}, Path=[TargetProcessNameToolTip]}" />

            <TextBlock Margin="0,10,0,0"
                       FontSize="11"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                       TextWrapping="Wrap"
                       Text="{Binding Source={StaticResource Loc}, Path=[ProcessRestrictionHint]}" />
        </StackPanel>
    </Border>
</UserControl>
