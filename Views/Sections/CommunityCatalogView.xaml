<UserControl x:Class="Gamepad_Mapping.Views.Sections.CommunityCatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="CommunityFolderCardStyle" TargetType="Border">
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppSeparatorBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
        </Style>

        <Style x:Key="CommunityTemplateCardBorderStyle" TargetType="Border">
            <Setter Property="Padding" Value="12" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Margin" Value="0,0,10,10" />
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppSeparatorBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Width" Value="300" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppSurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12" BorderBrush="{DynamicResource AppSeparatorBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="{Binding Source={StaticResource Loc}, Path=[CommunityCatalog_Header]}" 
                           FontSize="16" FontWeight="SemiBold" 
                           Foreground="{DynamicResource AppTextBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="{Binding Source={StaticResource Loc}, Path=[CommunityCatalog_Upload]}"
                            Command="{Binding UploadToCommunityCommand}"
                            Padding="12,4"
                            Margin="0,0,8,0"
                            Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                    <Border VerticalAlignment="Center"
                            SnapsToDevicePixels="True">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Cursor" Value="Arrow"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsRefreshCooldownActive}" Value="True">
                                        <Setter Property="Cursor" Value="No"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <Button Content="{Binding Source={StaticResource Loc}, Path=[Refresh]}"
                                Command="{Binding RefreshTemplatesCommand}"
                                Padding="12,4"
                                ToolTip="{Binding RefreshButtonToolTip}"
                                ToolTipService.ShowOnDisabled="True"
                                ToolTipService.InitialShowDelay="0"
                                Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                    </Border>
                </StackPanel>
                <Grid Grid.Row="1"
                      Margin="0,10,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Margin="0,0,10,0"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource AppTextBrush}"
                               Text="{Binding Source={StaticResource Loc}, Path=[CommunityCatalog_SearchLabel]}"/>
                    <TextBox Grid.Column="1"
                             MinHeight="28"
                             Padding="8,4"
                             VerticalContentAlignment="Center"
                             Text="{Binding SearchQuery, UpdateSourceTrigger=PropertyChanged}"
                             ToolTip="{Binding Source={StaticResource Loc}, Path=[CommunityCatalog_SearchPlaceholder]}"/>
                </Grid>
            </Grid>
        </Border>

        <!-- Template folders -->
        <ScrollViewer Grid.Row="1"
                      Padding="10"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="True"
                      PanningMode="VerticalFirst">
            <ItemsControl ItemsSource="{Binding FolderGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Style="{StaticResource CommunityFolderCardStyle}">
                            <Expander IsExpanded="True">
                                <Expander.Header>
                                    <Grid Margin="0,2,0,2">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding FolderName}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold" />
                                        <Border Grid.Column="1"
                                                Margin="10,0,0,0"
                                                Padding="8,2"
                                                CornerRadius="10"
                                                Background="{DynamicResource AppSelectionBrush}">
                                            <TextBlock Text="{Binding TemplateCount}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                        </Border>
                                    </Grid>
                                </Expander.Header>

                                <ItemsControl ItemsSource="{Binding AuthorGroups}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Margin="0,6,0,4">
                                                <TextBlock Text="{Binding AuthorName}"
                                                           FontSize="12"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                           Margin="2,0,0,8" />
                                                <ItemsControl ItemsSource="{Binding Templates}">
                                                    <ItemsControl.ItemsPanel>
                                                        <ItemsPanelTemplate>
                                                            <WrapPanel />
                                                        </ItemsPanelTemplate>
                                                    </ItemsControl.ItemsPanel>
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{StaticResource CommunityTemplateCardBorderStyle}"
                                                                    ToolTipService.ShowDuration="15000"
                                                                    ToolTipService.InitialShowDelay="120">
                                                                <Border.ToolTip>
                                                                    <ToolTip MaxWidth="380">
                                                                        <StackPanel>
                                                                            <TextBlock Text="{Binding ResolvedDisplayName}"
                                                                                       FontWeight="SemiBold"
                                                                                       Margin="0,0,0,4" />
                                                                            <TextBlock Text="{Binding AuthorCreditLine}"
                                                                                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                                                       Margin="0,0,0,6" />
                                                                            <TextBlock Text="{Binding Description}"
                                                                                       TextWrapping="Wrap"
                                                                                       Foreground="{DynamicResource AppTextBrush}" />
                                                                        </StackPanel>
                                                                    </ToolTip>
                                                                </Border.ToolTip>
                                                                <Grid>
                                                                    <Grid.RowDefinitions>
                                                                        <RowDefinition Height="Auto" />
                                                                        <RowDefinition Height="Auto" />
                                                                        <RowDefinition Height="*" />
                                                                        <RowDefinition Height="Auto" />
                                                                    </Grid.RowDefinitions>
                                                                    <TextBlock Grid.Row="0"
                                                                               Text="{Binding ResolvedDisplayName}"
                                                                               FontSize="13"
                                                                               FontWeight="SemiBold"
                                                                               TextWrapping="Wrap" />
                                                                    <TextBlock Grid.Row="1"
                                                                               Margin="0,2,0,0"
                                                                               Text="{Binding AuthorCreditLine}"
                                                                               FontSize="11"
                                                                               Foreground="{DynamicResource AppSecondaryTextBrush}" />
                                                                    <TextBlock Grid.Row="2"
                                                                               Margin="0,8,0,10"
                                                                               Text="{Binding Description}"
                                                                               TextWrapping="Wrap"
                                                                               Foreground="{DynamicResource AppTextBrush}" />
                                                                    <StackPanel Grid.Row="3"
                                                                                Orientation="Horizontal">
                                                                        <Button Command="{Binding DataContext.DownloadTemplateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                CommandParameter="{Binding}"
                                                                                Padding="14,5"
                                                                                ToolTipService.IsEnabled="False">
                                                                            <StackPanel Orientation="Horizontal">
                                                                                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CommunityCatalog_Download]}"
                                                                                           VerticalAlignment="Center" />
                                                                                <TextBlock Text="  ✓"
                                                                                           VerticalAlignment="Center"
                                                                                           Foreground="#2FA84F"
                                                                                           FontWeight="Bold"
                                                                                           Visibility="{Binding IsInstalledLocally, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                            </StackPanel>
                                                                        </Button>
                                                                        <Button Content="{Binding Source={StaticResource Loc}, Path=[CommunityCatalog_Delete]}"
                                                                                Command="{Binding DataContext.DeleteTemplateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                                CommandParameter="{Binding}"
                                                                                Padding="12,5"
                                                                                Margin="8,0,0,0"
                                                                                ToolTipService.IsEnabled="False"
                                                                                Visibility="{Binding IsInstalledLocally, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                                                    </StackPanel>
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Expander>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Status & Loading -->
        <Border Grid.Row="2" Padding="8" Background="{DynamicResource AppControlSurfaceAltBrush}"
                Visibility="{Binding StatusMessage, Converter={StaticResource StringHasContentToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <ProgressBar IsIndeterminate="True" Width="16" Height="16" Margin="0,0,8,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <TextBlock Text="{Binding StatusMessage}" 
                           FontSize="11" 
                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
