<UserControl x:Class="Gamepad_Mapping.Views.Sections.CommunityCatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:Gamepad_Mapping.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <Style x:Key="CommunityFolderHeaderToggleStyle" TargetType="ToggleButton">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Path x:Name="Arrow"
                                  Grid.Column="0"
                                  Width="7"
                                  Height="7"
                                  Margin="0,0,6,0"
                                  VerticalAlignment="Center"
                                  Fill="{DynamicResource AppSecondaryTextBrush}"
                                  Data="M 0 0 L 7 3.5 L 0 7 Z" />
                            <ContentPresenter Grid.Column="1"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="90" CenterX="3.5" CenterY="3.5" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource AppTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CommunityFolderExpanderStyle" TargetType="Expander">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Margin" Value="0,0,0,6" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Expander">
                        <StackPanel>
                            <ToggleButton x:Name="HeaderSite"
                                          Style="{StaticResource CommunityFolderHeaderToggleStyle}"
                                          IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          Content="{TemplateBinding Header}"
                                          ContentTemplate="{TemplateBinding HeaderTemplate}"
                                          ContentTemplateSelector="{TemplateBinding HeaderTemplateSelector}" />
                            <Border x:Name="ContentSite"
                                    Margin="14,4,0,0"
                                    Visibility="Collapsed">
                                <ContentPresenter Content="{TemplateBinding Content}"
                                                  ContentTemplate="{TemplateBinding ContentTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}" />
                            </Border>
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </UserControl.Resources>

    <Grid Background="{DynamicResource AppSurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12" BorderBrush="{DynamicResource AppSeparatorBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock Text="Community Templates" 
                           FontSize="16" FontWeight="SemiBold" 
                           Foreground="{DynamicResource AppTextBrush}"
                           VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="Upload…"
                            Command="{Binding UploadToCommunityCommand}"
                            Padding="12,4"
                            Margin="0,0,8,0"
                            Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                    <Button Content="Refresh" 
                            Command="{Binding RefreshTemplatesCommand}"
                            Padding="12,4"
                            Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Template folders -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding FolderGroups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Expander IsExpanded="False"
                                  Style="{StaticResource CommunityFolderExpanderStyle}">
                            <Expander.Header>
                                <DockPanel LastChildFill="False">
                                    <TextBlock Text="{Binding FolderName}"
                                               FontSize="13"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource AppTextBrush}"/>
                                    <TextBlock Text="{Binding Templates.Count, StringFormat=' ({0})'}"
                                               Margin="6,0,0,0"
                                               FontSize="11"
                                               Foreground="{DynamicResource AppSecondaryTextBrush}"/>
                                </DockPanel>
                            </Expander.Header>

                            <ItemsControl ItemsSource="{Binding Templates}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12" BorderBrush="{DynamicResource AppSeparatorBrush}" BorderThickness="0,0,0,1">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding DisplayName}"
                                                               FontSize="14" FontWeight="Bold"
                                                               Foreground="{DynamicResource AppTextBrush}"/>
                                                    <TextBlock Text="{Binding Author, StringFormat='By: {0}'}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                               Margin="0,2,0,4"/>
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                                                               TextWrapping="Wrap"/>
                                                </StackPanel>

                                                <Button Grid.Column="1"
                                                        Content="Download"
                                                        Command="{Binding DataContext.DownloadTemplateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        VerticalAlignment="Center"
                                                        Padding="16,6"
                                                        Margin="12,0,0,0"/>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </Expander>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Status & Loading -->
        <Border Grid.Row="2" Padding="8" Background="{DynamicResource AppControlSurfaceAltBrush}"
                Visibility="{Binding StatusMessage, Converter={StaticResource StringHasContentToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <ProgressBar IsIndeterminate="True" Width="16" Height="16" Margin="0,0,8,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <TextBlock Text="{Binding StatusMessage}" 
                           FontSize="11" 
                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
