<UserControl x:Class="Gamepad_Mapping.Views.Sections.CommunityCatalogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:vm="clr-namespace:Gamepad_Mapping.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid Background="{DynamicResource AppSurfaceBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="12" BorderBrush="{DynamicResource AppSeparatorBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock Text="Community Templates" 
                           FontSize="16" FontWeight="SemiBold" 
                           Foreground="{DynamicResource AppTextBrush}"
                           VerticalAlignment="Center"/>
                <Button Content="Refresh" 
                        Command="{Binding RefreshTemplatesCommand}"
                        HorizontalAlignment="Right"
                        Padding="12,4"
                        Style="{StaticResource {x:Static ToolBar.ButtonStyleKey}}"/>
            </Grid>
        </Border>

        <!-- Template List -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <ItemsControl ItemsSource="{Binding Templates}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Padding="12" BorderBrush="{DynamicResource AppSeparatorBrush}" BorderThickness="0,0,0,1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                
                                <StackPanel Grid.Column="0">
                                    <TextBlock Text="{Binding DisplayName}" 
                                               FontSize="14" FontWeight="Bold" 
                                               Foreground="{DynamicResource AppTextBrush}"/>
                                    <TextBlock Text="{Binding Author, StringFormat='By: {0}'}" 
                                               FontSize="12" 
                                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               Margin="0,2,0,4"/>
                                    <TextBlock Text="{Binding Description}" 
                                               FontSize="12" 
                                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                                               TextWrapping="Wrap"/>
                                </StackPanel>

                                <Button Grid.Column="1" 
                                        Content="Download" 
                                        Command="{Binding DataContext.DownloadTemplateCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                        CommandParameter="{Binding}"
                                        VerticalAlignment="Center"
                                        Padding="16,6"
                                        Margin="12,0,0,0"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- Status & Loading -->
        <Border Grid.Row="2" Padding="8" Background="{DynamicResource AppControlSurfaceAltBrush}"
                Visibility="{Binding StatusMessage, Converter={StaticResource StringHasContentToVisibilityConverter}}">
            <StackPanel Orientation="Horizontal">
                <ProgressBar IsIndeterminate="True" Width="16" Height="16" Margin="0,0,8,0"
                             Visibility="{Binding IsLoading, Converter={StaticResource BooleanToVisibilityConverter}}"/>
                <TextBlock Text="{Binding StatusMessage}" 
                           FontSize="11" 
                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                           VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
