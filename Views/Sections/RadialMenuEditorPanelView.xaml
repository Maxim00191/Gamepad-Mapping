<UserControl x:Class="Gamepad_Mapping.Views.Sections.RadialMenuEditorPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sections="clr-namespace:Gamepad_Mapping.Views.Sections"
             xmlns:views="clr-namespace:Gamepad_Mapping.Views"
             MinHeight="0"
             VerticalAlignment="Stretch">
    <Grid MinHeight="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="0" />
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0"
                      MinHeight="0"
                      VerticalAlignment="Stretch"
                      VerticalScrollBarVisibility="Auto">
        <StackPanel DataContext="{Binding SelectedRadialMenu}">
            <TextBlock Style="{StaticResource WorkspaceSectionTitleStyle}"
                       Text="{Binding Source={StaticResource Loc}, Path=[ProfileEditorRadialMenuTitle]}" />
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ProfileEditorRadialMenuHint]}"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12" />
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CatalogColumnId]}"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10" />
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CatalogColumnDisplayName]}"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding DataContext.RadialMenuDisplayNamePrimary, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,6" />
            <TextBlock Text="{Binding DataContext.DescriptionOptionalLanguageCaption, RelativeSource={RelativeSource AncestorType=views:MainView}}"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding DataContext.RadialMenuDisplayNameSecondary, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10" />
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CatalogColumnJoystick]}"
                       Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding DataContext.JoystickStickOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      SelectedItem="{Binding Joystick, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      Margin="0,0,0,16" />

            <Separator Margin="0,4,0,12" />

            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CatalogRadialSlotsHeader]}"
                       Style="{StaticResource WorkspaceSectionTitleStyle}"
                       FontSize="12"
                       Margin="0,0,0,6" />
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CatalogRadialSlotsHint]}"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8" />
            <WrapPanel Orientation="Horizontal"
                       Margin="0,0,0,8">
                <Button Content="{Binding Source={StaticResource Loc}, Path=[CatalogAddRow]}"
                        Command="{Binding DataContext.AddRadialSlotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Padding="10,4"
                        Margin="0,0,8,4" />
                <Button Content="{Binding Source={StaticResource Loc}, Path=[RemoveSelected]}"
                        Command="{Binding DataContext.RemoveRadialSlotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Padding="10,4"
                        Margin="0,0,0,4" />
            </WrapPanel>
            <DataGrid ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      SelectedItem="{Binding DataContext.SelectedRadialSlot, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                      SelectionUnit="FullRow"
                      MaxHeight="320"
                      VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="{Binding Source={StaticResource Loc}, Path=[CatalogColumnActionId]}"
                                            Width="1.2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ActionId}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.KeyboardActions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding ActionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                                    <ComboBox.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock VerticalAlignment="Center">
                                                <TextBlock.Text>
                                                    <MultiBinding Converter="{StaticResource KeyboardActionPickerLabelConverter}">
                                                        <Binding Path="Id" />
                                                        <Binding Path="ResolvedCatalogDescription" />
                                                        <Binding Source="{StaticResource Loc}" Path="[KeyboardActionPicker_OptionFormat]" />
                                                        <Binding Source="{StaticResource Loc}" Path="[MappingActionIdManual]" />
                                                        <Binding Path="KeyboardKey" />
                                                    </MultiBinding>
                                                </TextBlock.Text>
                                            </TextBlock>
                                        </DataTemplate>
                                    </ComboBox.ItemTemplate>
                                </ComboBox>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{Binding Source={StaticResource Loc}, Path=[CatalogColumnIcon]}"
                                        Binding="{Binding Icon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="0.9*" />
                    <DataGridTextColumn Width="1*"
                                        Binding="{Binding LabelPrimary, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{Binding DataContext.RadialSlotHudLinePrimaryColumnHeader, RelativeSource={RelativeSource AncestorType=views:MainView}}" />
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                    <DataGridTextColumn Width="1*"
                                        Binding="{Binding LabelSecondary, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                        <DataGridTextColumn.Header>
                            <TextBlock Text="{Binding DataContext.RadialSlotHudLineSecondaryColumnHeader, RelativeSource={RelativeSource AncestorType=views:MainView}}" />
                        </DataGridTextColumn.Header>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
