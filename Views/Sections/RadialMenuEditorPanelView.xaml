<UserControl x:Class="Gamepad_Mapping.Views.Sections.RadialMenuEditorPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sections="clr-namespace:Gamepad_Mapping.Views.Sections"
             xmlns:utils="clr-namespace:Gamepad_Mapping.Utils"
             MinHeight="0"
             VerticalAlignment="Stretch">
    <UserControl.Resources>
        <utils:StringHasContentToVisibilityConverter x:Key="StringHasContentToVis" />
    </UserControl.Resources>
    <Grid MinHeight="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="0" />
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0"
                      MinHeight="0"
                      VerticalAlignment="Stretch"
                      VerticalScrollBarVisibility="Auto">
        <StackPanel DataContext="{Binding SelectedRadialMenu}">
            <TextBlock Style="{StaticResource WorkspaceSectionTitleStyle}"
                       Text="{Binding Source={StaticResource Loc}, Path=[ProfileEditorRadialMenuTitle]}" />
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ProfileEditorRadialMenuHint]}"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12" />
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CatalogColumnId]}"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10" />
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CatalogColumnDisplayName]}"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding DisplayName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10" />
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CatalogColumnJoystick]}"
                       Margin="0,0,0,4" />
            <ComboBox ItemsSource="{Binding DataContext.JoystickStickOptions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                      SelectedItem="{Binding Joystick, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                      Margin="0,0,0,16" />

            <Separator Margin="0,4,0,12" />

            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CatalogRadialSlotsHeader]}"
                       Style="{StaticResource WorkspaceSectionTitleStyle}"
                       FontSize="12"
                       Margin="0,0,0,6" />
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CatalogRadialSlotsHint]}"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,0,0,8" />
            <WrapPanel Orientation="Horizontal"
                       Margin="0,0,0,8">
                <Button Content="{Binding Source={StaticResource Loc}, Path=[CatalogAddRow]}"
                        Command="{Binding DataContext.AddRadialSlotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Padding="10,4"
                        Margin="0,0,8,4" />
                <Button Content="{Binding Source={StaticResource Loc}, Path=[RemoveSelected]}"
                        Command="{Binding DataContext.RemoveRadialSlotCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                        Padding="10,4"
                        Margin="0,0,0,4" />
            </WrapPanel>
            <DataGrid ItemsSource="{Binding Items}"
                      AutoGenerateColumns="False"
                      CanUserAddRows="False"
                      HeadersVisibility="Column"
                      SelectedItem="{Binding DataContext.SelectedRadialSlot, RelativeSource={RelativeSource AncestorType=UserControl}, Mode=TwoWay}"
                      SelectionUnit="FullRow"
                      MaxHeight="280"
                      VerticalScrollBarVisibility="Auto"
                      ScrollViewer.HorizontalScrollBarVisibility="Auto">
                <DataGrid.Columns>
                    <DataGridTemplateColumn Header="{Binding Source={StaticResource Loc}, Path=[CatalogColumnActionId]}"
                                            Width="1.2*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding ActionId}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <ComboBox ItemsSource="{Binding DataContext.KeyboardActions, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                          DisplayMemberPath="Id"
                                          SelectedValuePath="Id"
                                          SelectedValue="{Binding ActionId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn Header="{Binding Source={StaticResource Loc}, Path=[CatalogColumnIcon]}"
                                        Binding="{Binding Icon, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="0.9*" />
                    <DataGridTextColumn Header="{Binding Source={StaticResource Loc}, Path=[CatalogColumnHudLabel]}"
                                        Binding="{Binding Label, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        Width="1*" />
                </DataGrid.Columns>
            </DataGrid>

            <Border Visibility="{Binding DataContext.CatalogPanel.ValidationError, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource StringHasContentToVis}}"
                    Background="#1AEB5757"
                    BorderBrush="#EB5757"
                    BorderThickness="1,0,0,0"
                    Padding="12,8"
                    Margin="0,20,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Path Data="M12,2C6.48,2,2,6.48,2,12s4.48,10,10,10,10-4.48,10-10S17.52,2,12,2Zm1,15h-2v-2h2v2Zm0-4h-2V7h2v6Z"
                              Fill="#EB5757" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Validation Errors" Foreground="#EB5757" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding DataContext.CatalogPanel.ValidationError, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                               Foreground="{DynamicResource AppTextBrush}" TextWrapping="Wrap" FontSize="12" Opacity="0.9"/>
                </StackPanel>
            </Border>

            <Border Visibility="{Binding DataContext.CatalogPanel.ValidationWarning, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource StringHasContentToVis}}"
                    Background="#1AF2994A"
                    BorderBrush="#F2994A"
                    BorderThickness="1,0,0,0"
                    Padding="12,8"
                    Margin="0,12,0,0">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <Path Data="M1,21H23L12,2L1,21ZM13,18H11V16H13V18ZM13,14H11V10H13V14Z"
                              Fill="#F2994A" Width="14" Height="14" Stretch="Uniform" Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="Validation Warnings" Foreground="#F2994A" FontWeight="SemiBold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <TextBlock Text="{Binding DataContext.CatalogPanel.ValidationWarning, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                               Foreground="{DynamicResource AppTextBrush}" TextWrapping="Wrap" FontSize="12" Opacity="0.9"/>
                </StackPanel>
            </Border>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
