<UserControl x:Class="Gamepad_Mapping.Views.Sections.KeyboardActionEditorPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="0"
             VerticalAlignment="Stretch">
    <Grid MinHeight="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="0" />
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0"
                      MinHeight="0"
                      VerticalAlignment="Stretch"
                      VerticalScrollBarVisibility="Auto">
        <StackPanel DataContext="{Binding SelectedKeyboardAction}">
            <TextBlock Style="{StaticResource WorkspaceSectionTitleStyle}"
                       Text="{Binding Source={StaticResource Loc}, Path=[ProfileEditorKeyboardActionTitle]}" />
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ProfileEditorKeyboardActionHint]}"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12" />
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CatalogColumnId]}"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10" />
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CatalogColumnKeyboardKey]}"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding KeyboardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10" />
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CatalogColumnDescription]}"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="72"
                     VerticalScrollBarVisibility="Auto" />
            
            <StackPanel Visibility="{Binding DataContext.CatalogPanel.HasValidationError, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Margin="0,12,0,0">
                <TextBlock Text="Validation Errors:" Foreground="Red" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding DataContext.CatalogPanel.ValidationError, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                           Foreground="Red" TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Visibility="{Binding DataContext.CatalogPanel.HasValidationWarning, RelativeSource={RelativeSource AncestorType=UserControl}, Converter={StaticResource BooleanToVisibilityConverter}}"
                        Margin="0,8,0,0">
                <TextBlock Text="Validation Warnings:" Foreground="Orange" FontWeight="Bold" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding DataContext.CatalogPanel.ValidationWarning, RelativeSource={RelativeSource AncestorType=UserControl}}" 
                           Foreground="Orange" TextWrapping="Wrap"/>
            </StackPanel>
        </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
