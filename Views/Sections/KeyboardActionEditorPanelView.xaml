<UserControl x:Class="Gamepad_Mapping.Views.Sections.KeyboardActionEditorPanelView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:utils="clr-namespace:Gamepad_Mapping.Utils"
             xmlns:views="clr-namespace:Gamepad_Mapping.Views"
             MinHeight="0"
             VerticalAlignment="Stretch">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <utils:KeyboardCatalogOutputKindToLocalizationConverter x:Key="CatalogOutputKindToLoc" />
        <utils:ItemCycleDirectionToLocalizationConverter x:Key="ItemCycleDirToLoc" />
    </UserControl.Resources>
    <Grid MinHeight="0">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" MinHeight="0" />
        </Grid.RowDefinitions>
        <ScrollViewer Grid.Row="0"
                      MinHeight="0"
                      VerticalAlignment="Stretch"
                      VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="0,0,0,16">
            <TextBlock Style="{StaticResource WorkspaceSectionTitleStyle}"
                       Text="{Binding Source={StaticResource Loc}, Path=[ProfileEditorKeyboardActionTitle]}" />
            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ProfileEditorKeyboardActionHint]}"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,0,0,12" />

            <TextBlock Text="{Binding KeyboardKeyCapturePrompt}"
                       Foreground="{DynamicResource AppAccentTextBrush}"
                       Margin="0,0,0,8" />

            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CatalogColumnId]}"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding SelectedKeyboardAction.Id, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Margin="0,0,0,10" />

            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CatalogColumnOutputKind]}"
                       Margin="0,0,0,4" />
            <ComboBox Margin="0,0,0,10"
                      ItemsSource="{Binding CatalogOutputKindOptions}"
                      SelectedItem="{Binding CatalogOutputKind, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                <ComboBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Converter={StaticResource CatalogOutputKindToLoc}}" />
                    </DataTemplate>
                </ComboBox.ItemTemplate>
            </ComboBox>

            <StackPanel Visibility="{Binding IsCatalogKeyboardSectionVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CatalogColumnKeyboardKey]}"
                           Margin="0,0,0,4" />
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox Grid.Column="0"
                              ItemsSource="{Binding AvailableKeys}"
                              SelectedItem="{Binding SelectedKeyboardAction.KeyboardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              IsEditable="True" />
                    <Button Grid.Column="1"
                            Content="{Binding Source={StaticResource Loc}, Path=[RecordKey]}"
                            Command="{Binding RecordKeyboardKeyCommand}"
                            Margin="8,0,0,0" />
                </Grid>
            </StackPanel>

            <StackPanel Visibility="{Binding IsCatalogTemplateToggleSectionVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TemplateToggleAlternateProfile]}"
                           Margin="0,0,0,4" />
                <ComboBox Margin="0,0,0,10"
                          ItemsSource="{Binding AvailableProfileTemplates}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="ProfileId"
                          SelectedValue="{Binding SelectedKeyboardAction.TemplateToggle.AlternateProfileId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Visibility="{Binding IsCatalogRadialMenuSectionVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[MappingSelectRadialMenu]}"
                           Margin="0,0,0,4" />
                <ComboBox Margin="0,0,0,10"
                          ItemsSource="{Binding AvailableRadialMenus}"
                          DisplayMemberPath="DisplayName"
                          SelectedValuePath="Id"
                          SelectedValue="{Binding SelectedKeyboardAction.RadialMenu.RadialMenuId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>

            <StackPanel Visibility="{Binding IsCatalogItemCycleSectionVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ItemCycleDirection]}"
                           Margin="0,0,0,4" />
                <ComboBox Margin="0,0,0,10"
                          ItemsSource="{Binding AvailableItemCycleDirections}"
                          SelectedItem="{Binding SelectedKeyboardAction.ItemCycle.Direction, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}">
                    <ComboBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Converter={StaticResource ItemCycleDirToLoc}}" />
                        </DataTemplate>
                    </ComboBox.ItemTemplate>
                </ComboBox>

                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ItemCycleSlotCount]}"
                           Margin="0,0,0,4" />
                <TextBox Margin="0,0,0,10"
                         Text="{Binding SelectedKeyboardAction.ItemCycle.SlotCount, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ItemCycleLoopForwardKey]}"
                           Margin="0,0,0,4" />
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding SelectedKeyboardAction.ItemCycle.LoopForwardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Content="{Binding Source={StaticResource Loc}, Path=[Record]}"
                            Command="{Binding RecordItemCycleForwardKeyCommand}"
                            Margin="8,0,0,0" />
                </Grid>

                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[ItemCycleLoopBackwardKey]}"
                           Margin="0,0,0,4" />
                <Grid Margin="0,0,0,10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding SelectedKeyboardAction.ItemCycle.LoopBackwardKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                    <Button Grid.Column="1"
                            Content="{Binding Source={StaticResource Loc}, Path=[Record]}"
                            Command="{Binding RecordItemCycleBackwardKeyCommand}"
                            Margin="8,0,0,0" />
                </Grid>
            </StackPanel>

            <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[CatalogColumnDescription]}"
                       Margin="0,0,0,4" />
            <TextBox Text="{Binding KeyboardCatalogDescriptionPrimary, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="72"
                     VerticalScrollBarVisibility="Auto" />
            <TextBlock Text="{Binding DataContext.DescriptionOptionalLanguageCaption, RelativeSource={RelativeSource AncestorType=views:MainView}}"
                       Foreground="{DynamicResource AppSecondaryTextBrush}"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Margin="0,8,0,4" />
            <TextBox Text="{Binding KeyboardCatalogDescriptionSecondary, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="56"
                     VerticalScrollBarVisibility="Auto" />
        </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
