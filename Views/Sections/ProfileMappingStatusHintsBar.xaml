<UserControl x:Class="Gamepad_Mapping.Views.Sections.ProfileMappingStatusHintsBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="0">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Border Padding="8,4"
            Background="{DynamicResource VisualWorkspacePanelBackgroundBrush}"
            BorderBrush="{DynamicResource VisualWorkspacePanelBorderBrush}"
            BorderThickness="0,1,0,0"
            CornerRadius="4">
        <StackPanel>
            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding HasUnusedActionIds, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="&#xE946;"
                           FontFamily="Segoe MDL2 Assets"
                           Foreground="#007ACC"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBlock Text="{Binding UnusedActionIdsHint}"
                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           ToolTipService.InitialShowDelay="100">
                    <TextBlock.ToolTip>
                        <ToolTip Background="{DynamicResource VisualWorkspacePanelBackgroundBrush}"
                                 Foreground="{DynamicResource AppTextBrush}"
                                 BorderBrush="{DynamicResource VisualWorkspacePanelBorderBrush}">
                            <StackPanel Margin="4">
                                <TextBlock FontWeight="Bold"
                                           Margin="0,0,0,4"
                                           Text="{Binding Source={StaticResource Loc}, Path=[ProfileMappingUnusedCatalogActionIdsTooltipTitle]}" />
                                <TextBlock Text="{Binding UnusedActionIdsTooltip}" />
                            </StackPanel>
                        </ToolTip>
                    </TextBlock.ToolTip>
                </TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Margin="0,4,0,0"
                        Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="&#xE783;"
                           FontFamily="Segoe MDL2 Assets"
                           Foreground="Red"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBlock Foreground="Red"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Text="{Binding Source={StaticResource Loc}, Path=[ProfileMappingValidationErrorsShort]}">
                    <TextBlock.ToolTip>
                        <ToolTip Background="{DynamicResource VisualWorkspacePanelBackgroundBrush}"
                                 Foreground="{DynamicResource AppTextBrush}"
                                 BorderBrush="{DynamicResource VisualWorkspacePanelBorderBrush}">
                            <StackPanel Margin="4">
                                <TextBlock FontWeight="Bold"
                                           Margin="0,0,0,4"
                                           Text="{Binding Source={StaticResource Loc}, Path=[ProfileMappingValidationErrorsTooltipTitle]}" />
                                <TextBlock Text="{Binding ValidationError}" />
                            </StackPanel>
                        </ToolTip>
                    </TextBlock.ToolTip>
                </TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Margin="0,4,0,0"
                        Visibility="{Binding HasValidationWarning, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="&#xE7BA;"
                           FontFamily="Segoe MDL2 Assets"
                           Foreground="Orange"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBlock Foreground="Orange"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Text="{Binding Source={StaticResource Loc}, Path=[ProfileMappingValidationWarningsShort]}">
                    <TextBlock.ToolTip>
                        <ToolTip Background="{DynamicResource VisualWorkspacePanelBackgroundBrush}"
                                 Foreground="{DynamicResource AppTextBrush}"
                                 BorderBrush="{DynamicResource VisualWorkspacePanelBorderBrush}">
                            <StackPanel Margin="4">
                                <TextBlock FontWeight="Bold"
                                           Margin="0,0,0,4"
                                           Text="{Binding Source={StaticResource Loc}, Path=[ProfileMappingValidationWarningsTooltipTitle]}" />
                                <TextBlock Text="{Binding ValidationWarning}" />
                            </StackPanel>
                        </ToolTip>
                    </TextBlock.ToolTip>
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
