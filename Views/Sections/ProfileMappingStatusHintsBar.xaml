<UserControl x:Class="Gamepad_Mapping.Views.Sections.ProfileMappingStatusHintsBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             MinHeight="0">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Border Padding="8,4"
            Background="{DynamicResource VisualWorkspaceHintBarBackgroundBrush}"
            BorderBrush="{DynamicResource VisualWorkspaceHintBarBorderBrush}"
            BorderThickness="0,1,0,0"
            CornerRadius="4">
        <StackPanel>
            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding HasUnusedActionIds, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="&#xE946;"
                           FontFamily="Segoe MDL2 Assets"
                           Foreground="{DynamicResource VisualWorkspaceListAccentBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBlock Text="{Binding UnusedActionIdsHint}"
                           Foreground="{DynamicResource VisualWorkspaceHintBarPrimaryForegroundBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           ToolTipService.InitialShowDelay="100">
                    <TextBlock.ToolTip>
                        <ToolTip>
                            <StackPanel Margin="4">
                                <TextBlock FontWeight="Bold"
                                           Margin="0,0,0,4"
                                           Foreground="{DynamicResource AppTextBrush}"
                                           Text="{Binding Source={StaticResource Loc}, Path=[ProfileMappingUnusedCatalogActionIdsTooltipTitle]}" />
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           Text="{Binding UnusedActionIdsTooltip}"
                                           TextWrapping="Wrap"
                                           MaxWidth="420" />
                            </StackPanel>
                        </ToolTip>
                    </TextBlock.ToolTip>
                </TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Margin="0,4,0,0"
                        Visibility="{Binding HasDuplicateActionIds, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="&#xE8C8;"
                           FontFamily="Segoe MDL2 Assets"
                           Foreground="{DynamicResource AppSemanticWarningForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBlock Text="{Binding DuplicateActionIdsHint}"
                           Foreground="{DynamicResource VisualWorkspaceHintBarPrimaryForegroundBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           TextTrimming="CharacterEllipsis"
                           ToolTipService.InitialShowDelay="100">
                    <TextBlock.ToolTip>
                        <ToolTip>
                            <StackPanel Margin="4">
                                <TextBlock FontWeight="Bold"
                                           Margin="0,0,0,4"
                                           Foreground="{DynamicResource AppTextBrush}"
                                           Text="{Binding Source={StaticResource Loc}, Path=[ProfileMappingDuplicateCatalogActionIdsTooltipTitle]}" />
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           Text="{Binding DuplicateActionIdsTooltip}"
                                           TextWrapping="Wrap"
                                           MaxWidth="420" />
                            </StackPanel>
                        </ToolTip>
                    </TextBlock.ToolTip>
                </TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Margin="0,4,0,0"
                        Visibility="{Binding HasValidationError, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="&#xE783;"
                           FontFamily="Segoe MDL2 Assets"
                           Foreground="{DynamicResource AppSemanticErrorForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBlock Foreground="{DynamicResource AppSemanticErrorForegroundBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Text="{Binding Source={StaticResource Loc}, Path=[ProfileMappingValidationErrorsShort]}">
                    <TextBlock.ToolTip>
                        <ToolTip>
                            <StackPanel Margin="4">
                                <TextBlock FontWeight="Bold"
                                           Margin="0,0,0,4"
                                           Foreground="{DynamicResource AppTextBrush}"
                                           Text="{Binding Source={StaticResource Loc}, Path=[ProfileMappingValidationErrorsTooltipTitle]}" />
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           Text="{Binding ValidationError}"
                                           TextWrapping="Wrap"
                                           MaxWidth="420" />
                            </StackPanel>
                        </ToolTip>
                    </TextBlock.ToolTip>
                </TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Margin="0,4,0,0"
                        Visibility="{Binding HasValidationWarning, Converter={StaticResource BoolToVis}}">
                <TextBlock Text="&#xE7BA;"
                           FontFamily="Segoe MDL2 Assets"
                           Foreground="{DynamicResource AppSemanticWarningForegroundBrush}"
                           VerticalAlignment="Center"
                           Margin="0,0,8,0" />
                <TextBlock Foreground="{DynamicResource AppSemanticWarningForegroundBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           Text="{Binding Source={StaticResource Loc}, Path=[ProfileMappingValidationWarningsShort]}">
                    <TextBlock.ToolTip>
                        <ToolTip>
                            <StackPanel Margin="4">
                                <TextBlock FontWeight="Bold"
                                           Margin="0,0,0,4"
                                           Foreground="{DynamicResource AppTextBrush}"
                                           Text="{Binding Source={StaticResource Loc}, Path=[ProfileMappingValidationWarningsTooltipTitle]}" />
                                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           Text="{Binding ValidationWarning}"
                                           TextWrapping="Wrap"
                                           MaxWidth="420" />
                            </StackPanel>
                        </ToolTip>
                    </TextBlock.ToolTip>
                </TextBlock>
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
