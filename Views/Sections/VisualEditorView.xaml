<UserControl x:Class="Gamepad_Mapping.Views.Sections.VisualEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:Gamepad_Mapping.Behaviors"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:cvis="clr-namespace:Gamepad_Mapping.Views.Sections.ControllerVisual"
             xmlns:sections="clr-namespace:Gamepad_Mapping.Views.Sections"
             xmlns:views="clr-namespace:Gamepad_Mapping.Views"
             xmlns:viewmodels="clr-namespace:Gamepad_Mapping.ViewModels"
             mc:Ignorable="d"
             d:DesignHeight="600"
             d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=viewmodels:VisualEditorViewModel}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition MinWidth="{DynamicResource VisualWorkspaceLogicalMappingsColumnMinWidth}"
                              Width="1*" />
            <ColumnDefinition Width="{DynamicResource VisualWorkspaceVisualEditorSplitterColumnWidth}" />
            <ColumnDefinition MinWidth="{DynamicResource VisualWorkspaceVisualEditorCenterColumnMinWidth}"
                              Width="3*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Row="0"
              Grid.Column="0"
              MinHeight="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <sections:VisualLogicalControlMappingsView Grid.Row="0"
                                                        VerticalAlignment="Stretch"
                                                        DataContext="{Binding LogicalControlMappings}" />

            <Border Grid.Row="1"
                    Margin="0,10,0,0"
                    Padding="12,10"
                    Background="{DynamicResource VisualWorkspacePanelBackgroundBrush}"
                    CornerRadius="4"
                    BorderBrush="{DynamicResource VisualWorkspacePanelBorderBrush}"
                    BorderThickness="1">
                <StackPanel>
                    <ToggleButton x:Name="OverlaySettingsButton"
                                  HorizontalAlignment="Stretch"
                                  MinHeight="28"
                                  Padding="10,4"
                                  Style="{StaticResource ToolbarToggleButtonStyle}">
                        <TextBlock FontWeight="SemiBold"
                                   Text="{Binding Source={StaticResource Loc}, Path=[ControllerOverlayLabelSettingsHeader]}" />
                    </ToggleButton>
                    <ToggleButton x:Name="DescriptionOverlayButton"
                                  Margin="0,8,0,0"
                                  HorizontalAlignment="Stretch"
                                  MinHeight="28"
                                  Padding="10,4"
                                  Style="{StaticResource ToolbarToggleButtonStyle}"
                                  behaviors:ButtonAttentionAssist.IsSoftWarningHighlighted="{Binding ShouldHighlightTemplateDescriptionButton}">
                        <TextBlock FontWeight="SemiBold"
                                   Text="{Binding Source={StaticResource Loc}, Path=[TemplateCommunityDescriptionHudTitle]}" />
                    </ToggleButton>
                    <Popup Placement="Bottom"
                           PlacementTarget="{Binding ElementName=OverlaySettingsButton}"
                           StaysOpen="False"
                           IsOpen="{Binding IsChecked, ElementName=OverlaySettingsButton, Mode=TwoWay}">
                        <Border Style="{StaticResource SectionCardBorder}"
                                MinWidth="320"
                                DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=views:MainView}}">
                            <StackPanel>
                                <ComboBox MinHeight="28"
                                          Width="{DynamicResource VisualWorkspaceOverlaySettingsComboWidth}"
                                          SelectedIndex="{Binding ControllerMappingOverlayPrimaryLabelModeIndex, Mode=TwoWay}">
                                    <ComboBoxItem Content="{Binding Source={StaticResource Loc}, Path=[ControllerOverlayLabelModeActionSummary]}" />
                                    <ComboBoxItem Content="{Binding Source={StaticResource Loc}, Path=[ControllerOverlayLabelModePhysicalControl]}" />
                                    <ComboBoxItem Content="{Binding Source={StaticResource Loc}, Path=[ControllerOverlayLabelModeActionAndPhysical]}" />
                                </ComboBox>
                                <CheckBox Margin="0,10,0,0"
                                          VerticalAlignment="Center"
                                          Content="{Binding Source={StaticResource Loc}, Path=[ControllerOverlayShowSecondaryLabel]}"
                                          IsChecked="{Binding ControllerMappingOverlayShowSecondary, Mode=TwoWay}" />
                            </StackPanel>
                        </Border>
                    </Popup>
                    <Popup Placement="Bottom"
                           PlacementTarget="{Binding ElementName=DescriptionOverlayButton}"
                           StaysOpen="False"
                           IsOpen="{Binding IsChecked, ElementName=DescriptionOverlayButton, Mode=TwoWay}">
                        <Border Style="{StaticResource SectionCardBorder}"
                                MinWidth="340">
                            <StackPanel>
                                <TextBlock Text="{Binding Source={StaticResource Loc}, Path=[TemplateCommunityDescriptionHudHint]}"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                                           Margin="0,0,0,6"
                                           FontSize="11"
                                           TextWrapping="Wrap" />
                                <TextBox MinHeight="84"
                                         MaxHeight="220"
                                         Padding="6,4"
                                         TextWrapping="Wrap"
                                         AcceptsReturn="True"
                                         VerticalScrollBarVisibility="Auto"
                                         Text="{Binding TemplateCommunityListingDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                            </StackPanel>
                        </Border>
                    </Popup>
                </StackPanel>
            </Border>
        </Grid>

        <GridSplitter Grid.Row="0"
                      Grid.Column="1"
                      Width="{DynamicResource VisualWorkspaceVisualEditorSplitterWidth}"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      ResizeDirection="Columns"
                      ResizeBehavior="PreviousAndNext"
                      ShowsPreview="True" />

        <Grid Grid.Row="0"
              Grid.Column="2"
              MinHeight="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="{DynamicResource VisualWorkspaceControllerBackgroundBrush}"
                    CornerRadius="4"
                    ClipToBounds="True">
                <cvis:ControllerVisualView DataContext="{Binding ControllerVisual}" />
            </Border>

            <Border Grid.Row="1"
                    Margin="0,10,0,0"
                    Padding="12,10"
                    Background="{DynamicResource VisualWorkspacePanelBackgroundBrush}"
                    CornerRadius="4"
                    BorderBrush="{DynamicResource VisualWorkspacePanelBorderBrush}"
                    BorderThickness="1">
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center">
                        <Button MinWidth="120"
                                VerticalAlignment="Center"
                                Padding="12,6"
                                Content="{Binding Source={StaticResource Loc}, Path=[AddMapping]}"
                                Command="{Binding CreateMappingCommand}"
                                Visibility="{Binding ShowVisualCreateMappingCallout, Converter={StaticResource BoolToVis}}" />
                </StackPanel>
            </Border>
        </Grid>

        <sections:ProfileMappingStatusHintsBar Grid.Row="1"
                                              Grid.Column="0"
                                              Grid.ColumnSpan="3"
                                              Margin="0,10,0,0"
                                              DataContext="{Binding DataContext.MappingEditorPanel, RelativeSource={RelativeSource AncestorType=views:MainView}}" />
    </Grid>
</UserControl>
