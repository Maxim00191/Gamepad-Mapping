<UserControl x:Class="Gamepad_Mapping.Views.Sections.VisualEditorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:Gamepad_Mapping.Views.Sections"
             xmlns:viewmodels="clr-namespace:Gamepad_Mapping.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="800"
             d:DataContext="{d:DesignInstance Type=viewmodels:VisualEditorViewModel}">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="4">
            <local:ControllerVisualView DataContext="{Binding ControllerVisual}" />
        </Border>

        <Border Grid.Row="1"
                Margin="0,10,0,0"
                Padding="12,10"
                Background="#2D2D30"
                CornerRadius="4"
                BorderBrush="#3F3F46"
                BorderThickness="1"
                Visibility="{Binding ShowVisualCreateMappingCallout, Converter={StaticResource BoolToVis}}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock FontWeight="SemiBold" Foreground="White" TextWrapping="Wrap"
                               Text="{Binding SelectedDisplayName}" />
                    <TextBlock Margin="0,4,0,0"
                               Foreground="#AAAAAA"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Text="{Binding Source={StaticResource Loc}, Path=[VisualEditorNoMappingHint]}" />
                </StackPanel>
                <Button Grid.Column="1"
                        MinWidth="120"
                        VerticalAlignment="Center"
                        Padding="12,6"
                        Content="{Binding Source={StaticResource Loc}, Path=[AddMapping]}"
                        Command="{Binding CreateMappingCommand}" />
            </Grid>
        </Border>
    </Grid>
</UserControl>
