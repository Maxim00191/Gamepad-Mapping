<Window x:Class="Gamepad_Mapping.Views.Automation.AutomationMagnifierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title=""
        Width="168"
        Height="168"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        AllowsTransparency="True"
        Background="#CC101010"
        BorderThickness="1"
        BorderBrush="#40888888">
    <Border Padding="4">
        <Image x:Name="ZoomImage"
               Stretch="Uniform" />
    </Border>
</Window>
