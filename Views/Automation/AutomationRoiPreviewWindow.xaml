<Window x:Class="Gamepad_Mapping.Views.Automation.AutomationRoiPreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        MinWidth="520"
        MinHeight="420"
        Width="960"
        Height="720"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Background="{DynamicResource AppSurfaceBrush}"
        PreviewMouseWheel="Window_PreviewMouseWheel">
    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <DrawingBrush x:Key="RoiPreviewPixelGridBrush"
                      TileMode="Tile"
                      Viewport="0,0,16,16"
                      ViewportUnits="Absolute"
                      Opacity="0.4">
            <DrawingBrush.Drawing>
                <GeometryDrawing Brush="Transparent">
                    <GeometryDrawing.Pen>
                        <Pen Brush="#55FFFFFF" Thickness="1" />
                    </GeometryDrawing.Pen>
                    <GeometryDrawing.Geometry>
                        <GeometryGroup>
                            <LineGeometry StartPoint="0,0"
                                          EndPoint="16,0" />
                            <LineGeometry StartPoint="0,0"
                                          EndPoint="0,16" />
                        </GeometryGroup>
                    </GeometryDrawing.Geometry>
                </GeometryDrawing>
            </DrawingBrush.Drawing>
        </DrawingBrush>
    </Window.Resources>
    <DockPanel>
        <ToolBarTray DockPanel.Dock="Top"
                     Background="{DynamicResource AppSurfaceBrush}">
            <ToolBar Band="0"
                     Background="Transparent">
                <TextBlock VerticalAlignment="Center"
                           Margin="0,0,8,0"
                           Foreground="{DynamicResource AppSecondaryTextBrush}"
                           Text="{Binding Source={StaticResource Loc}, Path=[AutomationRoiPreview_Zoom]}" />
                <Slider Width="200"
                        Minimum="0.125"
                        Maximum="16"
                        LargeChange="0.5"
                        SmallChange="0.05"
                        TickFrequency="0.25"
                        IsSnapToTickEnabled="False"
                        AutoToolTipPlacement="TopLeft"
                        Value="{Binding Zoom, Mode=TwoWay}" />
                <Separator />
                <Button Command="{Binding FitCommand}"
                        Content="{Binding Source={StaticResource Loc}, Path=[AutomationRoiPreview_Fit]}" />
                <Button Command="{Binding ActualPixelsCommand}"
                        Content="{Binding Source={StaticResource Loc}, Path=[AutomationRoiPreview_ActualPixels]}" />
                <Separator />
                <ToggleButton IsChecked="{Binding IsLiveRefresh, Mode=TwoWay}"
                              Content="{Binding Source={StaticResource Loc}, Path=[AutomationRoiPreview_LiveScreen]}" />
                <Button Command="{Binding RefreshLiveCommand}"
                        Content="{Binding Source={StaticResource Loc}, Path=[AutomationRoiPreview_RefreshLive]}" />
                <Button Command="{Binding RefreshStoredCommand}"
                        Content="{Binding Source={StaticResource Loc}, Path=[AutomationRoiPreview_RefreshStored]}" />
                <Separator />
                <CheckBox IsChecked="{Binding ShowPixelGrid, Mode=TwoWay}"
                          Content="{Binding Source={StaticResource Loc}, Path=[AutomationRoiPreview_PixelGrid]}" />
                <Button Command="{Binding CopyRoiInfoCommand}"
                        Content="{Binding Source={StaticResource Loc}, Path=[AutomationRoiPreview_CopyInfo]}" />
            </ToolBar>
        </ToolBarTray>
        <StatusBar DockPanel.Dock="Bottom"
                   Background="{DynamicResource AppSurfaceBrush}">
            <StatusBarItem>
                <TextBlock Foreground="{DynamicResource AppPrimaryTextBrush}"
                           Text="{Binding RoiSummaryText}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Foreground="{DynamicResource AppPrimaryTextBrush}"
                           FontFamily="Consolas"
                           Text="{Binding CursorPixelText}" />
            </StatusBarItem>
            <Separator />
            <StatusBarItem>
                <TextBlock Foreground="{DynamicResource AppSecondaryTextBrush}"
                           TextWrapping="Wrap"
                           MaxWidth="420"
                           Text="{Binding SourceHintText}" />
            </StatusBarItem>
        </StatusBar>
        <Border Padding="8">
            <ScrollViewer x:Name="ImageScroll"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          Background="{DynamicResource AppSurfaceBrush}"
                          SizeChanged="ImageScroll_SizeChanged">
                <Grid HorizontalAlignment="Left"
                      VerticalAlignment="Top">
                    <Grid.LayoutTransform>
                        <ScaleTransform ScaleX="{Binding Zoom}"
                                        ScaleY="{Binding Zoom}" />
                    </Grid.LayoutTransform>
                    <Grid Width="{Binding ImageLayoutWidth}"
                          Height="{Binding ImageLayoutHeight}"
                          MouseMove="PreviewImageArea_MouseMove"
                          MouseLeave="PreviewImageArea_MouseLeave">
                        <Image RenderOptions.BitmapScalingMode="NearestNeighbor"
                               Stretch="None"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Top"
                               Source="{Binding PreviewImage}"
                               Width="{Binding ImageLayoutWidth}"
                               Height="{Binding ImageLayoutHeight}" />
                        <Rectangle HorizontalAlignment="Stretch"
                                   VerticalAlignment="Stretch"
                                   Fill="{StaticResource RoiPreviewPixelGridBrush}"
                                   IsHitTestVisible="False"
                                   Visibility="{Binding ShowPixelGrid, Converter={StaticResource BoolToVis}}" />
                    </Grid>
                </Grid>
            </ScrollViewer>
        </Border>
    </DockPanel>
</Window>
