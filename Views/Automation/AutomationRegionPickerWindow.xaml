<Window x:Class="Gamepad_Mapping.Views.Automation.AutomationRegionPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="RegionPicker"
        WindowStyle="None"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        Background="#01000000"
        AllowsTransparency="True"
        Cursor="Cross">
    <Grid x:Name="RootGrid">
        <Image x:Name="FreezeView"
               Stretch="None"
               HorizontalAlignment="Left"
               VerticalAlignment="Top"
               IsHitTestVisible="False" />
        <Canvas x:Name="OverlayCanvas"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Stretch"
                Background="#01000000">
            <Rectangle x:Name="SelectionBorder"
                       Stroke="#FFF1C40F"
                       StrokeThickness="2"
                       Fill="#33F1C40F"
                       RadiusX="2"
                       RadiusY="2"
                       Visibility="Collapsed" />
            <Ellipse x:Name="HandleNw"
                     Width="12"
                     Height="12"
                     Fill="#FFF1C40F"
                     Stroke="#FF222222"
                     StrokeThickness="1"
                     Visibility="Collapsed"
                     Cursor="SizeNWSE" />
            <Ellipse x:Name="HandleNe"
                     Width="12"
                     Height="12"
                     Fill="#FFF1C40F"
                     Stroke="#FF222222"
                     StrokeThickness="1"
                     Visibility="Collapsed"
                     Cursor="SizeNESW" />
            <Ellipse x:Name="HandleSw"
                     Width="12"
                     Height="12"
                     Fill="#FFF1C40F"
                     Stroke="#FF222222"
                     StrokeThickness="1"
                     Visibility="Collapsed"
                     Cursor="SizeNESW" />
            <Ellipse x:Name="HandleSe"
                     Width="12"
                     Height="12"
                     Fill="#FFF1C40F"
                     Stroke="#FF222222"
                     StrokeThickness="1"
                     Visibility="Collapsed"
                     Cursor="SizeNWSE" />
        </Canvas>
        <Border VerticalAlignment="Top"
                HorizontalAlignment="Stretch"
                Padding="12,10"
                Background="#CC101010"
                IsHitTestVisible="False">
            <TextBlock Foreground="#FFF5F5F5"
                       FontSize="13"
                       TextWrapping="Wrap"
                       Text="Drag to select. Corners resize. Arrows nudge (Shift=10px). Enter confirm, Esc cancel." />
        </Border>
    </Grid>
</Window>
