<UserControl x:Class="Gamepad_Mapping.Views.CornerToastOverlay"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d"
             d:DesignHeight="120"
             d:DesignWidth="360"
             Focusable="False">
    <Border Padding="0"
            Background="Transparent"
            Visibility="{Binding IsToastVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
        <Border MinWidth="260"
                MaxWidth="400"
                Padding="14,12,10,12"
                CornerRadius="10"
                SnapsToDevicePixels="True"
                Background="{DynamicResource AppToastBackgroundBrush}"
                BorderBrush="{DynamicResource AppBorderBrush}"
                BorderThickness="1">
            <Border.Effect>
                <DropShadowEffect BlurRadius="18"
                                  Direction="270"
                                  ShadowDepth="3"
                                  Opacity="0.28"
                                  Color="#FF000000" />
            </Border.Effect>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                            Margin="0,0,4,0">
                    <TextBlock FontWeight="SemiBold"
                               FontSize="13"
                               TextWrapping="Wrap"
                               Text="{Binding ToastTitle}" />
                    <TextBlock Margin="0,6,0,0"
                               FontSize="12"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource AppSecondaryTextBrush}"
                               Text="{Binding ToastMessage}"
                               Visibility="{Binding HasToastMessage, Converter={StaticResource BooleanToVisibilityConverter}}" />
                </StackPanel>
                <Button Grid.Column="1"
                        Width="30"
                        Height="30"
                        Padding="0"
                        Margin="0,-6,-6,-6"
                        Focusable="False"
                        VerticalAlignment="Top"
                        Command="{Binding DismissToastCommand}"
                        ToolTip="{Binding Source={StaticResource Loc}, Path=[ToastDismissTooltip]}"
                        Background="Transparent"
                        BorderThickness="0"
                        Cursor="Hand">
                    <Button.Template>
                        <ControlTemplate TargetType="{x:Type Button}">
                            <Border x:Name="CloseRoot"
                                    Background="Transparent"
                                    CornerRadius="4"
                                    SnapsToDevicePixels="True">
                                <TextBlock FontFamily="Segoe MDL2 Assets"
                                           Text="&#xE711;"
                                           FontSize="11"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           Foreground="{DynamicResource AppSecondaryTextBrush}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="CloseRoot" Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="CloseRoot" Property="Background" Value="{DynamicResource AppControlPressedBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>
    </Border>
</UserControl>
