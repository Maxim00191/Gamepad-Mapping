<Application x:Class="Gamepad_Mapping.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             xmlns:sw="clr-namespace:System.Windows;assembly=PresentationFramework"
             xmlns:controls="clr-namespace:System.Windows.Controls;assembly=PresentationFramework"
             xmlns:local="clr-namespace:Gamepad_Mapping"
             xmlns:utils="clr-namespace:Gamepad_Mapping.Utils"
             xmlns:ui="clr-namespace:Gamepad_Mapping.Behaviors"
             xmlns:services="clr-namespace:GamepadMapperGUI.Services.Infrastructure"
             ShutdownMode="OnMainWindowClose">
    <Application.Resources>
        <services:TranslationService x:Key="Loc" />
        <SolidColorBrush x:Key="AppBackgroundBrush" Color="#FFE6E3DC" />
        <SolidColorBrush x:Key="AppSurfaceBrush" Color="#FFEDEAE3" />
        <SolidColorBrush x:Key="AppBorderBrush" Color="#FF504C46" />
        <SolidColorBrush x:Key="AppTextBrush" Color="#FF24221E" />
        <SolidColorBrush x:Key="AppSecondaryTextBrush" Color="#FF736E66" />
        <SolidColorBrush x:Key="AppAccentTextBrush" Color="#FF8A6018" />
        <SolidColorBrush x:Key="AppControlSurfaceBrush" Color="#FFEDEAE3" />
        <SolidColorBrush x:Key="AppControlSurfaceAltBrush" Color="#FFE0DBD2" />
        <SolidColorBrush x:Key="AppControlHoverBrush" Color="#FFD5D0C6" />
        <SolidColorBrush x:Key="AppControlPressedBrush" Color="#FFC9C3B8" />
        <SolidColorBrush x:Key="AppAccentBrush" Color="#FF2A4A7A" />
        <SolidColorBrush x:Key="AppAccentHoverBrush" Color="#FF223C66" />
        <SolidColorBrush x:Key="AppSelectionBrush" Color="#FFDDD4C4" />
        <SolidColorBrush x:Key="AppSelectionTextBrush" Color="#FF24221E" />
        <SolidColorBrush x:Key="AppScrollTrackBrush" Color="#FFD4D1C9" />
        <SolidColorBrush x:Key="AppScrollThumbBrush" Color="#FFA8A298" />
        <SolidColorBrush x:Key="AppScrollThumbHoverBrush" Color="#FF8A847A" />
        <SolidColorBrush x:Key="AppSeparatorBrush" Color="#FFC9C3B8" />
        <SolidColorBrush x:Key="AppGridSplitterBrush" Color="#FFBCB5AA" />
        <SolidColorBrush x:Key="AppGridSplitterHoverBrush" Color="#FFB89428" />
        <SolidColorBrush x:Key="AppUnsavedChangesIndicatorBrush" Color="#FF6D4714" />
        <SolidColorBrush x:Key="AppSoftWarningBorderBrush" Color="#FF92400E" />
        <SolidColorBrush x:Key="AppSemanticWarningForegroundBrush" Color="#FF9A3412" />
        <SolidColorBrush x:Key="AppSemanticErrorForegroundBrush" Color="#FFB91C1C" />
        <SolidColorBrush x:Key="AppHudTitleBrush" Color="#FF242220" />
        <SolidColorBrush x:Key="AppHudDetailBrush" Color="#FF5F5A54" />
        <SolidColorBrush x:Key="AppToastBackgroundBrush" Color="#D2EDEAE3" />
        <SolidColorBrush x:Key="AppTooltipBackgroundBrush" Color="#FFFDFBF7" />
        <SolidColorBrush x:Key="AppTooltipBorderBrush" Color="#FF504C46" />
        <Storyboard x:Key="SoftWarningBreathingBorderStoryboard">
            <DoubleAnimation Storyboard.TargetName="SoftWarningBorder"
                             Storyboard.TargetProperty="Opacity"
                             From="0.4"
                             To="1"
                             Duration="0:0:0.95"
                             AutoReverse="True"
                             RepeatBehavior="Forever">
                <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut" />
                </DoubleAnimation.EasingFunction>
            </DoubleAnimation>
        </Storyboard>
        <SolidColorBrush x:Key="VisualWorkspacePanelBackgroundBrush" Color="#FFD4CEC4" />
        <SolidColorBrush x:Key="VisualWorkspacePanelBorderBrush" Color="#FF8F887E" />
        <SolidColorBrush x:Key="VisualWorkspaceListItemBackgroundBrush" Color="#FFDFD9D0" />
        <SolidColorBrush x:Key="VisualWorkspaceListItemSelectedBackgroundBrush" Color="#FFB8C8E0" />
        <SolidColorBrush x:Key="VisualWorkspaceListAccentBrush" Color="#FF2A4A7A" />
        <SolidColorBrush x:Key="VisualWorkspaceListItemHoverBorderBrush" Color="#FF7A7369" />
        <SolidColorBrush x:Key="VisualWorkspaceControllerBackgroundBrush" Color="#FFC9C2B6" />
        <SolidColorBrush x:Key="VisualWorkspaceHintBarBackgroundBrush" Color="#CCBEB6A8" />
        <SolidColorBrush x:Key="VisualWorkspaceHintBarBorderBrush" Color="#FF8F887E" />
        <SolidColorBrush x:Key="VisualWorkspaceHintBarPrimaryForegroundBrush" Color="#FF24221E" />
        <SolidColorBrush x:Key="VisualWorkspaceHintBarSecondaryForegroundBrush" Color="#FF524E46" />
        <SolidColorBrush x:Key="VisualWorkspaceOverlayLeaderMutedStrokeBrush" Color="#66302C26" />
        <SolidColorBrush x:Key="VisualWorkspaceOverlayLabelDotBrush" Color="#44302C26" />
        <SolidColorBrush x:Key="VisualWorkspacePathHoverFillBrush" Color="#28000000" />
        <SolidColorBrush x:Key="VisualWorkspacePathSelectedFillBrush" Color="#45000000" />
        <SolidColorBrush x:Key="VisualWorkspaceChordPartFillBrush" Color="#402A4A7A" />
        <SolidColorBrush x:Key="VisualWorkspaceStrongAccentBorderBrush" Color="#CC2A4A7A" />
        <sys:Double x:Key="VisualWorkspaceLogicalMappingsColumnMinWidth">200</sys:Double>
        <sys:Double x:Key="VisualWorkspaceVisualEditorCenterColumnMinWidth">260</sys:Double>
        <sys:Double x:Key="VisualWorkspaceVisualEditorSplitterWidth">6</sys:Double>
        <sw:GridLength x:Key="VisualWorkspaceVisualEditorSplitterColumnWidth">6</sw:GridLength>
        <sys:Double x:Key="VisualWorkspaceOverlaySettingsComboWidth">240</sys:Double>

        <Style x:Key="SectionCardBorder" TargetType="{x:Type Border}">
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="6" />
            <Setter Property="Padding" Value="12" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
        </Style>

        <Style x:Key="FlatSectionToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,4" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Grid Background="Transparent">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="14" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Path x:Name="Arrow"
                                  Grid.Column="0"
                                  Width="7"
                                  Height="7"
                                  Margin="0,0,6,0"
                                  VerticalAlignment="Center"
                                  Fill="{DynamicResource AppSecondaryTextBrush}"
                                  Data="M 0 0 L 7 3.5 L 0 7 Z" />
                            <ContentPresenter Grid.Column="1"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Arrow" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="90" CenterX="3.5" CenterY="3.5" />
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource AppTextBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="WorkspaceSectionTitleStyle" TargetType="{x:Type TextBlock}">
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="MainWorkspaceTabControl" TargetType="{x:Type TabControl}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
        </Style>

        <Style x:Key="MainWorkspaceTabItem" TargetType="{x:Type TabItem}">
            <Setter Property="Foreground" Value="{DynamicResource AppSecondaryTextBrush}" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,4,0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type TabItem}">
                        <Grid x:Name="RootGrid" SnapsToDevicePixels="True">
                            <Border x:Name="TabBd"
                                    Padding="16,12"
                                    Margin="0,0,4,0"
                                    Background="Transparent"
                                    BorderThickness="0,0,0,3"
                                    BorderBrush="Transparent"
                                    CornerRadius="4,4,0,0"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter x:Name="Content"
                                                  ContentSource="Header"
                                                  HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Border>
                            <!-- Highlight bar for selected state -->
                            <Border x:Name="SelectionIndicator"
                                    Height="3"
                                    VerticalAlignment="Bottom"
                                    Margin="0,0,4,0"
                                    Background="{DynamicResource AppAccentBrush}"
                                    Visibility="Collapsed" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                                <Setter TargetName="SelectionIndicator" Property="Visibility" Value="Visible" />
                                <Setter TargetName="TabBd" Property="Background" Value="{DynamicResource AppControlSurfaceAltBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="TabBd" Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                                <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
                            </MultiTrigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Border}">
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
        </Style>

        <!-- Toolbar icon / text toggles (shared: main toolbar, gamepad monitor). -->
        <Style x:Key="ToolbarToggleButtonStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppControlSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Grid>
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                            <Border x:Name="SoftWarningBorder"
                                    BorderBrush="{DynamicResource AppSoftWarningBorderBrush}"
                                    BorderThickness="2"
                                    CornerRadius="4"
                                    IsHitTestVisible="False"
                                    Opacity="0"
                                    SnapsToDevicePixels="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppControlPressedBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AppAccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppControlPressedBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                            <Trigger Property="ui:ButtonAttentionAssist.IsSoftWarningHighlighted" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="SoftWarningBreathingStoryboard"
                                                     Storyboard="{StaticResource SoftWarningBreathingBorderStoryboard}" />
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="SoftWarningBreathingStoryboard" />
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="ToolbarButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppControlSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                  VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                            <Border x:Name="SoftWarningBorder"
                                    BorderBrush="{DynamicResource AppSoftWarningBorderBrush}"
                                    BorderThickness="2"
                                    CornerRadius="4"
                                    IsHitTestVisible="False"
                                    Opacity="0"
                                    SnapsToDevicePixels="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppControlPressedBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AppAccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                            <Trigger Property="ui:ButtonAttentionAssist.IsSoftWarningHighlighted" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="SoftWarningBreathingStoryboard"
                                                     Storyboard="{StaticResource SoftWarningBreathingBorderStoryboard}" />
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="SoftWarningBreathingStoryboard" />
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppSettingsToolbarToggleStyle" TargetType="{x:Type ToggleButton}" BasedOn="{StaticResource ToolbarToggleButtonStyle}">
            <Setter Property="MinHeight" Value="32" />
            <Setter Property="MinWidth" Value="172" />
            <Setter Property="Padding" Value="10,0,14,0" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
        </Style>

        <Style x:Key="ExpanderHeaderToggleStyle" TargetType="{x:Type ToggleButton}">
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="2" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ToggleButton}">
                        <Border x:Name="ToggleBd"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border x:Name="ChevronHost"
                                        Grid.Column="0"
                                        Width="26"
                                        Height="26"
                                        CornerRadius="4"
                                        VerticalAlignment="Center">
                                    <Path x:Name="ChevronPath"
                                          Width="9"
                                          Height="6"
                                          Stretch="Uniform"
                                          Fill="{DynamicResource AppSecondaryTextBrush}"
                                          Data="M 0 1 L 4.5 5 L 9 1"
                                          HorizontalAlignment="Center"
                                          VerticalAlignment="Center"
                                          RenderTransformOrigin="0.5,0.5">
                                        <Path.RenderTransform>
                                            <RotateTransform Angle="-90" />
                                        </Path.RenderTransform>
                                    </Path>
                                </Border>
                                <ContentPresenter Grid.Column="1"
                                                  Margin="8,0,0,0"
                                                  VerticalAlignment="Center"
                                                  RecognizesAccessKey="True" />
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="ChevronPath" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="0" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsChecked" Value="False">
                                <Setter TargetName="ChevronPath" Property="RenderTransform">
                                    <Setter.Value>
                                        <RotateTransform Angle="-90" />
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ChevronHost" Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ToggleBd" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Expander}">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Expander}">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6"
                                SnapsToDevicePixels="True">
                            <DockPanel>
                                <Border DockPanel.Dock="Top"
                                        Background="{DynamicResource AppControlSurfaceAltBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="0,0,0,1"
                                        CornerRadius="6,6,0,0">
                                    <ToggleButton x:Name="HeaderSite"
                                                  Style="{StaticResource ExpanderHeaderToggleStyle}"
                                                  MinHeight="40"
                                                  Padding="10,8"
                                                  HorizontalContentAlignment="Stretch"
                                                  Focusable="False"
                                                  IsChecked="{Binding IsExpanded, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                                  Content="{TemplateBinding Header}"
                                                  ContentTemplate="{TemplateBinding HeaderTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding HeaderTemplateSelector}" />
                                </Border>
                                <Border x:Name="ContentSite"
                                        DockPanel.Dock="Bottom"
                                        Background="{DynamicResource AppSurfaceBrush}"
                                        CornerRadius="0,0,6,6"
                                        Padding="12"
                                        Visibility="Collapsed">
                                    <ContentPresenter Focusable="False"
                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                      VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                                                      Content="{TemplateBinding Content}"
                                                      ContentStringFormat="{TemplateBinding ContentStringFormat}"
                                                      ContentTemplate="{TemplateBinding ContentTemplate}"
                                                      ContentTemplateSelector="{TemplateBinding ContentTemplateSelector}" />
                                </Border>
                            </DockPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsExpanded" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Visible" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Separator}">
            <Setter Property="Background" Value="{DynamicResource AppSeparatorBrush}" />
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="0,6" />
        </Style>

        <Style TargetType="{x:Type GridSplitter}">
            <Setter Property="Background" Value="{DynamicResource AppGridSplitterBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type GridSplitter}">
                        <Border x:Name="SplitterRoot"
                                Background="{TemplateBinding Background}"
                                BorderThickness="0" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="SplitterRoot" Property="Background" Value="{DynamicResource AppGridSplitterHoverBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TextBlock}">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
        </Style>

        <Style TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppControlSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,6" />
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Grid>
                            <Border x:Name="Root"
                                    Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="4"
                                    SnapsToDevicePixels="True">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  Margin="{TemplateBinding Padding}" />
                            </Border>
                            <Border x:Name="SoftWarningBorder"
                                    BorderBrush="{DynamicResource AppSoftWarningBorderBrush}"
                                    BorderThickness="2"
                                    CornerRadius="4"
                                    IsHitTestVisible="False"
                                    Opacity="0"
                                    SnapsToDevicePixels="True" />
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppControlPressedBrush}" />
                                <Setter TargetName="Root" Property="BorderBrush" Value="{DynamicResource AppAccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Root" Property="Opacity" Value="0.55" />
                            </Trigger>
                            <Trigger Property="ui:ButtonAttentionAssist.IsSoftWarningHighlighted" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard x:Name="SoftWarningBreathingStoryboard"
                                                     Storyboard="{StaticResource SoftWarningBreathingBorderStoryboard}" />
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <StopStoryboard BeginStoryboardName="SoftWarningBreathingStoryboard" />
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type CheckBox}">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type CheckBox}">
                        <StackPanel Orientation="Horizontal">
                            <Border x:Name="Box"
                                    Width="18"
                                    Height="18"
                                    CornerRadius="4"
                                    Background="{DynamicResource AppControlSurfaceBrush}"
                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                    BorderThickness="1">
                                <Path x:Name="Check"
                                      Width="10"
                                      Height="8"
                                      Margin="3,4,0,0"
                                      Stroke="{DynamicResource AppAccentBrush}"
                                      StrokeThickness="2"
                                      StrokeStartLineCap="Round"
                                      StrokeEndLineCap="Round"
                                      StrokeLineJoin="Round"
                                      Data="M 0 4 L 3.2 7 L 9 1"
                                      Visibility="Collapsed" />
                            </Border>
                            <ContentPresenter Margin="8,0,0,0"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </StackPanel>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                                <Setter TargetName="Box" Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Box" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                                <Setter TargetName="Box" Property="Background" Value="{DynamicResource AppSelectionBrush}" />
                                <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type TextBox}">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppControlSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,4" />
            <Setter Property="CaretBrush" Value="{DynamicResource AppTextBrush}" />
            <Style.Triggers>
                <Trigger Property="IsKeyboardFocused" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="AppSelectionDialogListBoxStyle" TargetType="{x:Type ListBox}">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppControlSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="4" />
        </Style>

        <Style x:Key="AppSelectionDialogListBoxItemStyle" TargetType="{x:Type ListBoxItem}">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Padding" Value="8,5" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AppSelectionTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type ComboBox}">
            <Setter Property="ui:ComboBoxMouseWheelBehavior.DisableMouseWheelSelection" Value="True" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppControlSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
            <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ComboBox}">
                        <Grid>
                            <Border x:Name="ComboBorder"
                                    CornerRadius="4"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    Background="{TemplateBinding Background}" />

                            <Grid Margin="1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="30" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter x:Name="ContentSite"
                                                  Grid.Column="0"
                                                  Margin="7,2,4,2"
                                                  VerticalAlignment="Center"
                                                  HorizontalAlignment="Left"
                                                  Content="{TemplateBinding SelectionBoxItem}"
                                                  ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                                  ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}" />

                                <TextBox x:Name="PART_EditableTextBox"
                                         Grid.Column="0"
                                         Margin="6,2,3,2"
                                         Visibility="Hidden"
                                         IsReadOnly="{TemplateBinding IsReadOnly}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Foreground="{TemplateBinding Foreground}" />

                                <ToggleButton Grid.Column="1"
                                              Focusable="False"
                                              IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                              ClickMode="Press">
                                    <ToggleButton.Template>
                                        <ControlTemplate TargetType="{x:Type ToggleButton}">
                                            <Border x:Name="ArrowArea"
                                                    Background="{DynamicResource AppControlSurfaceAltBrush}"
                                                    BorderBrush="{DynamicResource AppBorderBrush}"
                                                    BorderThickness="1,0,0,0">
                                                <Path x:Name="Arrow"
                                                      Width="10"
                                                      Height="6"
                                                      VerticalAlignment="Center"
                                                      HorizontalAlignment="Center"
                                                      Fill="{DynamicResource AppSecondaryTextBrush}"
                                                      Data="M 0 0 L 10 0 L 5 6 Z" />
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter TargetName="ArrowArea" Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                                                </Trigger>
                                                <Trigger Property="IsChecked" Value="True">
                                                    <Setter TargetName="Arrow" Property="Fill" Value="{DynamicResource AppAccentBrush}" />
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </ToggleButton.Template>
                                </ToggleButton>
                            </Grid>

                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade">
                                <Border x:Name="DropDownBorder"
                                        MinWidth="{TemplateBinding ActualWidth}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                        Background="{DynamicResource AppControlSurfaceBrush}"
                                        BorderBrush="{DynamicResource AppBorderBrush}"
                                        BorderThickness="1"
                                        CornerRadius="4"
                                        SnapsToDevicePixels="True">
                                    <ScrollViewer x:Name="DropDownScrollViewer"
                                                  Margin="0"
                                                  SnapsToDevicePixels="True">
                                        <ItemsPresenter KeyboardNavigation.DirectionalNavigation="Contained" />
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsDropDownOpen" Value="True">
                                <Setter TargetName="ComboBorder" Property="BorderBrush" Value="{DynamicResource AppAccentBrush}" />
                            </Trigger>
                            <Trigger Property="HasItems" Value="False">
                                <Setter TargetName="DropDownBorder" Property="MinHeight" Value="24" />
                            </Trigger>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="ContentSite" Property="Visibility" Value="Hidden" />
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="ComboBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ComboBoxItem}">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppControlSurfaceBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="8,5" />
            <Style.Triggers>
                <Trigger Property="IsHighlighted" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                </Trigger>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AppSelectionTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type DataGrid}">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppControlSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="RowBackground" Value="{DynamicResource AppControlSurfaceBrush}" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource AppControlSurfaceAltBrush}" />
        </Style>

        <Style TargetType="{x:Type DataGridCell}">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppSelectionBrush}" />
                    <Setter Property="Foreground" Value="{DynamicResource AppSelectionTextBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style TargetType="{x:Type DataGridColumnHeader}">
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppControlSurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style x:Key="AppScrollBarLineButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="{DynamicResource AppControlSurfaceAltBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppBorderBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                SnapsToDevicePixels="True" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppControlHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppControlPressedBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppScrollBarThumbStyle" TargetType="{x:Type Thumb}">
            <Setter Property="Background" Value="{DynamicResource AppScrollThumbBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Border x:Name="Root"
                                Background="{TemplateBinding Background}"
                                CornerRadius="4"
                                Margin="2"
                                SnapsToDevicePixels="True" />
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppScrollThumbHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsDragging" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource AppAccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppScrollBarPageButtonStyle" TargetType="{x:Type RepeatButton}">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Themed slider (default WPF thumb/track ignore App* brushes — hurts dark mode). -->
        <Style x:Key="AppSliderRepeatButton" TargetType="{x:Type RepeatButton}">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="IsTabStop" Value="False" />
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type RepeatButton}">
                        <Border Background="Transparent" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AppSliderThumb" TargetType="{x:Type Thumb}">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="OverridesDefaultStyle" Value="True" />
            <Setter Property="Height" Value="16" />
            <Setter Property="Width" Value="16" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Thumb}">
                        <Ellipse Fill="{DynamicResource AppAccentBrush}"
                                 Stroke="{DynamicResource AppBorderBrush}"
                                 StrokeThickness="1" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type Slider}">
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Focusable" Value="True" />
            <Setter Property="Foreground" Value="{DynamicResource AppAccentBrush}" />
            <Setter Property="Background" Value="{DynamicResource AppScrollTrackBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Slider}">
                        <Grid SnapsToDevicePixels="True">
                            <Border Height="4"
                                    CornerRadius="2"
                                    VerticalAlignment="Center"
                                    Background="{TemplateBinding Background}" />
                            <Track x:Name="PART_Track" VerticalAlignment="Center">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource AppSliderRepeatButton}"
                                                  Command="{x:Static controls:Slider.DecreaseLarge}" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource AppSliderThumb}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource AppSliderRepeatButton}"
                                                  Command="{x:Static controls:Slider.IncreaseLarge}" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="{x:Type ToolTip}">
            <Setter Property="Background" Value="{DynamicResource AppTooltipBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource AppTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource AppTooltipBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="8,6" />
        </Style>

        <Style TargetType="{x:Type ScrollBar}">
            <Setter Property="Background" Value="{DynamicResource AppScrollTrackBrush}" />
            <Setter Property="Width" Value="12" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type ScrollBar}">
                        <Grid Background="{TemplateBinding Background}">
                            <Track x:Name="PART_Track"
                                   IsDirectionReversed="True">
                                <Track.DecreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource AppScrollBarPageButtonStyle}"
                                                  Command="ScrollBar.PageUpCommand" />
                                </Track.DecreaseRepeatButton>
                                <Track.Thumb>
                                    <Thumb Style="{StaticResource AppScrollBarThumbStyle}" />
                                </Track.Thumb>
                                <Track.IncreaseRepeatButton>
                                    <RepeatButton Style="{StaticResource AppScrollBarPageButtonStyle}"
                                                  Command="ScrollBar.PageDownCommand" />
                                </Track.IncreaseRepeatButton>
                            </Track>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="Orientation" Value="Horizontal">
                                <Setter Property="Height" Value="12" />
                                <Setter Property="Width" Value="Auto" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="False" />
                            </Trigger>
                            <Trigger Property="Orientation" Value="Vertical">
                                <Setter Property="Width" Value="12" />
                                <Setter Property="Height" Value="Auto" />
                                <Setter TargetName="PART_Track" Property="IsDirectionReversed" Value="True" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <utils:InverseBooleanConverter x:Key="InverseBooleanConverter" />
        <utils:StringHasContentToVisibilityConverter x:Key="StringHasContentToVisibilityConverter" />
        <utils:KeyboardActionPickerLabelConverter x:Key="KeyboardActionPickerLabelConverter" />
        
        <Style x:Key="AppAccentButtonStyle" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{DynamicResource AppAccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{DynamicResource AppAccentHoverBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
    </Application.Resources>
</Application>
